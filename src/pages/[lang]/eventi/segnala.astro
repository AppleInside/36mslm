---
export const prerender = false;
import Base from '../../../layouts/Base.astro';
import type { Lang } from '../../../i18n/ui';

const lang = Astro.params.lang as Lang;
const it   = lang === 'it';

const t = {
  title:    it ? 'Proponi un evento' : 'Propose an event',
  intro:    it
    ? 'Hai un evento da proporre? Raccontacelo: ti risponderemo il prima possibile.'
    : 'Got an event to suggest? Tell us about it and we will get back to you.',
  name:     it ? 'Nome' : 'First name',
  titleLbl: it ? "Titolo dell'evento" : 'Event title',
  body:     it ? 'Descrizione' : 'Description',
  bodyHint: it ? "Descrivi l'evento con il maggior dettaglio possibile." : 'Describe the event in as much detail as possible.',
  send:     it ? 'Invia proposta' : 'Send proposal',
  sending:  it ? 'Invio…' : 'Sending…',
  okTitle:  it ? 'Proposta ricevuta!' : 'Proposal received!',
  okBody:   it ? 'Grazie! Ti risponderemo il prima possibile.' : "Thank you! We'll be in touch.",
  err:      it ? 'Qualcosa è andato storto. Riprova.' : 'Something went wrong. Please try again.',
};
---

<Base title={t.title}>
  <article class="wrap">
    <h1 class="title">{t.title}</h1>
    <p class="intro">{t.intro}</p>

    <form id="segnala-form" class="form" novalidate>
      <input type="hidden" name="lang"   value={lang} />
      <input type="hidden" name="source" value="evento" />

      <label class="field">
        <span>{t.name} <span class="req">*</span></span>
        <input name="name" type="text" required maxlength="120" autocomplete="given-name" />
      </label>

      <label class="field">
        <span>Email <span class="req">*</span></span>
        <input name="email" type="email" required maxlength="200" autocomplete="email" />
      </label>

      <label class="field">
        <span>{t.titleLbl} <span class="req">*</span></span>
        <input name="subject" type="text" required maxlength="200" />
      </label>

      <label class="field">
        <span>{t.body} <span class="req">*</span></span>
        <textarea name="body" required rows="6" maxlength="5000"></textarea>
        <span class="hint">{t.bodyHint}</span>
      </label>

      <div id="form-err" class="form-err" hidden></div>

      <div class="actions">
        <button type="submit" id="segnala-submit" disabled>{t.send}</button>
      </div>
    </form>
  </article>
</Base>

<!-- Success modal -->
<div id="ok-modal" class="modal" aria-modal="true" role="dialog" hidden>
  <div class="modal-backdrop"></div>
  <div class="modal-box">
    <svg class="modal-icon" width="44" height="44" viewBox="0 0 44 44" fill="none" aria-hidden="true">
      <circle cx="22" cy="22" r="20" stroke="#3d7a6a" stroke-width="1.8"/>
      <path d="M14 22L19 27L30 16" stroke="#3d7a6a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    <h2 class="modal-title">{t.okTitle}</h2>
    <p class="modal-body">{t.okBody}</p>
  </div>
</div>

<style>
  .wrap {
    max-width: 520px;
    margin: 0 auto;
    padding: 3rem 1.25rem 5rem;
  }
  .title {
    font-family: theme('fontFamily.hand');
    font-size: clamp(2.2rem, 7vw, 3.2rem);
    font-weight: 700;
    line-height: 1.1;
    margin: 0 0 1rem;
    color: theme('colors.ink');
  }
  .intro {
    font-size: .97rem;
    color: theme('colors.ink-soft');
    line-height: 1.65;
    margin: 0 0 2rem;
  }

  /* ── Form ── */
  .form { display: flex; flex-direction: column; gap: 1.25rem; }

  .field {
    display: flex;
    flex-direction: column;
    gap: .4rem;
    font-size: .85rem;
    font-weight: 500;
    color: theme('colors.ink');
  }
  .req { color: #b5451b; }

  .field input,
  .field textarea {
    padding: .65rem .85rem;
    border: 1px solid theme('colors.rule');
    border-radius: .45rem;
    background: theme('colors.paper');
    font-family: theme('fontFamily.serif');
    font-size: .97rem;
    color: theme('colors.ink');
    outline: none;
    transition: border-color .15s;
    resize: vertical;
  }
  .field input:focus,
  .field textarea:focus { border-color: theme('colors.acquadeep'); }

  .hint {
    font-size: .75rem;
    color: theme('colors.ink-soft');
    opacity: .6;
  }

  .form-err {
    font-size: .85rem;
    color: #b5451b;
    padding: .65rem .85rem;
    border: 1px solid rgba(181,69,27,.25);
    border-radius: .45rem;
    background: rgba(181,69,27,.05);
  }

  .actions { margin-top: .5rem; }
  .actions button {
    padding: .75rem 2rem;
    border-radius: 999px;
    background: theme('colors.acquadeep');
    color: #fff;
    border: none;
    font-family: theme('fontFamily.serif');
    font-size: 1rem;
    cursor: pointer;
    transition: opacity .15s;
  }
  .actions button:hover:not(:disabled) { opacity: .88; }
  .actions button:disabled { opacity: .38; cursor: default; }

  /* ── Modal ── */
  .modal {
    position: fixed; inset: 0; z-index: 200;
    display: flex; align-items: center; justify-content: center;
    padding: 1.5rem;
  }
  .modal[hidden] { display: none; }
  .modal.is-closing {
    opacity: 0;
    pointer-events: none;
    transition: opacity .45s ease;
  }

  .modal-backdrop {
    position: absolute; inset: 0;
    background: rgba(10,16,22,.55);
    backdrop-filter: blur(6px);
    animation: bdfade .2s ease;
  }
  @keyframes bdfade { from { opacity:0; } to { opacity:1; } }

  .modal-box {
    position: relative; z-index: 1;
    background: theme('colors.sabbia');
    border-radius: 1.2rem;
    padding: 2.5rem 2.75rem;
    max-width: 380px;
    width: 100%;
    text-align: center;
    box-shadow: 0 24px 60px rgba(0,0,0,.22);
    animation: boxup .28s cubic-bezier(.2,.7,.2,1);
  }
  @keyframes boxup {
    from { opacity: 0; transform: translateY(16px) scale(.97); }
    to   { opacity: 1; transform: translateY(0)   scale(1); }
  }

  .modal-icon { margin: 0 auto 1.25rem; display: block; }
  .modal-title {
    font-family: theme('fontFamily.hand');
    font-size: 1.9rem;
    font-weight: 700;
    color: theme('colors.ink');
    margin: 0 0 .6rem;
    line-height: 1.15;
  }
  .modal-body {
    font-size: .95rem;
    color: theme('colors.ink-soft');
    line-height: 1.6;
    margin: 0;
  }
</style>

<script>
  const form    = document.getElementById('segnala-form') as HTMLFormElement;
  const submit  = document.getElementById('segnala-submit') as HTMLButtonElement;
  const formErr = document.getElementById('form-err') as HTMLElement;
  const modal   = document.getElementById('ok-modal') as HTMLElement;

  // Enable submit only when all required fields are filled
  const required = form.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>('[required]');
  function checkValidity() {
    submit.disabled = !Array.from(required).every(el => el.value.trim().length > 0);
  }
  required.forEach(el => el.addEventListener('input', checkValidity));

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    formErr.hidden = true;
    submit.disabled = true;
    submit.textContent = submit.dataset.sending ?? 'Invio…';

    try {
      const res = await fetch('/api/report', {
        method: 'POST',
        headers: { 'accept': 'application/json' },
        body: new FormData(form),
      });
      const json = await res.json();
      if (!json.ok) throw new Error();

      // Show modal, then auto-close after 3 s with fade
      modal.removeAttribute('hidden');
      document.body.style.overflow = 'hidden';
      form.reset();
      checkValidity();

      setTimeout(() => {
        modal.classList.add('is-closing');
        setTimeout(() => {
          modal.setAttribute('hidden', '');
          document.body.style.overflow = '';
          modal.classList.remove('is-closing');
        }, 450);
      }, 3000);

    } catch {
      formErr.textContent = form.dataset.err ?? 'Qualcosa è andato storto. Riprova.';
      formErr.hidden = false;
      submit.disabled = false;
      submit.textContent = form.dataset.send ?? 'Invia proposta';
    }
  });

  // Close modal on backdrop click
  modal.querySelector('.modal-backdrop')?.addEventListener('click', () => {
    modal.setAttribute('hidden', '');
    document.body.style.overflow = '';
  });
</script>
