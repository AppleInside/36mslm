---
export const prerender = false;

import Base from '../../../layouts/Base.astro';
import { formatTime } from '../../../lib/dates';
import type { Lang } from '../../../i18n/ui';
import EventSignupForm from '../../../components/EventSignupForm.astro';
import { getEvent } from '../../../server/db';
import { marked } from 'marked';

const lang = Astro.params.lang as Lang;
const slug = Astro.params.slug as string;

const event = await getEvent(lang, slug);
if (!event) return Astro.redirect(`/${lang}/eventi`);

const dateObj = new Date(event.date);
let timeObj: Date | null = null;
if (event.time_start) {
  timeObj = new Date(event.date);
  const [h, m] = event.time_start.split(':');
  timeObj.setUTCHours(parseInt(h), parseInt(m), 0, 0);
}

const timeStr = timeObj ? formatTime(timeObj, lang) : null;
const descHtml = event.description ? String(marked.parse(event.description)) : null;

const day  = dateObj.getUTCDate();
const year = dateObj.getUTCFullYear();
const monthsIt = ['gennaio','febbraio','marzo','aprile','maggio','giugno','luglio','agosto','settembre','ottobre','novembre','dicembre'];
const monthsEn = ['january','february','march','april','may','june','july','august','september','october','november','december'];
const monthStr = (lang === 'it' ? monthsIt : monthsEn)[dateObj.getUTCMonth()];
---

<Base title={event.title}>
  <div class="ev-split">

    <!-- ── Left: sticky image ── -->
    <div class:list={['ev-img-col', event.cover_type === 'locandina' && 'ev-img-col--locandina']}>
      {event.cover_url
        ? <img src={event.cover_url} alt={event.title}
            class:list={['ev-img', event.cover_type === 'locandina' && 'ev-img--locandina']} />
        : <div class="ev-img-empty">
            <span class="ev-img-num">36</span>
          </div>
      }
    </div>

    <!-- ── Right: scrollable content ── -->
    <div class="ev-content">

      <!-- Back link -->
      <a class="ev-back" href={`/${lang}/eventi/calendario`}>
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
          <path d="M10 3L5 8l5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        {lang === 'it' ? 'Tutti gli eventi' : 'All events'}
      </a>

      <!-- Date stamp + meta -->
      <div class="ev-datestamp">
        <span class="ds-day">{day}</span>
        <div class="ds-aside">
          <span class="ds-month">{monthStr}</span>
          <span class="ds-year">{year}</span>
        </div>
        {(event.location || timeStr) && (
          <div class="ds-meta">
            {event.location && (
              <span class="ds-loc">
                <span class="ds-label">Dove</span>
                <span class="ds-value">{event.location}</span>
              </span>
            )}
            {timeStr && (
              <span class="ds-time">
                <span class="ds-label">A che ora</span>
                <span class="ds-value">{timeStr}</span>
              </span>
            )}
          </div>
        )}
      </div>

      <!-- Title -->
      <h1 class="ev-title">{event.title}</h1>

      <!-- Description -->
      {descHtml && (
        <div class="ev-body" set:html={descHtml} />
      )}

      <!-- Signup -->
      {event.signup_required && (
        <div class="ev-signup">
          <EventSignupForm eventSlug={event.slug} />
        </div>
      )}

    </div>
  </div>
</Base>

<style>
  /* ── Split container ── */
  .ev-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: calc(100vh - 72px);
    align-items: start;
  }

  /* ── Left column ── */
  .ev-img-col {
    position: sticky;
    top: 72px;
    height: calc(100vh - 72px);
    overflow: hidden;
    background: theme('colors.ink');
  }
  .ev-img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
    filter: saturate(.88);
  }
  .ev-img-col--locandina { background: theme('colors.paper'); }
  .ev-img--locandina {
    object-fit: contain;
    filter: none;
    padding: 3rem;
  }
  .ev-img-empty {
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
    background: linear-gradient(160deg, theme('colors.ink') 0%, theme('colors.acquadeep') 100%);
  }
  .ev-img-num {
    font-family: theme('fontFamily.serif');
    font-style: italic; font-weight: 300;
    font-size: 14rem; line-height: 1;
    color: rgba(244,235,217,.12);
    letter-spacing: -0.04em;
    user-select: none;
  }

  /* back link – in-flow, top of right column */
  .ev-back {
    display: inline-flex; align-items: center; gap: .4rem;
    font-family: theme('fontFamily.mono');
    font-size: .65rem;
    text-transform: uppercase;
    letter-spacing: .18em;
    color: theme('colors.ink-soft');
    text-decoration: none;
    margin-bottom: 2rem;
    transition: color .2s ease;
  }
  .ev-back:hover { color: theme('colors.ink'); }

  /* ── Right column ── */
  .ev-content {
    padding: 2.5rem 4.5rem 6rem;
    max-width: 60ch;
  }

  /* ── Date stamp ── */
  .ev-datestamp {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 2rem;
    padding-bottom: 2rem;
    border-bottom: 1px dashed theme('colors.rule');
  }
  .ds-day {
    font-family: theme('fontFamily.serif');
    font-style: italic; font-weight: 300;
    font-size: clamp(5rem, 10vw, 8rem);
    line-height: .85;
    color: theme('colors.gold');
    letter-spacing: -0.02em;
    flex-shrink: 0;
  }
  .ds-aside {
    display: flex; flex-direction: column; gap: .1rem;
    flex-shrink: 0;
  }
  .ds-month {
    font-family: theme('fontFamily.mono');
    font-size: .72rem;
    text-transform: uppercase;
    letter-spacing: .3em;
    color: theme('colors.ink');
    font-weight: 500;
  }
  .ds-year {
    font-family: theme('fontFamily.mono');
    font-size: .65rem;
    letter-spacing: .2em;
    color: theme('colors.ink-soft');
  }
  .ds-meta {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: .55rem;
    padding-left: 1.5rem;
    border-left: 1px solid theme('colors.rule');
    min-width: 0;
  }
  .ds-loc, .ds-time {
    display: flex;
    flex-direction: column;
    gap: .2rem;
  }
  .ds-label {
    font-family: theme('fontFamily.mono');
    font-size: .58rem;
    letter-spacing: .25em;
    text-transform: uppercase;
    color: theme('colors.ink-soft');
  }
  .ds-value {
    font-family: theme('fontFamily.mono');
    font-size: .92rem;
    letter-spacing: .03em;
    color: theme('colors.ink');
    line-height: 1.45;
  }
  .ds-time .ds-value {
    font-size: 1.15rem;
    letter-spacing: .06em;
  }

  /* ── Title ── */
  .ev-title {
    font-size: clamp(2.4rem, 4.5vw, 4rem);
    line-height: 1.05;
    margin: 0 0 2.5rem;
  }

  /* ── Body ── */
  .ev-body {
    font-size: 1.05rem;
    line-height: 1.75;
    color: theme('colors.ink-soft');
  }
  .ev-body :global(p)  { margin: 0 0 1.1em; }
  .ev-body :global(h1),
  .ev-body :global(h2),
  .ev-body :global(h3) {
    font-family: theme('fontFamily.hand');
    font-weight: 700;
    color: theme('colors.ink');
    margin: 1.6em 0 .5em;
    line-height: 1.2;
  }
  .ev-body :global(h1) { font-size: 1.7rem; }
  .ev-body :global(h2) { font-size: 1.35rem; }
  .ev-body :global(h3) { font-size: 1.1rem; }
  .ev-body :global(strong) { color: theme('colors.ink'); font-weight: 600; }
  .ev-body :global(em) { font-style: italic; }
  .ev-body :global(ul),
  .ev-body :global(ol) { padding-left: 1.4em; margin: 0 0 1.1em; }
  .ev-body :global(li) { margin-bottom: .35em; }
  .ev-body :global(a)  { color: theme('colors.acquadeep'); text-underline-offset: 3px; }
  .ev-body :global(hr) { border: none; border-top: 1px dashed theme('colors.rule'); margin: 1.75em 0; }

  /* ── Signup ── */
  .ev-signup {
    margin-top: 3rem;
    padding-top: 2.5rem;
    border-top: 1px solid theme('colors.rule');
  }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .ev-split { grid-template-columns: 1fr; }
    .ev-img-col {
      position: relative; top: 0;
      height: 55vw; min-height: 260px; max-height: 420px;
    }
    .ev-content { padding: 2.5rem 1.5rem 4rem; max-width: none; }
    .ev-content { padding: 2rem 1.5rem 4rem; max-width: none; }
    .ds-meta { font-size: .78rem; }
  }
</style>
