---
import Base from '../../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { formatEventDate, formatTime } from '../../../lib/dates';
import type { Lang } from '../../../i18n/ui';
import EventSignupForm from '../../../components/EventSignupForm.astro';

export async function getStaticPaths() {
  const all = await getCollection('events');
  return all.map((entry) => {
    const [lang, ...rest] = entry.slug.split('/');
    return { params: { lang, slug: rest.join('/') }, props: { entry } };
  });
}

const { entry } = Astro.props;
const lang = Astro.params.lang as Lang;
const { Content } = await entry.render();
const dateStr = formatEventDate(entry.data.date, lang);
const timeStr = formatTime(entry.data.date, lang);
---

<Base title={entry.data.title}>
  {entry.data.cover && (
    <div class="event-cover">
      <img src={entry.data.cover} alt={entry.data.title} />
      <div class="cover-gradient" aria-hidden="true"></div>
    </div>
  )}

  <article class="event-article">
    <div class="event-meta">
      <span class="meta-date">{dateStr} · {timeStr}</span>
      <span class="meta-dot" aria-hidden="true"></span>
      <span class="meta-place">{entry.data.location}</span>
    </div>

    <h1>{entry.data.title}</h1>

    <div class="event-body prose">
      <Content />
    </div>

    {entry.data.signupRequired && (
      <div class="event-signup-wrap">
        <EventSignupForm eventSlug={entry.slug.split('/').slice(1).join('/')} />
      </div>
    )}
  </article>
</Base>

<style>
  .event-cover {
    position: relative;
    width: 100%;
    max-height: 520px;
    overflow: hidden;
    border-bottom: 1px solid theme('colors.rule');
  }
  .event-cover img {
    width: 100%;
    height: 100%;
    max-height: 520px;
    object-fit: cover;
    filter: saturate(.88) contrast(1.02);
    display: block;
  }
  .cover-gradient {
    position: absolute; inset: 0;
    background: linear-gradient(180deg, transparent 50%, rgba(244,235,217,0.55) 100%);
  }

  .event-article {
    max-width: 68ch;
    margin: 0 auto;
    padding: 4rem 2rem 6rem;
  }

  .event-meta {
    display: flex;
    align-items: center;
    gap: .75rem;
    font-family: theme('fontFamily.mono');
    font-size: .75rem;
    text-transform: uppercase;
    letter-spacing: .18em;
    color: theme('colors.ink-soft');
    margin-bottom: 1.25rem;
  }
  .meta-dot {
    width: 4px; height: 4px;
    border-radius: 50%;
    background: theme('colors.gold');
  }
  .meta-place { color: theme('colors.acquadeep'); }

  h1 {
    font-size: clamp(2.6rem, 5vw, 4.4rem);
    line-height: 1.05;
    margin: 0 0 2rem;
  }

  .event-body {
    font-size: 1.1rem;
    line-height: 1.7;
    color: theme('colors.ink-soft');
    border-top: 1px dashed theme('colors.rule');
    padding-top: 2rem;
  }
  .event-body :global(p) { margin: 0 0 1.25em; }

  .event-signup-wrap {
    margin-top: 3rem;
    padding-top: 2.5rem;
    border-top: 1px solid theme('colors.rule');
  }
</style>
