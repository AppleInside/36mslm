---
export const prerender = false;

import Base from '../../../layouts/Base.astro';
import { formatEventDate, formatTime } from '../../../lib/dates';
import type { Lang } from '../../../i18n/ui';
import EventSignupForm from '../../../components/EventSignupForm.astro';
import { getEvent } from '../../../server/db';

const lang = Astro.params.lang as Lang;
const slug = Astro.params.slug as string;

const event = await getEvent(lang, slug);
if (!event) return Astro.redirect(`/${lang}/eventi`);

const dateObj = new Date(event.date);
let timeObj: Date | null = null;
if (event.time_start) {
  timeObj = new Date(event.date);
  const [h, m] = event.time_start.split(':');
  timeObj.setUTCHours(parseInt(h), parseInt(m), 0, 0);
}

const dateStr = formatEventDate(dateObj, lang);
const timeStr = timeObj ? formatTime(timeObj, lang) : null;
---

<Base title={event.title}>
  {event.cover_url && (
    <div class="event-cover-wrap">
      <img src={event.cover_url} alt={event.title} class="event-cover" />
    </div>
  )}
  <article class="event-article">
    <div class="event-meta">
      <span class="meta-date">{dateStr}{timeStr && ` · ${timeStr}`}</span>
      <span class="meta-dot" aria-hidden="true"></span>
      <span class="meta-place">{event.location}</span>
    </div>

    <h1>{event.title}</h1>

    {event.description && (
      <div class="event-body prose">
        {event.description.split('\n').map(line => line.trim()).filter(Boolean).map(line => (
          <p>{line}</p>
        ))}
      </div>
    )}

    {event.signup_required && (
      <div class="event-signup-wrap">
        <EventSignupForm eventSlug={event.slug} />
      </div>
    )}
  </article>
</Base>

<style>
  .event-cover-wrap {
    width: 100%;
    max-height: 420px;
    overflow: hidden;
  }
  .event-cover {
    width: 100%;
    height: 100%;
    max-height: 420px;
    object-fit: cover;
    display: block;
  }

  .event-article {
    max-width: 68ch;
    margin: 0 auto;
    padding: 4rem 2rem 6rem;
  }

  .event-meta {
    display: flex;
    align-items: center;
    gap: .75rem;
    font-family: theme('fontFamily.mono');
    font-size: .75rem;
    text-transform: uppercase;
    letter-spacing: .18em;
    color: theme('colors.ink-soft');
    margin-bottom: 1.25rem;
  }
  .meta-dot {
    width: 4px; height: 4px;
    border-radius: 50%;
    background: theme('colors.gold');
  }
  .meta-place { color: theme('colors.acquadeep'); }

  h1 {
    font-size: clamp(2.6rem, 5vw, 4.4rem);
    line-height: 1.05;
    margin: 0 0 2rem;
  }

  .event-body {
    font-size: 1.1rem;
    line-height: 1.7;
    color: theme('colors.ink-soft');
    border-top: 1px dashed theme('colors.rule');
    padding-top: 2rem;
  }
  .event-body p { margin: 0 0 1.25em; }

  .event-signup-wrap {
    margin-top: 3rem;
    padding-top: 2.5rem;
    border-top: 1px solid theme('colors.rule');
  }
</style>
