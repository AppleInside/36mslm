---
export const prerender = false;

import Base from '../../../../layouts/Base.astro';
import PageHeader from '../../../../components/PageHeader.astro';
import PageBody from '../../../../components/PageBody.astro';
import NoticeCard from '../../../../components/NoticeCard.astro';
import { getNotices } from '../../../../server/db';
import { formatEventDate } from '../../../../lib/dates';
import { marked } from 'marked';
import type { Lang } from '../../../../i18n/ui';

const lang = Astro.params.lang as Lang;
const notices = await getNotices(lang);
---

<Base title={lang === 'it' ? 'Bacheca' : 'Notice board'}>
  <PageHeader
    pageKey="eventi-bacheca"
    eyebrow={lang === 'it' ? '— Comunicazioni —' : '— Notices —'}
    bg="/media/storico/leggevano-il-giornale-in-piazza.jpg"
  >
    {lang === 'it' ? <>Bacheca <em>e avvisi</em></> : <>Notice <em>board</em></>}
  </PageHeader>
  <PageBody>
    <div class="notice-grid grid gap-4 md:grid-cols-2">
      {notices.map((notice) => (
        <div data-notice-open={notice.slug}>
          <NoticeCard notice={notice} />
        </div>
      ))}
    </div>
  </PageBody>

  <!-- Pre-rendered notice content (hidden, consumed by the modal) -->
  {notices.map((notice) => (
    <div id={`nc-${notice.slug}`} hidden aria-hidden="true">
      <div class="nc-header">
        <p class="nc-meta">{formatEventDate(new Date(notice.date ?? notice.created_at), lang)}</p>
        <h2 class="nc-title">{notice.title}</h2>
      </div>
      <div class="prose mt-6" set:html={marked.parse(notice.body)} />
      {notice.cta && (
        <button class="nc-cta-btn" data-cta-label={notice.cta}>{notice.cta}</button>
      )}
      {(notice.attachments as {label: string; url: string}[])?.length > 0 && (
        <ul class="nc-attachments">
          {(notice.attachments as {label: string; url: string}[]).map((a) => (
            <li><a href={a.url} target="_blank" rel="noopener">{a.label}</a></li>
          ))}
        </ul>
      )}
    </div>
  ))}

  <!-- Modal -->
  <div id="notice-modal" class="nmodal" role="dialog" aria-modal="true" hidden>
    <div class="nmodal-backdrop" id="nmodal-backdrop"></div>
    <div class="nmodal-panel">
      <button class="nmodal-close" id="nmodal-close" aria-label={lang === 'it' ? 'Chiudi' : 'Close'}>
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M2 2l12 12M14 2L2 14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
        </svg>
      </button>
      <div class="nmodal-body" id="nmodal-body"></div>
    </div>
  </div>
</Base>

<style is:global>
  .nmodal {
    position: fixed; inset: 0; z-index: 80;
    display: flex; align-items: flex-end; justify-content: center;
  }
  .nmodal[hidden] { display: none; }

  .nmodal-backdrop {
    position: absolute; inset: 0;
    background: rgba(10,16,22,.58);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    animation: nmodal-fade .2s ease;
  }

  .nmodal-panel {
    position: relative; z-index: 1;
    width: 100%; max-width: 680px;
    max-height: 90dvh;
    background: theme('colors.sabbia');
    border-radius: 1rem 1rem 0 0;
    overflow-y: auto;
    overscroll-behavior: contain;
    padding: 2rem 1.5rem 3rem;
    box-shadow: 0 -4px 40px rgba(0,0,0,.18);
    animation: nmodal-up .28s cubic-bezier(.2,.7,.2,1);
  }
  @media (min-width: 640px) {
    .nmodal { align-items: center; }
    .nmodal-panel {
      border-radius: 1rem;
      max-height: 82dvh;
      padding: 2.5rem;
    }
  }

  @keyframes nmodal-fade {
    from { opacity: 0; } to { opacity: 1; }
  }
  @keyframes nmodal-up {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .nmodal-close {
    position: absolute; top: 1rem; right: 1rem;
    width: 34px; height: 34px; border-radius: 50%;
    background: rgba(0,0,0,.06);
    border: 1px solid rgba(0,0,0,.1);
    color: theme('colors.ink-soft');
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; transition: background .15s;
  }
  .nmodal-close:hover { background: rgba(0,0,0,.13); }
  .nmodal-close:focus-visible { outline: 2px solid theme('colors.brand'); outline-offset: 2px; }

  .nmodal-body .nc-header {
    background: theme('colors.acqua');
    margin: -2rem -1.5rem 2rem;
    padding: 3rem 1.5rem 1.5rem;
    border-bottom: 2px solid theme('colors.po');
    position: relative;
  }
  .nmodal-body .nc-header::after {
    content: '';
    position: absolute;
    bottom: -2px; left: 1.5rem;
    width: 3rem; height: 2px;
    background: theme('colors.gold');
  }
  @media (min-width: 640px) {
    .nmodal-body .nc-header {
      margin: -2.5rem -2.5rem 2rem;
      padding: 3rem 2.5rem 1.75rem;
    }
    .nmodal-body .nc-header::after { left: 2.5rem; }
  }

  .nmodal-body .nc-header .nc-meta {
    font-family: theme('fontFamily.mono');
    font-size: .72rem; text-transform: uppercase; letter-spacing: .2em;
    color: theme('colors.ink-soft'); margin: 0 0 .5rem;
  }
  .nmodal-body .nc-header .nc-title {
    font-size: clamp(1.6rem, 5vw, 2.4rem);
    line-height: 1.1; margin: 0;
    padding-right: 2.5rem;
  }
  .nmodal-body .nc-attachments {
    margin-top: 1.75rem;
    padding: 1rem 1.25rem;
    background: theme('colors.argento');
    border: 1px solid theme('colors.pioppo');
    border-radius: .5rem;
    list-style: none;
    display: flex; flex-direction: column; gap: .4rem;
  }
  .nmodal-body .nc-attachments a {
    color: theme('colors.brand-deep'); font-size: .9rem;
    text-decoration: underline; text-underline-offset: 3px;
  }

  .nc-cta-btn {
    display: block;
    margin-top: 2rem;
    width: 100%;
    padding: .85rem 1.5rem;
    background: theme('colors.brand');
    color: #fff;
    border: none;
    border-radius: .5rem;
    font-family: theme('fontFamily.serif');
    font-size: 1.05rem;
    cursor: pointer;
    transition: opacity .15s;
    text-align: center;
  }
  .nc-cta-btn:hover { opacity: .88; }
  .nc-cta-btn:focus-visible { outline: 2px solid theme('colors.brand'); outline-offset: 3px; }

  .ncf-back {
    display: inline-flex;
    align-items: center;
    gap: .3rem;
    background: none;
    border: none;
    color: theme('colors.ink-soft');
    font-family: theme('fontFamily.mono');
    font-size: .72rem;
    text-transform: uppercase;
    letter-spacing: .14em;
    cursor: pointer;
    padding: 0;
    margin-bottom: 1.5rem;
  }
  .ncf-back:hover { color: theme('colors.ink'); }

  .ncf-heading {
    font-size: clamp(1.4rem, 4.5vw, 2rem);
    line-height: 1.15;
    margin: 0 0 1.75rem;
    padding-right: 2rem;
  }

  .ncf-form { display: flex; flex-direction: column; gap: 1rem; }

  .ncf-field { display: flex; flex-direction: column; gap: .35rem; }
  .ncf-field label {
    font-family: theme('fontFamily.mono');
    font-size: .68rem;
    text-transform: uppercase;
    letter-spacing: .16em;
    color: theme('colors.ink-soft');
  }
  .ncf-field input {
    padding: .65rem .85rem;
    border: 1px solid theme('colors.rule');
    border-radius: .4rem;
    background: theme('colors.paper');
    font-family: theme('fontFamily.serif');
    font-size: 1rem;
    color: theme('colors.ink');
    outline: none;
    transition: border-color .15s;
  }
  .ncf-field input:focus { border-color: theme('colors.brand'); }

  .ncf-submit {
    margin-top: .5rem;
    padding: .85rem 1.5rem;
    background: theme('colors.brand');
    color: #fff;
    border: none;
    border-radius: .5rem;
    font-family: theme('fontFamily.serif');
    font-size: 1rem;
    cursor: pointer;
    transition: opacity .15s;
    align-self: flex-start;
  }
  .ncf-submit:hover { opacity: .88; }
  .ncf-submit:disabled { opacity: .45; cursor: default; }

  .ncf-error {
    color: #b5451b;
    font-size: .85rem;
    margin: .25rem 0 0;
    font-family: theme('fontFamily.mono');
  }

  .ncf-success { padding: 3rem 0; text-align: center; }
  .ncf-success p {
    font-family: theme('fontFamily.serif');
    font-size: 1.15rem;
    color: theme('colors.ink');
  }
</style>

<script>
  const modal    = document.getElementById('notice-modal');
  const body     = document.getElementById('nmodal-body');
  const backdrop = document.getElementById('nmodal-backdrop');
  const closeBtn = document.getElementById('nmodal-close');

  let currentSlug = '';

  function t(it: string, en: string) {
    return document.documentElement.lang === 'en' ? en : it;
  }

  function openModal(slug: string) {
    const src = document.getElementById(`nc-${slug}`);
    if (!src || !body || !modal) return;
    currentSlug = slug;
    body.innerHTML = src.innerHTML;
    modal.removeAttribute('hidden');
    document.body.style.overflow = 'hidden';
    closeBtn?.focus();
  }

  function closeModal() {
    modal?.setAttribute('hidden', '');
    document.body.style.overflow = '';
  }

  function showForm(ctaLabel: string) {
    if (!body) return;
    const savedHtml = body.innerHTML;
    body.innerHTML = `
      <button class="ncf-back" type="button">← ${t("Torna all'avviso", 'Back to notice')}</button>
      <h3 class="ncf-heading">${ctaLabel}</h3>
      <form class="ncf-form">
        <div class="ncf-field">
          <label for="ncf-nome">${t('Nome', 'First name')}</label>
          <input id="ncf-nome" name="nome" type="text" autocomplete="given-name" required />
        </div>
        <div class="ncf-field">
          <label for="ncf-cognome">${t('Cognome', 'Last name')}</label>
          <input id="ncf-cognome" name="cognome" type="text" autocomplete="family-name" required />
        </div>
        <div class="ncf-field">
          <label for="ncf-tel">${t('Recapito telefonico', 'Phone number')}</label>
          <input id="ncf-tel" name="telefono" type="tel" autocomplete="tel" required />
        </div>
        <button class="ncf-submit" type="submit">${t('Invia', 'Send')}</button>
      </form>
    `;
    body.querySelector<HTMLButtonElement>('.ncf-back')!.addEventListener('click', () => {
      body!.innerHTML = savedHtml;
    });
    body.querySelector<HTMLFormElement>('.ncf-form')!.addEventListener('submit', handleFormSubmit);
  }

  async function handleFormSubmit(e: SubmitEvent) {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const submit = form.querySelector<HTMLButtonElement>('.ncf-submit')!;
    const nome     = form.querySelector<HTMLInputElement>('[name=nome]')!.value;
    const cognome  = form.querySelector<HTMLInputElement>('[name=cognome]')!.value;
    const telefono = form.querySelector<HTMLInputElement>('[name=telefono]')!.value;

    submit.disabled = true;
    submit.textContent = t('Invio…', 'Sending…');

    try {
      const res = await fetch('/api/notice-response', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({ notice_slug: currentSlug, nome, cognome, telefono }),
      });
      if (!res.ok) throw new Error();
      body!.innerHTML = `
        <div class="ncf-success">
          <p>${t('Grazie! Ti contatteremo presto.', "Thank you! We'll be in touch soon.")}</p>
        </div>
      `;
    } catch {
      submit.disabled = false;
      submit.textContent = t('Invia', 'Send');
      let err = form.querySelector<HTMLElement>('.ncf-error');
      if (!err) {
        err = document.createElement('p');
        err.className = 'ncf-error';
        form.appendChild(err);
      }
      err.textContent = t('Qualcosa è andato storto. Riprova.', 'Something went wrong. Please try again.');
    }
  }

  document.querySelector('.notice-grid')?.addEventListener('click', (e) => {
    const link = (e.target as Element).closest('a.notice-card');
    if (!link) return;
    const wrapper = link.closest('[data-notice-open]') as HTMLElement | null;
    if (!wrapper?.dataset.noticeOpen) return;
    e.preventDefault();
    openModal(wrapper.dataset.noticeOpen);
  });

  body?.addEventListener('click', (e) => {
    const btn = (e.target as Element).closest<HTMLElement>('.nc-cta-btn');
    if (btn) showForm(btn.dataset.ctaLabel ?? '');
  });

  backdrop?.addEventListener('click', closeModal);
  closeBtn?.addEventListener('click', closeModal);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !modal?.hasAttribute('hidden')) closeModal();
  });
</script>
