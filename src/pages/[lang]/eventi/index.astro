---
import Base from '../../../layouts/Base.astro';
import PageHeader from '../../../components/PageHeader.astro';
import EventCard from '../../../components/EventCard.astro';
import { getCollection } from 'astro:content';
import { useTranslations } from '../../../i18n/utils';
import { byLang, splitFutureFromPast } from '../../../lib/content';
import type { Lang } from '../../../i18n/ui';

export function getStaticPaths() {
  return [{ params: { lang: 'it' } }, { params: { lang: 'en' } }];
}

const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);
const all = await getCollection('events');
const { future, past } = splitFutureFromPast(byLang(all, lang), new Date());

// future ASC (prossimo prima), past DESC (più recente prima)
const events = [
  ...future.map((e) => ({ entry: e, past: false })),
  ...past.map((e)   => ({ entry: e, past: true  })),
];
const hasPast = past.length > 0;
---

<Base title={t('nav.events')}>

  <PageHeader
    eyebrow={`— ${lang === 'it' ? 'Calendario' : 'Calendar'} —`}
    bg="/media/storico/cercavano-il-fresco-destate-sulla-Via-Alzaia-FILEminimizer.jpg"
  >
    {lang === 'it' ? <>Tutti gli <em>eventi</em></> : <>All <em>events</em></>}
  </PageHeader>
  {events.length === 0 && (
    <p class="empty">{lang === 'it' ? 'Nessun evento in programma. Torna presto.' : 'No events yet. Check back soon.'}</p>
  )}

  {events.length > 0 && (
    <section class="events-list">
      {events.map(({ entry, past: isPast }, i) => (
        <>
          {isPast && i > 0 && !events[i - 1].past && (
            <div class="past-divider">
              <span>{lang === 'it' ? 'Passati' : 'Past events'}</span>
            </div>
          )}
          <div class:list={['ev-wrap', { 'ev-past': isPast }]}>
            <EventCard entry={entry} />
          </div>
        </>
      ))}
    </section>
  )}

</Base>

<style>
  .empty {
    font-style: italic;
    color: theme('colors.ink-soft');
    margin-top: 1.5rem;
  }

  /* ── Events list ── mobile first: 1 col */
  .events-list {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    padding: 2rem 1.25rem 5rem;
  }

  /* ── Past dimming */
  .ev-wrap { position: relative; }
  .ev-past {
    opacity: 0.45;
    filter: saturate(0.4);
    transition: opacity .25s ease, filter .25s ease;
  }
  .ev-past:hover {
    opacity: 0.75;
    filter: saturate(0.7);
  }

  /* ── Separatore futuri / passati */
  .past-divider {
    grid-column: 1 / -1;
    display: flex;
    align-items: center;
    gap: 1rem;
    margin: 1rem 0 .5rem;
    color: theme('colors.ink-soft');
  }
  .past-divider::before,
  .past-divider::after {
    content: "";
    flex: 1;
    height: 1px;
    background: theme('colors.rule');
  }
  .past-divider span {
    font-family: theme('fontFamily.mono');
    font-size: .7rem;
    text-transform: uppercase;
    letter-spacing: .2em;
    white-space: nowrap;
  }

  /* ── Tablet ≥ 600px: 2 colonne */
  @media (min-width: 600px) {
    .events-list { grid-template-columns: repeat(2, 1fr); gap: 1.75rem; }
  }

  /* ── Desktop ≥ 1000px */
  @media (min-width: 1000px) {
    .events-list { grid-template-columns: repeat(3, 1fr); gap: 2rem; padding: 3rem 4rem 6rem; }
  }
</style>
