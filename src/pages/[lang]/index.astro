---
export const prerender = false;

import Base from '../../layouts/Base.astro';
import { sql, getEvents, getNotices } from '../../server/db';
import { useTranslations, localizedPath } from '../../i18n/utils';
import type { Lang } from '../../i18n/ui';

const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);
const now = new Date();

const allEvents = await getEvents(lang);
const upcoming = allEvents.filter(e => new Date(e.date) >= now).slice(0, 3);

const notices = (await getNotices(lang)).slice(0, 3);

const staticCovers: Record<string, string> = {
  'eventi-calendario': '/media/storico/cercavano-il-fresco-destate-sulla-Via-Alzaia-FILEminimizer.jpg',
  'scopri-itinerari':  '/media/storico/Guareschi-sul-Po.jpg',
  'scopri-ricettario': '/media/storico/Tortelli-1959-.jpg',
  'scopri-storie':     '/media/storico/Giovanni-Guareschi-al-bar-in-piazza.jpg',
  'eventi-bacheca':    '/media/storico/leggevano-il-giornale-in-piazza.jpg',
};

let pageCoverMap: Record<string, string> = {};
try {
  const rows = await sql<{ page_key: string; cover_url: string }[]>`
    SELECT page_key, cover_url FROM page_covers
    WHERE page_key IN ('eventi-calendario','scopri-itinerari','scopri-ricettario','scopri-storie','eventi-bacheca')
  `;
  for (const r of rows) { if (r.cover_url) pageCoverMap[r.page_key] = r.cover_url; }
} catch {}

const c = (key: string) => pageCoverMap[key] ?? staticCovers[key];

const carouselSlides = [
  { label: lang === 'it' ? 'Eventi'     : 'Events',       href: localizedPath(lang, 'eventi/calendario'), cover: c('eventi-calendario') },
  { label: lang === 'it' ? 'Itinerari'  : 'Itineraries',  href: localizedPath(lang, 'scopri/itinerari'),  cover: c('scopri-itinerari')  },
  { label: lang === 'it' ? 'Ricettario' : 'Recipes',      href: localizedPath(lang, 'scopri/ricettario'), cover: c('scopri-ricettario') },
  { label: lang === 'it' ? 'Dialetto'   : 'Dialect',      href: localizedPath(lang, 'scopri/storie'),     cover: c('scopri-storie')     },
  { label: lang === 'it' ? 'Bacheca'    : 'Notices',      href: localizedPath(lang, 'eventi/bacheca'),    cover: c('eventi-bacheca')    },
];

const monthsIt = ['gen', 'feb', 'mar', 'apr', 'mag', 'giu', 'lug', 'ago', 'set', 'ott', 'nov', 'dic'];
const monthsEn = ['jan', 'feb', 'mar', 'apr', 'may', 'jun', 'jul', 'aug', 'sep', 'oct', 'nov', 'dec'];
function stamp(d: Date) {
  const months = lang === 'it' ? monthsIt : monthsEn;
  return { d: new Date(d).getUTCDate(), m: months[new Date(d).getUTCMonth()] };
}
function fmtNoticeDate(d: Date) {
  return d.toLocaleDateString(lang === 'it' ? 'it-IT' : 'en-GB', { day: '2-digit', month: 'long', year: 'numeric' });
}
function eventHref(slug: string) {
  if (!slug || slug.startsWith('data:') || slug.startsWith('blob:')) {
    return localizedPath(lang, 'eventi');
  }
  return localizedPath(lang, `eventi/${slug}`);
}
---
<Base title={t('nav.events')}>
  <section class="section section-paper">
    <div class="portal-grid">

      <!-- Left: content -->
      <div class="portal-left">
        <p class="eyebrow">— {lang === 'it' ? 'Il portale' : 'The portal'} —</p>
        <h2 class="portal-h2">{lang === 'it' ? <>Il <em>riferimento</em> digitale del paese</> : <>The village&apos;s <em>digital</em> home</>}</h2>
        <div class="portal-rule"></div>
        <p class="portal-lead">
          {lang === 'it'
            ? 'Non è una brochure. È una piattaforma editoriale viva: eventi, itinerari del fiume, ricettario di casa, dialetto e modi di dire, bacheca degli avvisi.'
            : "Not a brochure. A living editorial platform: events, river itineraries, home recipes, dialect and sayings, notice board."}
        </p>
        <ul class="portal-tags" role="list">
          <li><a class="portal-tag" href={localizedPath(lang, 'eventi/calendario')}>{lang === 'it' ? 'Eventi' : 'Events'} →</a></li>
          <li><a class="portal-tag" href={localizedPath(lang, 'scopri/itinerari')}>{lang === 'it' ? 'Itinerari' : 'Itineraries'} →</a></li>
          <li><a class="portal-tag" href={localizedPath(lang, 'scopri/ricettario')}>{lang === 'it' ? 'Ricettario' : 'Recipes'} →</a></li>
          <li><a class="portal-tag" href={localizedPath(lang, 'scopri/storie')}>{lang === 'it' ? 'Dialetto' : 'Dialect'} →</a></li>
          <li><a class="portal-tag" href={localizedPath(lang, 'eventi/bacheca')}>{lang === 'it' ? 'Bacheca' : 'Notices'} →</a></li>
        </ul>
        <a class="portal-cta" href={localizedPath(lang, 'portale')}>
          {lang === 'it' ? 'Scopri il portale' : 'Explore the portal'} <span class="portal-cta-arr">→</span>
        </a>
      </div>

      <!-- Right: carousel -->
      <div class="portal-carousel" id="portal-carousel">
        <div class="carousel-slides">
          {carouselSlides.map((slide, i) => (
            <a class={`carousel-slide${i === 0 ? ' active' : ''}`} href={slide.href}>
              <img src={slide.cover} alt={slide.label} loading={i === 0 ? 'eager' : 'lazy'} />
              <div class="slide-overlay"></div>
              <div class="slide-content">
                <span class="slide-label">{slide.label}</span>
                <span class="slide-arr">→</span>
              </div>
            </a>
          ))}
        </div>
        <div class="carousel-dots">
          {carouselSlides.map((slide, i) => (
            <button class={`cdot${i === 0 ? ' active' : ''}`} data-idx={i} aria-label={slide.label}></button>
          ))}
        </div>
      </div>

    </div>
  </section>

  <div class="wave" style="background: #CCE4EF;" aria-hidden="true">
    <svg viewBox="0 0 1440 48" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,24 C240,0 480,48 720,24 C960,0 1200,48 1440,24 L1440,48 L0,48 Z" fill="#F2EDE0"/>
    </svg>
  </div>

  {upcoming.length > 0 && (
    <section class="section section-sand">
      <div class="section-head">
        <div>
          <p class="eyebrow">— {lang === 'it' ? 'Cosa succede' : "What's on"} —</p>
          <h2>{lang === 'it' ? <>I prossimi <em>eventi</em></> : <>Upcoming <em>events</em></>}</h2>
        </div>
        <a class="all" href={localizedPath(lang, 'eventi')}>{t('common.allEvents')} →</a>
      </div>

      <div class="events">
        {upcoming.map((e, i) => {
          const s = stamp(e.date);
          return (
            <a class={`event ${i === 0 ? 'big' : ''}`} href={eventHref(e.slug)}>
              <div class="pic">
                {e.cover_url && <img src={e.cover_url} alt={e.title} loading="lazy" />}
                <div class="event-stamp"><span class="d">{s.d}</span><span class="m">{s.m}</span></div>
              </div>
              <h3>{e.title}</h3>
              <p class="where">{e.location}</p>
              {e.signup_required && <span class="signup">→ {lang === 'it' ? 'iscrizione richiesta' : 'signup required'}</span>}
            </a>
          );
        })}
      </div>
    </section>
  )}

  <div class="wave wave--acqua" aria-hidden="true">
    <svg viewBox="0 0 1440 48" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M0,12 C360,48 720,0 1080,24 C1260,36 1380,12 1440,24 L1440,48 L0,48 Z" fill="#C5D3D7"/>
    </svg>
  </div>

  {notices.length > 0 && (
    <section class="section section-acqua">
      <div class="section-head">
        <div>
          <p class="eyebrow">— {lang === 'it' ? 'In bacheca' : 'Notice board'} —</p>
          <h2>{lang === 'it' ? <>Annunci <em>e avvisi</em></> : <>Announcements <em>& notices</em></>}</h2>
        </div>
        <a class="all" href={localizedPath(lang, 'eventi/bacheca')}>{lang === 'it' ? 'Tutta la bacheca' : 'All notices'} →</a>
      </div>

      <ol class="notices">
        {notices.map((n) => (
          <li class="notice">
            <a href={localizedPath(lang, 'eventi/bacheca')}>
              <time datetime={new Date(n.date ?? n.created_at).toISOString()}>{fmtNoticeDate(new Date(n.date ?? n.created_at))}</time>
              <h3>{n.title}</h3>
              <span class="arrow">→</span>
            </a>
          </li>
        ))}
      </ol>
    </section>
  )}

</Base>

<style>
  /* ── Mobile quick nav ── */
  .mob-nav {
    display: flex;
    flex-direction: column;
    border-bottom: 1px solid theme('colors.rule');
  }
  .mob-nav-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid theme('colors.rule');
    text-decoration: none;
    color: theme('colors.ink');
    transition: background .15s ease;
  }
  .mob-nav-item:last-child { border-bottom: none; }
  .mob-nav-item:active { background: theme('colors.paper'); }
  .mob-nav-label {
    font-family: theme('fontFamily.hand');
    font-size: 1.55rem;
    font-weight: 700;
    line-height: 1;
  }
  .mob-nav-arrow {
    font-family: theme('fontFamily.mono');
    font-size: .85rem;
    color: theme('colors.acquadeep');
  }
  @media (min-width: 640px) {
    .mob-nav { display: none; }
  }

  .hero {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    min-height: 88vh;
    border-bottom: 1px solid theme('colors.rule');
    position: relative;
  }
  .hero .text {
    padding: 5rem 3rem 4rem 4rem;
    display: flex; flex-direction: column; justify-content: center;
  }
  .meta {
    font-family: theme('fontFamily.mono');
    font-size: .78rem; text-transform: uppercase; letter-spacing: .2em;
    color: theme('colors.ink-soft');
    margin-bottom: 1.5rem;
    display: flex; align-items: center; gap: 1rem;
  }
  .meta .dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: theme('colors.gold');
    box-shadow: 0 0 0 4px rgba(216,161,74,0.18);
  }
  .hero h1 {
    font-family: theme('fontFamily.serif');
    font-weight: 300;
    font-size: clamp(3.2rem, 6.6vw, 6.8rem);
    line-height: 0.96; letter-spacing: -0.02em;
    margin: 0 0 .5rem 0;
  }
  .hero h1 :global(em) { font-style: italic; color: theme('colors.acquadeep'); font-weight: 400; }
  .hero h1 .hand {
    font-family: theme('fontFamily.hand');
    font-weight: 700;
    color: theme('colors.gold-deep');
    font-size: 1em; line-height: 1;
    display: inline-block;
    transform: rotate(-2deg) translateY(-.05em);
    margin-right: .15em;
  }
  .kicker {
    font-style: italic; font-size: 1.25rem; max-width: 38ch;
    color: theme('colors.ink-soft'); margin-top: 1.75rem;
  }
  .ctas { display: flex; gap: 1rem; margin-top: 2.5rem; flex-wrap: wrap; }
  .btn {
    display: inline-flex; align-items: center; gap: .6rem;
    padding: .9rem 1.4rem;
    font-family: theme('fontFamily.mono'); font-size: .82rem;
    text-transform: uppercase; letter-spacing: .14em;
    text-decoration: none;
    border: 1.5px solid theme('colors.ink');
    border-radius: 999px;
    transition: all .25s ease;
  }
  .btn.primary { background: theme('colors.ink'); color: theme('colors.paper'); }
  .btn.primary:hover { background: theme('colors.gold-deep'); border-color: theme('colors.gold-deep'); }
  .btn.ghost { background: transparent; color: theme('colors.ink'); }
  .btn.ghost:hover { background: theme('colors.ink'); color: theme('colors.paper'); }
  .btn .arrow { transition: transform .25s ease; }
  .btn:hover .arrow { transform: translateX(4px); }

  .hero .image { position: relative; overflow: hidden; background: theme('colors.ink'); }
  .hero .image img {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    filter: saturate(.92) contrast(1.02);
    mix-blend-mode: multiply;
    opacity: .92;
  }
  .hero .image::after {
    content: ""; position: absolute; inset: 0;
    background: linear-gradient(180deg, transparent 60%, rgba(31,42,42,0.35) 100%);
  }
  .hero .quota {
    position: absolute; right: 2rem; bottom: 2rem;
    font-family: theme('fontFamily.serif');
    font-style: italic; font-weight: 300;
    font-size: 11rem; line-height: .85;
    color: theme('colors.paper'); z-index: 2;
    text-shadow: 0 4px 30px rgba(0,0,0,.35);
    pointer-events: none;
    letter-spacing: -0.04em;
  }
  .hero .quota small {
    font-size: 1.4rem; font-style: normal;
    font-family: theme('fontFamily.mono');
    letter-spacing: .15em; text-transform: uppercase;
    display: block; margin-top: .5rem; opacity: .85;
  }

  .section { padding: 6rem 4rem; }
  .section-sand { background: theme('colors.sabbia'); }
  .section-acqua { background: theme('colors.acqua'); }
  .section-paper { background: theme('colors.paper'); }

  .portal-lead {
    font-style: italic; font-size: 1.25rem; max-width: 52ch;
    color: theme('colors.ink-soft'); margin: 0 0 2rem 0;
  }
  .portal-tags {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-wrap: wrap; gap: .65rem;
  }
  .portal-tag {
    display: inline-flex; align-items: center; gap: .35rem;
    padding: .55rem 1.1rem;
    border: 1.5px solid theme('colors.rule');
    border-radius: 999px;
    font-family: theme('fontFamily.mono'); font-size: .75rem;
    text-transform: uppercase; letter-spacing: .16em;
    color: theme('colors.acquadeep');
    text-decoration: none;
    background: rgba(255,255,255,0.55);
    transition: background .2s, color .2s, border-color .2s, transform .2s;
  }
  .portal-tag:hover {
    background: theme('colors.acquadeep');
    color: #fff;
    border-color: theme('colors.acquadeep');
    transform: translateY(-2px);
  }

  /* ── Wave dividers ── */
  .wave { display: block; line-height: 0; margin-bottom: -1px; }
  .wave svg { display: block; width: 100%; height: 48px; }
  .wave--sand { background: theme('colors.ink'); }
  .wave--acqua { background: theme('colors.sabbia'); }
  .section-head {
    display: grid; grid-template-columns: 1fr auto;
    align-items: end; gap: 2rem;
    margin-bottom: 3rem; padding-bottom: 1.5rem;
    border-bottom: 1px dashed theme('colors.rule');
  }
  .eyebrow {
    font-family: theme('fontFamily.mono');
    font-size: .78rem; text-transform: uppercase;
    letter-spacing: .22em; color: theme('colors.ink-soft');
  }
  .section-head h2 {
    font-family: theme('fontFamily.serif');
    font-weight: 300;
    font-size: clamp(2.4rem, 4.5vw, 4rem);
    line-height: 1; letter-spacing: -0.02em;
    margin: .5rem 0 0 0;
  }
  .section-head h2 :global(em) { font-style: italic; color: theme('colors.acquadeep'); }
  .section-head .all {
    font-family: theme('fontFamily.mono');
    font-size: .78rem; text-transform: uppercase;
    letter-spacing: .18em;
    color: theme('colors.brand-deep');
    text-decoration: none;
    align-self: end;
  }
  .section-head .all:hover { color: theme('colors.brand'); }

  .events { display: grid; grid-template-columns: 1.4fr 1fr 1fr; gap: 2.5rem; }
  .event { text-decoration: none; color: inherit; display: flex; flex-direction: column; transition: transform .3s ease; }
  .event:hover { transform: translateY(-4px); }
  .event .pic {
    aspect-ratio: 4 / 3;
    overflow: hidden; position: relative;
    background: theme('colors.ink');
    border: 1px solid theme('colors.rule');
    margin-bottom: 1.25rem;
    -webkit-mask-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 75' preserveAspectRatio='none'><path d='M1 2 Q 25 0 50 2 T 99 2 L 99 73 Q 75 75 50 73 T 1 73 Z' fill='black'/></svg>");
    mask-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 75' preserveAspectRatio='none'><path d='M1 2 Q 25 0 50 2 T 99 2 L 99 73 Q 75 75 50 73 T 1 73 Z' fill='black'/></svg>");
  }
  .event.big .pic { aspect-ratio: 4 / 3.5; }
  .event .pic img { width: 100%; height: 100%; object-fit: cover; filter: saturate(.92); transition: transform .8s cubic-bezier(.2,.7,.2,1); }
  .event:hover .pic img { transform: scale(1.04); }
  .event-stamp {
    position: absolute; top: 1rem; left: 1rem;
    background: theme('colors.paper');
    color: theme('colors.ink');
    font-family: theme('fontFamily.serif');
    padding: .5rem .75rem; line-height: 1; text-align: center;
    box-shadow: 0 1px 0 rgba(0,0,0,.05), 0 8px 16px rgba(0,0,0,.08);
    transform: rotate(-2deg);
  }
  .event-stamp .d { font-size: 1.8rem; font-weight: 300; display: block; font-style: italic; }
  .event-stamp .m {
    font-family: theme('fontFamily.mono');
    font-size: .68rem; text-transform: uppercase;
    letter-spacing: .18em; margin-top: .15rem;
  }
  .event h3 {
    font-family: theme('fontFamily.serif');
    font-weight: 400; font-size: 1.55rem; line-height: 1.15;
    margin: .25rem 0 .5rem 0;
  }
  .event.big h3 { font-size: 2.1rem; }
  .event .where {
    font-family: theme('fontFamily.mono');
    font-size: .75rem; text-transform: uppercase;
    letter-spacing: .18em; color: theme('colors.ink-soft');
  }
  .event .signup { margin-top: .75rem; color: theme('colors.gold-deep'); font-style: italic; }

  .notices { list-style: none; padding: 0; margin: 0; }
  .notice { border-top: 1px solid theme('colors.rule'); }
  .notice:last-child { border-bottom: 1px solid theme('colors.rule'); }
  .notice a {
    display: grid;
    grid-template-columns: 14rem 1fr auto;
    align-items: baseline;
    gap: 2rem;
    padding: 1.6rem 0;
    text-decoration: none; color: theme('colors.ink');
    transition: padding .25s ease, color .25s ease;
  }
  .notice a:hover { padding-left: .75rem; color: theme('colors.brand'); }
  .notice time {
    font-family: theme('fontFamily.mono');
    font-size: .75rem; text-transform: uppercase;
    letter-spacing: .18em; color: theme('colors.ink-soft');
  }
  .notice h3 {
    font-family: theme('fontFamily.serif');
    font-weight: 400; font-size: 1.5rem; line-height: 1.2;
    margin: 0;
  }
  .notice .arrow {
    font-family: theme('fontFamily.mono');
    color: theme('colors.brand');
    opacity: 0; transform: translateX(-6px);
    transition: opacity .25s ease, transform .3s ease;
  }
  .notice a:hover .arrow { opacity: 1; transform: translateX(0); }

  .threecol {
    display: grid; grid-template-columns: repeat(3, 1fr);
    border-top: 1px solid theme('colors.rule');
    border-bottom: 1px solid theme('colors.rule');
  }
  .threecol .col {
    padding: 4.5rem 2.5rem;
    border-right: 1px dashed theme('colors.rule');
    text-decoration: none; color: inherit;
    transition: background .3s ease;
  }
  .threecol .col:last-child { border-right: none; }
  .threecol .col:hover { background: theme('colors.paper-2'); }
  .threecol .col .num {
    font-family: theme('fontFamily.serif');
    font-style: italic; font-weight: 300;
    color: theme('colors.gold');
    font-size: 4rem; line-height: 1; margin-bottom: 1rem;
  }
  .threecol .col h3 {
    font-family: theme('fontFamily.serif');
    font-weight: 400; font-size: 2rem; line-height: 1.1;
    margin: 0 0 .75rem 0;
  }
  .threecol .col h3 :global(em) { font-style: italic; color: theme('colors.acquadeep'); }
  .threecol .col p {
    font-style: italic; color: theme('colors.ink-soft');
    max-width: 32ch; margin: 0 0 1.5rem 0;
  }
  .threecol .col .arrow-link {
    font-family: theme('fontFamily.mono');
    font-size: .78rem; text-transform: uppercase;
    letter-spacing: .18em; color: theme('colors.gold-deep');
  }

  .pull {
    padding: 7rem 4rem;
    display: grid; grid-template-columns: 1fr 1.6fr 1fr;
    gap: 3rem; align-items: center;
    border-bottom: 1px solid theme('colors.rule');
    background: linear-gradient(180deg, transparent, rgba(123,143,111,0.07));
  }
  .pull blockquote {
    grid-column: 2 / 3;
    margin: 0;
    font-family: theme('fontFamily.serif');
    font-style: italic; font-weight: 300;
    font-size: clamp(2rem, 3.6vw, 3.2rem);
    line-height: 1.1; text-align: center;
    color: theme('colors.ink');
    position: relative;
  }
  .pull blockquote::before {
    content: "“"; position: absolute;
    top: -3rem; left: -1.5rem;
    font-size: 8rem;
    color: theme('colors.gold');
    line-height: 1; font-style: normal; opacity: .55;
  }
  .pull blockquote :global(em) { font-style: italic; color: theme('colors.acquadeep'); }

  .cta {
    padding: 6rem 4rem;
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 4rem; align-items: center;
    border-bottom: 1px solid theme('colors.rule');
  }
  .cta h2 {
    font-family: theme('fontFamily.serif');
    font-weight: 300;
    font-size: clamp(2.4rem, 4.5vw, 4rem);
    line-height: 1; margin: 0;
  }
  .cta h2 :global(em) { font-style: italic; color: theme('colors.gold-deep'); }
  .cta .opts { display: grid; gap: 1rem; }
  .cta .opt {
    display: flex; justify-content: space-between; align-items: center;
    padding: 1.5rem 0;
    border-bottom: 1px solid theme('colors.rule');
    text-decoration: none; color: inherit;
    transition: padding .25s ease;
  }
  .cta .opt:hover { padding-left: .75rem; }
  .cta .opt .label {
    font-family: theme('fontFamily.serif');
    font-size: 1.6rem; font-weight: 400;
  }
  .cta .opt .label :global(em) { font-style: italic; color: theme('colors.acquadeep'); }
  .cta .opt .arrow {
    font-family: theme('fontFamily.mono');
    font-size: .9rem; color: theme('colors.gold-deep');
  }

  /* ── Portal preview grid ── */
  .portal-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
  }
  .portal-left { display: flex; flex-direction: column; }
  .portal-h2 {
    font-family: theme('fontFamily.serif');
    font-weight: 300;
    font-size: clamp(2.4rem, 4.5vw, 4rem);
    line-height: 1; letter-spacing: -0.02em;
    margin: .5rem 0 0 0;
  }
  .portal-h2 :global(em) { font-style: italic; color: theme('colors.acquadeep'); }
  .portal-rule {
    width: 100%; height: 1px;
    background: theme('colors.rule');
    border: none; margin: 1.75rem 0;
  }
  .portal-cta {
    display: inline-flex; align-items: center; gap: .5rem;
    margin-top: 2rem;
    font-family: theme('fontFamily.mono'); font-size: .78rem;
    text-transform: uppercase; letter-spacing: .16em;
    color: theme('colors.acquadeep');
    text-decoration: none;
    transition: color .2s;
  }
  .portal-cta:hover { color: theme('colors.brand'); }
  .portal-cta-arr { transition: transform .25s; }
  .portal-cta:hover .portal-cta-arr { transform: translateX(4px); }

  /* ── Carousel ── */
  .portal-carousel {
    position: relative;
    height: 460px;
    border-radius: .75rem;
    overflow: hidden;
    background: theme('colors.ink');
    cursor: pointer;
  }
  .carousel-slides { position: relative; width: 100%; height: 100%; }
  .carousel-slide {
    position: absolute; inset: 0;
    display: block; text-decoration: none;
    opacity: 0;
    transition: opacity .8s ease;
  }
  .carousel-slide.active { opacity: 1; }
  .carousel-slide img,
  .slide-color {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    filter: saturate(.85) contrast(1.05);
  }
  .slide-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(160deg, rgba(31,42,42,0.08) 0%, rgba(31,42,42,0.72) 100%);
  }
  .slide-content {
    position: absolute;
    bottom: 2rem; left: 2rem; right: 2rem;
    display: flex; justify-content: space-between; align-items: flex-end;
  }
  .slide-label {
    font-family: theme('fontFamily.hand');
    font-weight: 700;
    font-size: 3.2rem;
    color: #fff;
    line-height: 1;
    text-shadow: 0 2px 16px rgba(0,0,0,.35);
  }
  .slide-arr {
    font-family: theme('fontFamily.mono');
    font-size: 1rem; color: rgba(255,255,255,.7);
    transition: transform .3s;
  }
  .carousel-slide:hover .slide-arr { transform: translateX(5px); }
  .carousel-dots {
    position: absolute; top: 1.25rem; right: 1.25rem;
    display: flex; gap: .5rem; z-index: 5;
  }
  .cdot {
    width: 8px; height: 8px; border-radius: 50%;
    border: 1.5px solid rgba(255,255,255,0.55);
    background: transparent; cursor: pointer; padding: 0;
    transition: background .25s, border-color .25s, transform .25s;
  }
  .cdot.active {
    background: #fff; border-color: #fff; transform: scale(1.25);
  }

  @media (max-width: 1000px) {
    .hero { grid-template-columns: 1fr; }
    .hero .text { padding: 3rem 1.5rem; }
    .hero .image { aspect-ratio: 4/3; min-height: 300px; }
    .hero .quota { font-size: 6rem; right: 1rem; bottom: 1rem; }
    .portal-grid { grid-template-columns: 1fr; gap: 2.5rem; }
    .portal-carousel { height: 320px; }
    .events, .threecol, .cta { grid-template-columns: 1fr; }
    .threecol .col { border-right: none; border-bottom: 1px dashed theme('colors.rule'); }
    .section, .pull, .cta { padding: 3.5rem 1.5rem; }
    .pull blockquote { grid-column: 1 / -1; }
    .notice a { grid-template-columns: 1fr; gap: .35rem; padding: 1.25rem 0; }
  }
</style>

<script>
  (function () {
    const carousel = document.getElementById('portal-carousel');
    if (!carousel) return;
    const slides = Array.from(carousel.querySelectorAll<HTMLElement>('.carousel-slide'));
    const dots   = Array.from(carousel.querySelectorAll<HTMLElement>('.cdot'));
    if (!slides.length) return;
    let current = 0;
    let timer: ReturnType<typeof setInterval>;

    function go(n: number) {
      slides[current].classList.remove('active');
      dots[current].classList.remove('active');
      current = ((n % slides.length) + slides.length) % slides.length;
      slides[current].classList.add('active');
      dots[current].classList.add('active');
    }

    function start() {
      timer = setInterval(() => go(current + 1), 4000);
    }

    dots.forEach((dot, i) => {
      dot.addEventListener('click', (e) => {
        e.preventDefault();
        clearInterval(timer);
        go(i);
        start();
      });
    });

    carousel.addEventListener('mouseenter', () => clearInterval(timer));
    carousel.addEventListener('mouseleave', start);

    start();
  })();
</script>
