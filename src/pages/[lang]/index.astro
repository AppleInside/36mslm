</style>

<script>
  (function () {
    const container = document.getElementById('portal-panels');
    if (!container) return;
    const panels = Array.from(container.querySelectorAll<HTMLElement>('.panel'));
    if (!panels.length) return;
    let current = 0;
    let timer: ReturnType<typeof setInterval>;

    function goTo(n: number) {
      panels[current].classList.remove('is-active');
      current = ((n % panels.length) + panels.length) % panels.length;
      panels[current].classList.add('is-active');
    }

    function start() {
      timer = setInterval(() => goTo(current + 1), 3500);
    }

    panels.forEach((p, i) => {
      p.addEventListener('mouseenter', () => {
        clearInterval(timer);
        goTo(i);
      });
      p.addEventListener('click', (e) => {
        if (i !== current) { e.preventDefault(); goTo(i); }
      });
    });

    container.addEventListener('mouseleave', () => {
      clearInterval(timer);
      start();
    });

    start();
  })();
</script>
