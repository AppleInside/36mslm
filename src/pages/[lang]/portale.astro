<script>
  (function () {
    const slides = document.querySelectorAll<HTMLElement>('.ws');
    const dots   = document.querySelectorAll<HTMLElement>('.wdot');

    // Map section ids to dots
    const ids = Array.from(slides).map(s => s.id);

    const obs = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            (entry.target as HTMLElement).classList.add('wvis');
            const idx = ids.indexOf((entry.target as HTMLElement).id);
            dots.forEach((d, i) => d.classList.toggle('wdot--on', i === idx));
          }
        });
      },
      { threshold: 0.3 }
    );

    slides.forEach(s => obs.observe(s));

    // Dot click → smooth scroll
    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        const target = dot.dataset.to;
        const el = target ? document.getElementById(target) : null;
        el?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    });

    // Keyboard arrow nav between sections
    document.addEventListener('keydown', (e) => {
      if (e.key !== 'ArrowDown' && e.key !== 'ArrowUp') return;
      const active = Array.from(slides).findIndex(s => s.classList.contains('wvis'));
      const next = e.key === 'ArrowDown'
        ? Math.min(active + 1, slides.length - 1)
        : Math.max(active - 1, 0);
      if (next !== active) {
        e.preventDefault();
        slides[next].scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  })();
</script>
