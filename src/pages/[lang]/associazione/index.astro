---
export const prerender = false;
import Base from '../../../layouts/Base.astro';
import PageHeader from '../../../components/PageHeader.astro';
import { localizedPath } from '../../../i18n/utils';
import type { Lang } from '../../../i18n/ui';
import { sql } from '../../../server/db';

const lang = Astro.params.lang as Lang;

let docsUrl = '/media/legacy/wp-content_uploads_2021_09_Giovanni-Guareschi-al-bar-in-piazza.jpg';

try {
  const covers = await sql<{ cover_url: string }[]>`
    SELECT cover_url FROM page_covers WHERE page_key = 'associazione-docs' LIMIT 1
  `;
  if (covers[0]?.cover_url) docsUrl = covers[0].cover_url;
} catch {}
---

<Base title={lang === 'it' ? "L'associazione" : 'The association'}>
  <PageHeader
    pageKey="chi-siamo"
    eyebrow={lang === 'it' ? '— Informazioni —' : '— Information —'}
    bg="/media/storico/1953-Giovannino-Guareschi-Polesine-Due-Torri-1.jpg"
  >
    {lang === 'it' ? <>L'<em>associazione</em></> : <>The <em>association</em></>}
  </PageHeader>

  <div class="hub">

    <!-- ── Documenti ──────────────────────────── -->
    <div class="hub-card">
      <div class="hub-img-wrap">
        <a class="hub-img-link" href={localizedPath(lang, 'chi-siamo/storia')}>
          <div class="hub-img" id="hub-img-docs" style={`--img: url('${docsUrl}')`}>
            <div class="hub-caption">
              <p class="hub-eyebrow">{lang === 'it' ? '— Documenti —' : '— Documents —'}</p>
              <h2>{lang === 'it' ? 'L\'associazione' : 'The association'}</h2>
            </div>
          </div>
        </a>
        <button class="hub-edit-btn" id="hub-editbtn-docs" style="display:none" title="Modifica immagine" aria-label="Modifica immagine">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="3" width="18" height="18" rx="2"/>
            <circle cx="8.5" cy="8.5" r="1.5"/>
            <polyline points="21 15 16 10 5 21"/>
          </svg>
        </button>
        <input type="file" id="hub-file-docs" accept="image/*" style="display:none">
      </div>
      <ul class="hub-links">
        <li>
          <a href={localizedPath(lang, 'chi-siamo/storia')}>
            {lang === 'it' ? 'Chi siamo' : 'Who we are'}
            <span class="arr">→</span>
          </a>
        </li>
        <li>
          <a href={localizedPath(lang, 'chi-siamo/statuto')}>
            {lang === 'it' ? 'Statuto' : 'Bylaws'}
            <span class="arr">→</span>
          </a>
        </li>
        <li>
          <a href={localizedPath(lang, 'chi-siamo/press-kit')}>
            {lang === 'it' ? 'Press kit' : 'Press kit'}
            <span class="arr">→</span>
          </a>
        </li>
      </ul>
    </div>

  </div>
</Base>

<script is:inline>
(function () {
  var cards = [
    { imgId: 'hub-img-docs', btnId: 'hub-editbtn-docs', fileId: 'hub-file-docs', key: 'associazione-docs' },
  ];

  function setupCard(c, isAdmin) {
    var imgEl   = document.getElementById(c.imgId);
    var btn     = document.getElementById(c.btnId);
    var fileInp = document.getElementById(c.fileId);
    if (!imgEl || !btn || !fileInp) return;

    if (isAdmin) btn.style.display = 'flex';

    btn.addEventListener('click', function (e) {
      e.preventDefault();
      e.stopPropagation();
      fileInp.click();
    });

    fileInp.addEventListener('change', function () {
      var f = fileInp.files && fileInp.files[0];
      if (!f) return;

      var reader = new FileReader();
      reader.onload = function (ev) {
        imgEl.style.setProperty('--img', "url('" + ev.target.result + "')");
      };
      reader.readAsDataURL(f);

      var fd = new FormData();
      fd.append('cover', f);
      fd.append('position', 'center 30%');

      btn.style.opacity = '.35';
      btn.disabled = true;

      fetch('/api/covers/' + c.key, { method: 'POST', body: fd })
        .then(function (r) { return r.json(); })
        .then(function (resp) {
          if (resp && resp.ok && resp.cover_url) {
            var probe = new Image();
            probe.onload = function () {
              imgEl.style.setProperty('--img', "url('" + resp.cover_url + "')");
            };
            probe.src = resp.cover_url;
          }
          btn.style.opacity = '';
          btn.disabled = false;
        })
        .catch(function () {
          btn.style.opacity = '';
          btn.disabled = false;
        });
    });
  }

  fetch('/api/admin/me')
    .then(function (r) { return r.json(); })
    .then(function (d) { cards.forEach(function (c) { setupCard(c, d && d.ok); }); })
    .catch(function ()  { cards.forEach(function (c) { setupCard(c, false); }); });
})();
</script>

<style>
  .hub {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    max-width: 1100px;
    margin: 2rem auto 3rem;
    padding: 0 1.25rem;
  }

  @media (min-width: 700px) {
    .hub {
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
      margin-top: 2.5rem;
    }
  }

  .hub-card {
    border: 1px solid theme('colors.rule');
    border-radius: .5rem;
    overflow: hidden;
    margin-bottom: 1.5rem;
  }
  @media (min-width: 700px) {
    .hub-card { margin-bottom: 0; }
  }

  .hub-img-wrap {
    position: relative;
    display: block;
  }

  .hub-img-link {
    display: block;
    text-decoration: none;
  }
  .hub-img {
    position: relative;
    height: 220px;
    background-color: theme('colors.ink');
    background-image: var(--img);
    background-size: cover;
    background-position: center 30%;
    display: flex;
    align-items: flex-end;
  }
  .hub-img::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(15,22,28,.15) 0%, rgba(15,22,28,.72) 100%);
    transition: opacity .2s;
  }
  .hub-img-link:hover .hub-img::before { opacity: .85; }
  @media (min-width: 700px) {
    .hub-img { height: 260px; }
  }

  .hub-edit-btn {
    position: absolute;
    bottom: .75rem;
    right: .75rem;
    z-index: 4;
    width: 2.2rem;
    height: 2.2rem;
    border-radius: 50%;
    border: none;
    background: rgba(15,22,28,.55);
    backdrop-filter: blur(6px);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background .15s, transform .12s, opacity .15s;
    box-shadow: 0 1px 8px rgba(0,0,0,.2), 0 0 0 1px rgba(255,255,255,.1);
  }
  .hub-edit-btn:hover { background: rgba(15,22,28,.82); transform: scale(1.08); }

  .hub-caption {
    position: relative;
    z-index: 1;
    padding: 1rem 1.25rem 1.1rem;
  }
  .hub-eyebrow {
    font-family: theme('fontFamily.mono');
    font-size: .68rem;
    letter-spacing: .22em;
    text-transform: uppercase;
    color: rgba(232,244,248,.75);
    margin: 0 0 .3rem;
  }
  .hub-caption h2 {
    margin: 0;
    font-size: clamp(1.5rem, 4vw, 2rem);
    color: #fff;
    text-shadow: 0 2px 12px rgba(0,0,0,.4);
    line-height: 1.1;
  }

  .hub-links {
    list-style: none;
    margin: 0;
    padding: 0;
    background: theme('colors.paper');
  }
  .hub-links li { border-top: 1px solid theme('colors.rule'); }
  .hub-links a {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: .8rem 1.25rem;
    font-family: theme('fontFamily.serif');
    font-size: 1rem;
    color: theme('colors.ink');
    text-decoration: none;
    transition: background .15s, color .15s;
  }
  .hub-links a:hover {
    background: theme('colors.paper-2');
    color: theme('colors.acquadeep');
  }
  .arr {
    font-size: .85rem;
    color: theme('colors.ink-soft');
    transition: transform .15s;
  }
  .hub-links a:hover .arr {
    transform: translateX(3px);
    color: theme('colors.acquadeep');
  }
</style>
