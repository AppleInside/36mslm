---
import Base from '../../layouts/Base.astro';
import PageHeader from '../../components/PageHeader.astro';
import PageBody from '../../components/PageBody.astro';
import { SITE } from '../../consts';
import { useTranslations } from '../../i18n/utils';
import type { Lang } from '../../i18n/ui';

export function getStaticPaths() {
  return [{ params: { lang: 'it' } }, { params: { lang: 'en' } }];
}

const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);
---

<Base title={t('nav.contact')}>
  <PageHeader
    eyebrow={lang === 'it' ? '— Scrivici —' : '— Write to us —'}
    bg="/media/storico/passeggiavano-nel-viale.jpg"
  >
    {lang === 'it' ? <>Contatti e <em>recapiti</em></> : <>Contacts and <em>info</em></>}
  </PageHeader>

  <PageBody narrow>
    <div class="contact-block">
      <p class="intro">{lang === 'it'
        ? 'Per qualsiasi domanda — eventi, foto, segnalazioni — scrivici. Rispondiamo nel giro di qualche giorno.'
        : 'Any question — events, photos, reports — drop us a line. We reply within a few days.'}</p>

      <ul class="info-list">
        <li>
          <span class="info-label">{lang === 'it' ? 'Email' : 'Email'}</span>
          <a href={`mailto:${SITE.email}`} class="info-value">{SITE.email}</a>
        </li>
        <li>
          <span class="info-label">{lang === 'it' ? 'Sede' : 'Office'}</span>
          <span class="info-value">{SITE.address}</span>
        </li>
        <li>
          <span class="info-label">{lang === 'it' ? 'Codice fiscale' : 'Tax code'}</span>
          <span class="info-value">{SITE.codiceFiscale}</span>
        </li>
      </ul>

      <div class="social-section">
        <p class="social-label">{lang === 'it' ? 'Seguici su' : 'Follow us on'}</p>
        <div class="social-buttons">
          <a href="https://www.facebook.com/polesineparmense36" target="_blank" rel="noopener" class="social-btn">
            <img src="/icons/Facebook_icon.png" alt="Facebook" width="28" height="28" />
            Facebook
          </a>
          <a href="https://www.instagram.com/polesineparmense36" target="_blank" rel="noopener" class="social-btn">
            <img src="/icons/Instragram_icon.png" alt="Instagram" width="28" height="28" />
            Instagram
          </a>
        </div>
      </div>
    </div>
  </PageBody>
</Base>

<style>
  .contact-block { display: flex; flex-direction: column; gap: 2rem; }

  .intro {
    font-size: 1.05rem;
    line-height: 1.7;
    color: theme('colors.ink-soft');
    margin: 0;
  }

  .info-list {
    list-style: none;
    padding: 0; margin: 0;
    border: 1px solid theme('colors.rule');
    border-radius: .5rem;
    overflow: hidden;
  }
  .info-list li {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    padding: .85rem 1.25rem;
    border-bottom: 1px solid theme('colors.rule');
  }
  .info-list li:last-child { border-bottom: none; }
  .info-label {
    font-family: theme('fontFamily.mono');
    font-size: .68rem;
    text-transform: uppercase;
    letter-spacing: .16em;
    color: theme('colors.ink-soft');
    flex-shrink: 0;
    min-width: 7rem;
  }
  .info-value {
    font-family: theme('fontFamily.serif');
    font-size: 1rem;
    color: theme('colors.ink');
    text-decoration: none;
  }
  a.info-value:hover { color: theme('colors.brand'); text-decoration: underline; text-underline-offset: 3px; }

  .social-section { display: flex; flex-direction: column; gap: .75rem; }
  .social-label {
    font-family: theme('fontFamily.mono');
    font-size: .72rem;
    text-transform: uppercase;
    letter-spacing: .18em;
    color: theme('colors.ink-soft');
    margin: 0;
  }
  .social-buttons {
    display: flex;
    gap: .75rem;
    flex-wrap: wrap;
  }
  .social-btn {
    display: inline-flex;
    align-items: center;
    gap: .55rem;
    padding: .65rem 1.25rem;
    border-radius: .4rem;
    border: 1px solid theme('colors.rule');
    background: theme('colors.paper');
    font-family: theme('fontFamily.mono');
    font-size: .8rem;
    letter-spacing: .06em;
    color: theme('colors.ink');
    text-decoration: none;
    font-weight: 600;
    transition: background .18s, transform .18s;
  }
  .social-btn:hover { background: theme('colors.paper-2'); transform: translateY(-1px); }
</style>
