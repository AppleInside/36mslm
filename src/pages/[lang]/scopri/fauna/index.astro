    opacity: .5;
    background: none;
    border: 1px solid transparent;
    border-radius: 999px;
    padding: .28rem .72rem;
    cursor: pointer;
    transition: opacity .15s, background .15s, border-color .15s;
    display: inline-flex;
    align-items: center;
    gap: .32rem;
    white-space: nowrap;
  }
  .filtri-btn:hover { opacity: .8; }
  .filtri-btn.attivo { opacity:1; background:rgba(74,102,112,.07); border-color:rgba(74,102,112,.2); }
  .dot { width:7px; height:7px; border-radius:50%; background:var(--dot,#6b7280); flex-shrink:0; }
  .cnt { font-size:.58rem; background:rgba(74,86,104,.1); border-radius:999px; padding:.04rem .34rem; }

  /* Card list */
  .ani-list { flex:1; overflow-y:auto; overscroll-behavior:contain; }
  .ani-list::-webkit-scrollbar { width:3px; }
  .ani-list::-webkit-scrollbar-thumb { background:rgba(74,86,104,.18); border-radius:2px; }

  /* Animal card */
  .ani-card {
    width:100%;
    display:grid;
    grid-template-columns: 4px 68px 1fr auto;
    align-items: stretch;
    background:none; border:none;
    border-bottom:1px solid rgba(74,86,104,.07);
    cursor:pointer; text-align:left; padding:0;
    transition:background .15s;
  }
  .ani-card:hover  { background:rgba(74,86,104,.04); }
  .ani-card.attiva { background:color-mix(in srgb,var(--col) 8%,white); }

  .ani-stripe {
    background:var(--col,#6b7280);
    opacity:0; transition:opacity .15s;
  }
  .ani-card:hover  .ani-stripe { opacity:.45; }
  .ani-card.attiva .ani-stripe { opacity:1; }

  /* Thumbnail */
  .ani-thumb {
    width:68px; min-height:68px;
    overflow:hidden;
    background:color-mix(in srgb,var(--col) 12%,#f0ede8);
