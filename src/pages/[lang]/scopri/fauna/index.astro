---
import Base from '../../../../layouts/Base.astro';
import PageHeader from '../../../../components/PageHeader.astro';
import { getCollection } from 'astro:content';
import type { Lang } from '../../../../i18n/ui';

export function getStaticPaths() {
  return [{ params: { lang: 'it' } }, { params: { lang: 'en' } }];
}

const lang = Astro.params.lang as Lang;

const all = await getCollection('sightings');
const items = all
  .filter(e => e.slug.startsWith(`${lang}/`) && !e.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const catLabel: Record<string, string> = lang === 'it'
  ? { uccello:'Uccelli', mammifero:'Mammiferi', pesce:'Pesci', rettile:'Rettili', anfibio:'Anfibi', pianta:'Piante', altro:'Altro' }
  : { uccello:'Birds', mammifero:'Mammals', pesce:'Fish', rettile:'Reptiles', anfibio:'Amphibians', pianta:'Plants', altro:'Other' };

const catColor: Record<string,string> = {
  uccello:'#3a7abf', mammifero:'#9b6020', pesce:'#1f8a9a',
  rettile:'#5a8a1e', anfibio:'#2e7a3e', pianta:'#2d6a4f', altro:'#6b7280',
};

const counts: Record<string,number> = {};
for (const s of items) counts[s.data.category] = (counts[s.data.category] ?? 0) + 1;

const months = lang === 'it'
  ? ['gen','feb','mar','apr','mag','giu','lug','ago','set','ott','nov','dic']
  : ['jan','feb','mar','apr','may','jun','jul','aug','sep','oct','nov','dec'];
function fmtDate(d: Date) { return `${d.getDate()} ${months[d.getMonth()]} ${d.getFullYear()}`; }

/* ── Wikipedia thumbnails — fetched once at build time ─── */
const wikiTitles: Record<string,string> = {
  'airone-cenerino':     'Ardea_cinerea',
  'martin-pescatore':    'Alcedo_atthis',
  'nitticora':           'Nycticorax_nycticorax',
  'cicogna-bianca':      'Ciconia_ciconia',
  'nutria':              'Myocastor_coypus',
  'capriolo':            'Capreolus_capreolus',
  'testuggine-palustre': 'Emys_orbicularis',
  'rana-verde':          'Pelophylax_ridibundus',
  'luccio':              'Esox_lucius',
  'pioppo-bianco':       'Populus_alba',
};

const thumbs: Record<string,string> = {};
await Promise.all(
  Object.entries(wikiTitles).map(async ([id, title]) => {
    try {
      const r = await fetch(
        `https://en.wikipedia.org/api/rest_v1/page/summary/${title}`,
        { headers: { 'User-Agent': '36mslm-astro-build/1.0' } }
      );
      if (!r.ok) return;
      const j = await r.json() as { thumbnail?: { source: string } };
      if (j.thumbnail?.source) thumbs[id] = j.thumbnail.source;
    } catch { /* fallback to placeholder */ }
  })
);

/* ── Serialise for JS ─────────────────────────────────── */
const mapItems = items.map(s => {
  const id = s.slug.replace(/^(it|en)\//, '');
  const singlePhoto = s.data.photo ?? null;
  const singleVideo = s.data.video ?? null;
  const allPhotos   = [...(singlePhoto ? [singlePhoto] : []), ...s.data.photos];
  const allVideos   = [...(singleVideo && singleVideo !== 'true' ? [singleVideo] : []), ...s.data.videos];
  return {
    id,
    title:        s.data.title,
    category:     s.data.category,
    coords:       s.data.coords,
    date:         fmtDate(s.data.date),
    notes:        s.data.notes ?? null,
    thumb:        thumbs[id] ?? null,
    photos:       allPhotos,
    videos:       allVideos,
    hasVideoFlag: singleVideo === 'true',
  };
});
---

<Base title={lang === 'it' ? 'Fauna e flora' : 'Fauna and flora'}>
  <PageHeader
    eyebrow={lang === 'it' ? '— Territorio —' : '— Territory —'}
    bg="/media/storico/Guareschi-sul-Po.jpg"
  >
    {lang === 'it' ? <>Fauna e <em>flora</em></> : <>Fauna and <em>flora</em></>}
  </PageHeader>

  <!-- Tab bar: lista / mappa (solo mobile) -->
  <div class="fauna-tabs" id="fauna-tabs">
    <button class="fauna-tab attivo" id="tab-lista">
      <svg width="13" height="13" viewBox="0 0 13 13" fill="none"><rect x="1" y="1" width="3" height="3" rx=".5" fill="currentColor"/><rect x="1" y="5.5" width="3" height="3" rx=".5" fill="currentColor"/><rect x="1" y="10" width="3" height="2.5" rx=".5" fill="currentColor"/><rect x="5.5" y="2" width="6.5" height="1.2" rx=".5" fill="currentColor"/><rect x="5.5" y="6.5" width="6.5" height="1.2" rx=".5" fill="currentColor"/><rect x="5.5" y="11" width="4" height="1.2" rx=".5" fill="currentColor"/></svg>
      {lang === 'it' ? 'Lista' : 'List'}
    </button>
    <button class="fauna-tab" id="tab-mappa">
      <svg width="13" height="13" viewBox="0 0 13 13" fill="none"><path d="M6.5 1.5C4.5 1.5 2.5 3.2 2.5 5.3c0 3.2 4 6.7 4 6.7s4-3.5 4-6.7c0-2.1-2-3.8-4-3.8z" stroke="currentColor" stroke-width="1.2"/><circle cx="6.5" cy="5.3" r="1.3" stroke="currentColor" stroke-width="1.1"/></svg>
      Mappa
    </button>
    <button class="fauna-tab" id="tab-media">
      <svg width="13" height="13" viewBox="0 0 13 13" fill="none"><rect x="1" y="1" width="4.5" height="4.5" rx=".6" fill="currentColor"/><rect x="7.5" y="1" width="4.5" height="4.5" rx=".6" fill="currentColor"/><rect x="1" y="7.5" width="4.5" height="4.5" rx=".6" fill="currentColor"/><rect x="7.5" y="7.5" width="4.5" height="4.5" rx=".6" fill="currentColor"/></svg>
      Media
    </button>
  </div>

  <div class="fauna-layout">

    <!-- ── Sidebar ─────────────────────────────────── -->
    <aside class="fauna-sidebar">
      <nav class="filtri">
        <button class="filtri-btn attivo" data-filter="all">
          {lang === 'it' ? 'Tutti' : 'All'} <span class="cnt">{items.length}</span>
        </button>
        {Object.entries(counts).map(([cat, n]) => (
          <button class="filtri-btn" data-filter={cat} style={`--dot:${catColor[cat]}`}>
            <span class="dot"></span>{catLabel[cat]}<span class="cnt">{n}</span>
          </button>
        ))}
      </nav>

      <div class="ani-list" id="ani-list">
        {items.map(s => {
          const id     = s.slug.replace(/^(it|en)\//, '');
          const cat    = s.data.category;
          const col    = catColor[cat];
          const thumb  = thumbs[id] ?? null;
          const hasAnyPhoto = !!(thumb || s.data.photo || s.data.photos?.length);
          const firstVideoUrl = (s.data.video && s.data.video !== 'true') ? s.data.video : (s.data.videos?.[0] ?? null);
          return (
            <div
              class="ani-card"
              data-id={id}
              data-category={cat}
              data-lat={s.data.coords[0]}
              data-lng={s.data.coords[1]}
              style={`--col:${col}`}
              role="button"
              tabindex="0"
              aria-label={s.data.title}
            >
              <span class="ani-stripe"></span>

              <!-- Thumbnail -->
              <div class="ani-thumb" style={`--col:${col}`}>
                {thumb
                  ? <img src={thumb} alt={s.data.title} class="ani-thumb-img" loading="lazy" />
                  : <span class="ani-thumb-icon" aria-hidden="true">
                      {cat === 'uccello'   && <svg viewBox="0 0 32 32"><path d="M26 8c-3-3-8-3-11 0l-9 5-1 3 5-1 5 3c-3 4-4 8-2 10 5-5 9-7 13-12 3-4 3-7 0-8z" fill="currentColor"/><path d="M5 20c-2 2-4 5-2 7" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round"/></svg>}
                      {cat === 'mammifero' && <svg viewBox="0 0 32 32"><ellipse cx="15" cy="18" rx="9" ry="6" fill="currentColor"/><circle cx="15" cy="10" r="5" fill="currentColor"/><path d="M11 24v4M19 24v4M9 16c-3 0-5-1-5-3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" fill="none"/></svg>}
                      {cat === 'pesce'     && <svg viewBox="0 0 32 32"><path d="M4 16c0 0 4-8 14-8 6 0 10 4 10 8s-4 8-10 8C8 24 4 16 4 16z" fill="currentColor"/><path d="M2 12l4 4-4 4" fill="currentColor"/><circle cx="22" cy="14" r="1.5" fill="white"/></svg>}
                      {cat === 'rettile'   && <svg viewBox="0 0 32 32"><ellipse cx="16" cy="18" rx="11" ry="7" fill="currentColor"/><path d="M10 18c0-4 3-7 6-7s6 3 6 7" fill="currentColor" opacity=".6"/><circle cx="12" cy="15" r="1.2" fill="white"/><circle cx="20" cy="15" r="1.2" fill="white"/></svg>}
                      {cat === 'anfibio'   && <svg viewBox="0 0 32 32"><circle cx="16" cy="18" r="7" fill="currentColor"/><circle cx="10" cy="11" r="4" fill="currentColor"/><circle cx="22" cy="11" r="4" fill="currentColor"/><circle cx="10" cy="10" r="2" fill="white"/><circle cx="22" cy="10" r="2" fill="white"/><path d="M7 24l-3 4M25 24l3 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>}
                      {cat === 'pianta'    && <svg viewBox="0 0 32 32"><path d="M16 28V14M16 14C16 8 10 5 5 7c2 5 6 7 11 7M16 14c0-5 6-9 11-7-2 5-6 8-11 7" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>}
                      {(cat === 'altro' || !['uccello','mammifero','pesce','rettile','anfibio','pianta'].includes(cat)) && <svg viewBox="0 0 32 32"><path d="M16 4C11 4 7 8 7 13c0 7 9 15 9 15s9-8 9-15c0-5-4-9-9-9z" fill="currentColor"/><circle cx="16" cy="13" r="3" fill="white"/></svg>}
                    </span>
                }
              </div>

              <!-- Info -->
              <div class="ani-body">
                <p class="ani-cat">{catLabel[cat]}</p>
                <h3 class="ani-name">{s.data.title}</h3>
                {s.data.notes && <p class="ani-notes">{s.data.notes}</p>}
              </div>
              {(hasAnyPhoto || firstVideoUrl) && (
                <div class="ani-actions">
                  {hasAnyPhoto && (
                    <button class="ani-action-btn ani-photo-btn" data-id={id} aria-label="Vedi media">
                      <svg width="11" height="11" viewBox="0 0 12 12" fill="none"><rect x="1" y="1.5" width="10" height="8.5" rx="1.2" stroke="currentColor" stroke-width="1.1"/><circle cx="4" cy="4.5" r="1" fill="currentColor" opacity=".8"/><path d="M1 9l3.5-3.5L7 8l2-2 3 3" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/></svg>media
                    </button>
                  )}
                  {firstVideoUrl && (
                    <button class="ani-action-btn ani-video-btn" data-id={id} data-video={firstVideoUrl} aria-label="Vedi video">
                      <svg width="11" height="11" viewBox="0 0 10 10"><polygon points="2,1 9,5 2,9" fill="currentColor"/></svg>video
                    </button>
                  )}
                </div>
              )}
            </div>
          );
        })}
      </div>
    </aside>

    <!-- ── Map column ──────────────────────────────── -->
    <div class="fauna-mappa-col">
      <!-- Desktop tab bar: Mappa / Media -->
      <div class="fauna-col-tabs" id="fauna-col-tabs">
        <button class="fauna-col-tab attivo" id="col-tab-mappa">
          <svg width="13" height="13" viewBox="0 0 13 13" fill="none"><path d="M6.5 1.5C4.5 1.5 2.5 3.2 2.5 5.3c0 3.2 4 6.7 4 6.7s4-3.5 4-6.7c0-2.1-2-3.8-4-3.8z" stroke="currentColor" stroke-width="1.2"/><circle cx="6.5" cy="5.3" r="1.3" stroke="currentColor" stroke-width="1.1"/></svg>
          Mappa
        </button>
        <button class="fauna-col-tab" id="col-tab-media">
          <svg width="13" height="13" viewBox="0 0 13 13" fill="none"><rect x="1" y="1" width="4.5" height="4.5" rx=".6" fill="currentColor"/><rect x="7.5" y="1" width="4.5" height="4.5" rx=".6" fill="currentColor"/><rect x="1" y="7.5" width="4.5" height="4.5" rx=".6" fill="currentColor"/><rect x="7.5" y="7.5" width="4.5" height="4.5" rx=".6" fill="currentColor"/></svg>
          Media
        </button>
      </div>

      <div id="fauna-map" class="fauna-map"></div>
      <div class="legenda" id="fauna-legenda">
        {Object.entries(catColor).filter(([cat]) => counts[cat]).map(([cat, color]) => (
          <div class="legenda-item" data-cat={cat}>
            <span class="legenda-dot" style={`background:${color}`}></span>
            <span class="legenda-lbl">{catLabel[cat]}</span>
          </div>
        ))}
      </div>

      <!-- ── Inline media panel ──────────────────── -->
      <div id="fauna-media" class="fauna-media" hidden>
        <div class="fmedia-bar">
          <button class="fmedia-back" id="fmedia-back">
            <svg width="13" height="13" viewBox="0 0 13 13" fill="none"><path d="M8.5 2L3.5 6.5 8.5 11" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span id="fmedia-back-label">Mappa</span>
          </button>
          <span class="fmedia-title" id="fmedia-title"></span>
        </div>
        <div class="fmedia-stage" id="fmedia-stage"></div>
        <div class="fmedia-nav" id="fmedia-nav">
          <button class="fmedia-arrow" id="fmedia-prev"><svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M9 2L4 7l5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
          <div class="fmedia-dots" id="fmedia-dots"></div>
          <button class="fmedia-arrow" id="fmedia-next"><svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M5 2l5 5-5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
        </div>
      </div>

      <!-- ── Media tab panel ─────────────────────── -->
      <div id="fauna-media-tab" class="fauna-media-tab">
        <div class="fmtab-grid">
          {items.map(s => {
            const id    = s.slug.replace(/^(it|en)\//, '');
            const thumb = thumbs[id] ?? null;
            const col   = catColor[s.data.category];
            return (
              <button class="fmtab-item" data-id={id} style={`--col:${col}`}>
                <div class="fmtab-thumb">
                  {thumb
                    ? <img src={thumb} alt={s.data.title} loading="lazy" />
                    : <span class="fmtab-icon" aria-hidden="true" style={`color:${col}`}>
                        <svg viewBox="0 0 32 32" width="32" height="32"><rect x="3" y="5" width="26" height="20" rx="2" stroke="currentColor" stroke-width="2" fill="none"/><circle cx="11" cy="13" r="3" stroke="currentColor" stroke-width="1.8" fill="none"/><path d="M3 22l7-6 5 5 4-4 8 8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
                      </span>
                  }
                </div>
                <span class="fmtab-title">{s.data.title}</span>
              </button>
            );
          })}
        </div>
      </div>
    </div>

  </div>

  <!-- ── Slideshow modal ─────────────────────────── -->
  <div class="sl-overlay" id="sl-overlay" hidden role="dialog" aria-modal="true">
    <button class="sl-close" id="sl-close" aria-label="Chiudi">
      <svg width="16" height="16" viewBox="0 0 16 16"><path d="M2 2l12 12M14 2L2 14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
    </button>
    <button class="sl-nav sl-prev" id="sl-prev" aria-label="Precedente">
      <svg width="16" height="16" viewBox="0 0 16 16"><path d="M10 3L4 8l6 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
    <div class="sl-stage" id="sl-stage"></div>
    <button class="sl-nav sl-next" id="sl-next" aria-label="Successivo">
      <svg width="16" height="16" viewBox="0 0 16 16"><path d="M6 3l6 5-6 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
    <div class="sl-dots" id="sl-dots"></div>
  </div>

  <!-- ── Serialised data ─────────────────────────── -->
  <script is:inline id="sightings-json" type="application/json" set:html={JSON.stringify(mapItems)}></script>
  <script is:inline id="sightings-meta" type="application/json" set:html={JSON.stringify({ catColor, catLabel })}></script>

  <!-- ── Leaflet ─────────────────────────────────── -->
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

  <script is:inline>
  (function () {
    var sightings = JSON.parse(document.getElementById('sightings-json').textContent);
    var meta      = JSON.parse(document.getElementById('sightings-meta').textContent);
    var catColor  = meta.catColor;
    var catLabel  = meta.catLabel;

    /* ── Comune boundary ────────────────────────── */
    var comuneGeoJSON = {
      type:'Feature', properties:{},
      geometry:{ type:'Polygon', coordinates:[[
        [10.063,44.936],[10.072,44.946],[10.085,44.954],[10.100,44.959],
        [10.118,44.961],[10.137,44.959],[10.155,44.954],[10.170,44.946],
        [10.180,44.934],[10.182,44.920],[10.178,44.907],[10.168,44.897],
        [10.152,44.891],[10.132,44.888],[10.110,44.890],[10.090,44.895],
        [10.073,44.906],[10.063,44.920],[10.063,44.936]
      ]]}
    };

    /* ── Map init ───────────────────────────────── */
    window.addEventListener('load', function () {
      var map = L.map('fauna-map', { scrollWheelZoom:true, zoomControl:true, attributionControl:false });
      L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', { maxZoom:19 }).addTo(map);

      L.geoJSON(comuneGeoJSON, {
        style:{ fillColor:'#D8A14A', fillOpacity:.10, color:'#D8A14A', weight:2, opacity:.55, dashArray:'5,4' }
      }).addTo(map);

      var allCoords = sightings.map(function(s){ return s.coords; });
      if (allCoords.length > 1) map.fitBounds(L.latLngBounds(allCoords).pad(0.18));
      else map.setView([44.935,10.120],13);

      /* icons */
      function makeIcon(color, hasMedia) {
        return L.divIcon({
          html: '<div style="width:16px;height:16px;border-radius:50%;background:'+color
              + ';border:2.5px solid white;box-shadow:0 1px 6px rgba(0,0,0,.45)'
              + (hasMedia?';outline:2px solid '+color+';outline-offset:2px':'')+'"></div>',
          iconSize:[16,16], iconAnchor:[8,8], popupAnchor:[0,-12], className:'',
        });
      }

      /* layers & markers */
      var layers  = {};
      var markers = {};

      sightings.forEach(function(s) {
        var color    = catColor[s.category]||'#6b7280';
        var hasMedia = s.photos.length>0||s.videos.length>0||s.hasVideoFlag;
        if (!layers[s.category]) layers[s.category]=L.layerGroup().addTo(map);
        var marker = L.marker(s.coords,{icon:makeIcon(color,hasMedia),title:s.title});
        marker.on('click', function(){ activateCard(s.id,false); });
        layers[s.category].addLayer(marker);
        markers[s.id]=marker;
      });

      /* activate card */
      function activateCard(id, openSl) {
        document.querySelectorAll('.ani-card').forEach(function(c){
          c.classList.toggle('attiva', c.dataset.id===id);
        });
        var el = document.querySelector('.ani-card[data-id="'+id+'"]');
        if (el) el.scrollIntoView({behavior:'smooth',block:'nearest'});

        var s = sightings.find(function(x){return x.id===id;});
        if (s && markers[id]) {
          var color = catColor[s.category]||'#6b7280';
          var thumbHtml = s.thumb
            ? '<img src="'+s.thumb+'" style="width:100%;height:80px;object-fit:cover;display:block;margin-bottom:0" />'
            : '';
          markers[id].unbindPopup();
          markers[id].bindPopup(
            '<div style="padding:0;min-width:170px;overflow:hidden">'
            + thumbHtml
            + '<div style="background:'+color+';color:rgba(255,255,255,.92);font-size:.57rem;font-family:monospace;'
            + 'text-transform:uppercase;letter-spacing:.2em;padding:.32rem .8rem">'+(catLabel[s.category]||s.category)+'</div>'
            + '<div style="padding:.5rem .8rem .65rem">'
            + '<strong style="font-size:.92rem;color:#1a2020">'+s.title+'</strong>'
            + '</div></div>',
            {maxWidth:220}
          ).openPopup();
        }
        if (openSl) openSlideshow(id);
      }

      /* card click */
      var mapFitted    = window.innerWidth > 820; /* desktop: già fittato all'init */
      var setMobileTab = null;
      document.querySelectorAll('.ani-card').forEach(function(card){
        card.addEventListener('click', function(e){
          if (!e.target.closest('.ani-action-btn')) {
            activateCard(card.dataset.id, false);
            if (window.innerWidth <= 820 && setMobileTab) setMobileTab('mappa');
          }
        });
        card.addEventListener('keydown', function(e){
          if (e.key==='Enter'||e.key===' ') { e.preventDefault(); activateCard(card.dataset.id, false); }
        });
      });

      /* ── Inline media panel ─────────────────── */
      var fmPanel  = document.getElementById('fauna-media');
      var fmMap    = document.getElementById('fauna-map');
      var fmLegend = document.getElementById('fauna-legenda');
      var fmStage  = document.getElementById('fmedia-stage');
      var fmNav    = document.getElementById('fmedia-nav');
      var fmDots   = document.getElementById('fmedia-dots');
      var fmPrev   = document.getElementById('fmedia-prev');
      var fmNext   = document.getElementById('fmedia-next');
      var fmTitle  = document.getElementById('fmedia-title');
      var fmBack   = document.getElementById('fmedia-back');
      var fmItems = [], fmIdx = 0;
      var fmReturnTo       = 'mappa';
      var activeColTab     = 'mappa';
      var fmBackLabel      = document.getElementById('fmedia-back-label');
      var fmTabPanel       = document.getElementById('fauna-media-tab');
      var setDesktopColTab = null;

      function fmShow(idx) {
        fmIdx = (idx + fmItems.length) % fmItems.length;
        var item = fmItems[fmIdx];
        var oldV = fmStage.querySelector('video');
        if (oldV) { oldV.pause(); oldV.src = ''; }
        fmStage.innerHTML = item.type === 'photo'
          ? '<img class="fmedia-img" src="'+item.src+'" alt="'+item.label+'" />'
          : '<video class="fmedia-video" src="'+item.src+'" controls autoplay></video>';
        var multi = fmItems.length > 1;
        fmNav.hidden  = !multi;
        fmPrev.hidden = !multi;
        fmNext.hidden = !multi;
        if (multi) {
          fmDots.innerHTML = fmItems.map(function(_,i){
            return '<span class="fmedia-dot'+(i===fmIdx?' attivo':'')
              +'" data-i="'+i+'"></span>';
          }).join('');
          fmDots.querySelectorAll('.fmedia-dot').forEach(function(d){
            d.addEventListener('click', function(){ fmShow(+d.dataset.i); });
          });
        }
      }

      function openMediaPanel(id, startType, returnTo) {
        var s = sightings.find(function(x){ return x.id===id; });
        if (!s) return;
        fmItems = [];
        var photoSrcs = s.photos.length > 0 ? s.photos : (s.thumb ? [s.thumb] : []);
        photoSrcs.forEach(function(src){ fmItems.push({type:'photo',src:src,label:s.title}); });
        s.videos.forEach(function(src){ fmItems.push({type:'video',src:src,label:s.title}); });
        if (!fmItems.length) return;
        fmReturnTo = returnTo || (window.innerWidth > 820 ? activeColTab : 'mappa');
        if (fmBackLabel) fmBackLabel.textContent = fmReturnTo === 'media' ? 'Media' : 'Mappa';
        fmTitle.textContent = s.title;
        var startIdx = (startType==='video' && s.photos.length > 0) ? s.photos.length : 0;
        fmShow(startIdx);
        fmMap.hidden    = true;
        fmLegend.hidden = true;
        if (fmTabPanel) fmTabPanel.style.display = 'none';
        fmPanel.hidden  = false;
        activateCard(id, false);
      }

      function closeMediaPanel() {
        var oldV = fmStage.querySelector('video');
        if (oldV) { oldV.pause(); oldV.src = ''; }
        fmPanel.hidden = true;
        fmItems = [];
        var showMap;
        if (window.innerWidth > 820) {
          showMap = activeColTab === 'mappa';
          fmMap.hidden    = !showMap;
          fmLegend.hidden = !showMap;
          if (fmTabPanel) fmTabPanel.style.display = activeColTab === 'media' ? 'flex' : 'none';
        } else {
          showMap = true;
          fmMap.hidden    = false;
          fmLegend.hidden = false;
        }
        if (showMap) {
          setTimeout(function(){ map.invalidateSize(); }, 60);
          setTimeout(function(){ map.invalidateSize(); }, 320);
        }
      }

      fmPrev.addEventListener('click', function(){ fmShow(fmIdx-1); });
      fmNext.addEventListener('click', function(){ fmShow(fmIdx+1); });
      fmBack.addEventListener('click', function(){
        closeMediaPanel();
        if (fmReturnTo === 'media') {
          if (window.innerWidth <= 820 && setMobileTab) setMobileTab('media');
          else if (setDesktopColTab) setDesktopColTab('media');
        }
      });
      document.addEventListener('keydown', function(e){
        if (fmPanel.hidden) return;
        if (e.key==='Escape')     closeMediaPanel();
        if (e.key==='ArrowLeft')  fmShow(fmIdx-1);
        if (e.key==='ArrowRight') fmShow(fmIdx+1);
      });

      document.querySelectorAll('.ani-photo-btn').forEach(function(btn){
        btn.addEventListener('click', function(e){
          e.stopPropagation();
          if (window.innerWidth <= 820 && setMobileTab) setMobileTab('mappa');
          openMediaPanel(btn.dataset.id, 'photo', activeColTab);
        });
      });
      document.querySelectorAll('.ani-video-btn').forEach(function(btn){
        btn.addEventListener('click', function(e){
          e.stopPropagation();
          if (window.innerWidth <= 820 && setMobileTab) setMobileTab('mappa');
          openMediaPanel(btn.dataset.id, 'video', activeColTab);
        });
      });

      /* filter */
      var btns = document.querySelectorAll('.filtri-btn');
      function applyFilter(filter) {
        Object.keys(layers).forEach(function(cat){
          var show = filter==='all'||cat===filter;
          if (show && !map.hasLayer(layers[cat])) map.addLayer(layers[cat]);
          if (!show && map.hasLayer(layers[cat]))  map.removeLayer(layers[cat]);
        });
        document.querySelectorAll('.ani-card').forEach(function(c){
          c.hidden = !(filter==='all'||c.dataset.category===filter);
        });
        btns.forEach(function(b){ b.classList.toggle('attivo', b.dataset.filter===filter); });
        document.querySelectorAll('.legenda-item').forEach(function(el){
          el.style.opacity = (filter==='all'||el.dataset.cat===filter)?'1':'.3';
        });
      }
      btns.forEach(function(btn){
        btn.addEventListener('click', function(){ applyFilter(btn.dataset.filter); });
      });

      /* ── Mobile tabs ────────────────────────────── */
      var tabLista = document.getElementById('tab-lista');
      var tabMappa = document.getElementById('tab-mappa');
      var tabMedia = document.getElementById('tab-media');
      var layoutEl = document.querySelector('.fauna-layout');
      if (tabLista && tabMappa) {
        setMobileTab = function(t) {
          layoutEl.classList.toggle('tab-mappa', t==='mappa');
          layoutEl.classList.toggle('tab-media', t==='media');
          tabLista.classList.toggle('attivo', t==='lista');
          tabMappa.classList.toggle('attivo', t==='mappa');
          if (tabMedia) tabMedia.classList.toggle('attivo', t==='media');
          if (t==='mappa') {
            setTimeout(function(){
              map.invalidateSize();
              if (!mapFitted) {
                mapFitted = true;
                if (allCoords.length > 1) map.fitBounds(L.latLngBounds(allCoords).pad(0.18));
                else map.setView([44.935,10.120],13);
              }
            }, 150);
            setTimeout(function(){ map.invalidateSize(); }, 450);
          }
        };
        var tabsEl = document.getElementById('fauna-tabs');
        function scrollToTabs() {
          if (tabsEl && window.innerWidth <= 820) {
            tabsEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        }
        tabLista.addEventListener('click', function(){ setMobileTab('lista'); scrollToTabs(); });
        tabMappa.addEventListener('click',  function(){ setMobileTab('mappa'); scrollToTabs(); });
        if (tabMedia) tabMedia.addEventListener('click', function(){ setMobileTab('media'); scrollToTabs(); });
      }

      /* ── Desktop column tabs ────────────────────────── */
      var colTabMappa = document.getElementById('col-tab-mappa');
      var colTabMedia = document.getElementById('col-tab-media');
      if (colTabMappa && colTabMedia) {
        setDesktopColTab = function(t) {
          if (window.innerWidth <= 820) return;
          activeColTab = t;
          colTabMappa.classList.toggle('attivo', t === 'mappa');
          colTabMedia.classList.toggle('attivo', t === 'media');
          fmMap.hidden    = t !== 'mappa';
          fmLegend.hidden = t !== 'mappa';
          if (fmTabPanel) {
            fmTabPanel.style.display       = t === 'media' ? 'flex' : 'none';
            fmTabPanel.style.flexDirection = 'column';
            fmTabPanel.style.flex          = '1';
            fmTabPanel.style.overflowY     = 'auto';
            fmTabPanel.style.minHeight     = '0';
          }
        };
        colTabMappa.addEventListener('click', function(){ setDesktopColTab('mappa'); });
        colTabMedia.addEventListener('click',  function(){ setDesktopColTab('media'); });
      }

      /* fmtab-item click */
      document.querySelectorAll('.fmtab-item').forEach(function(btn){
        btn.addEventListener('click', function(){
          if (window.innerWidth <= 820) {
            if (setMobileTab) setMobileTab('mappa');
            openMediaPanel(btn.dataset.id, 'photo', 'media');
          } else {
            openMediaPanel(btn.dataset.id, 'photo', 'media');
          }
        });
      });

    }); /* end load */

    /* ── Slideshow ──────────────────────────────── */
    var overlay  = document.getElementById('sl-overlay');
    var stage    = document.getElementById('sl-stage');
    var dotsEl   = document.getElementById('sl-dots');
    var prevBtn  = document.getElementById('sl-prev');
    var nextBtn  = document.getElementById('sl-next');
    var closeBtn = document.getElementById('sl-close');
    var slSlides = [];
    var slIdx    = 0;

    function buildSlides(s) {
      var slides = [{ type:'info', s:s }];
      s.photos.forEach(function(src){ slides.push({type:'photo',src:src,title:s.title}); });
      s.videos.forEach(function(src){ slides.push({type:'video',src:src,title:s.title}); });
      if (s.hasVideoFlag && s.videos.length===0) slides.push({type:'video-pending',s:s});
      return slides;
    }

    function renderSlide(slide) {
      var s     = slide.s || {};
      var color = catColor[s.category||'altro']||'#6b7280';
      var label = catLabel[s.category||'altro']||'';

      if (slide.type==='info') {
        var thumbHtml = s.thumb
          ? '<div class="sl-thumb-wrap"><img src="'+s.thumb+'" alt="'+s.title+'" class="sl-thumb" /></div>'
          : '';
        return '<div class="sl-info-card" style="--sl-col:'+color+'">'
          + thumbHtml
          + '<div class="sl-info-band">'+label+'</div>'
          + '<div class="sl-info-body">'
          + '<h2 class="sl-info-title">'+s.title+'</h2>'
          + '<p class="sl-info-date">'+s.date+'</p>'
          + (s.notes?'<p class="sl-info-notes">'+s.notes+'</p>':'')
          + '</div></div>';
      }
      if (slide.type==='photo')
        return '<img class="sl-img" src="'+slide.src+'" alt="'+slide.title+'" />';
      if (slide.type==='video')
        return '<video class="sl-video" src="'+slide.src+'" controls autoplay></video>';
      if (slide.type==='video-pending')
        return '<div class="sl-pending" style="--sl-col:'+color+'">'
          + '<svg width="52" height="52" viewBox="0 0 52 52" fill="none">'
          + '<circle cx="26" cy="26" r="24" stroke="'+color+'" stroke-width="2" fill="none" opacity=".3"/>'
          + '<polygon points="20,14 42,26 20,38" fill="'+color+'" opacity=".7"/></svg>'
          + '<p class="sl-pending-lbl">Video disponibile</p>'
          + '<p class="sl-pending-name">'+s.title+'</p></div>';
      return '';
    }

    function showSlide(idx) {
      slIdx = (idx+slSlides.length)%slSlides.length;
      stage.innerHTML = renderSlide(slSlides[slIdx]);
      prevBtn.hidden  = slSlides.length<=1;
      nextBtn.hidden  = slSlides.length<=1;
      dotsEl.innerHTML = slSlides.length>1
        ? slSlides.map(function(_,i){
            return '<span class="sl-dot'+(i===slIdx?' attivo':'')
              +'" data-i="'+i+'"></span>';
          }).join('') : '';
      dotsEl.querySelectorAll('.sl-dot').forEach(function(d){
        d.addEventListener('click', function(){ showSlide(+d.dataset.i); });
      });
    }

    function openSlideshow(id) {
      var s = sightings.find(function(x){return x.id===id;});
      if (!s) return;
      slSlides = buildSlides(s);
      showSlide(0);
      overlay.hidden = false;
      document.body.style.overflow='hidden';
    }
    function closeSl() {
      overlay.hidden=true; stage.innerHTML=''; document.body.style.overflow='';
      var v=stage.querySelector('video'); if(v){v.pause();v.src='';}
    }

    prevBtn.addEventListener('click',  function(){ showSlide(slIdx-1); });
    nextBtn.addEventListener('click',  function(){ showSlide(slIdx+1); });
    closeBtn.addEventListener('click', closeSl);
    overlay.addEventListener('click',  function(e){ if(e.target===overlay) closeSl(); });
    document.addEventListener('keydown', function(e){
      if(overlay.hidden) return;
      if(e.key==='Escape')     closeSl();
      if(e.key==='ArrowLeft')  showSlide(slIdx-1);
      if(e.key==='ArrowRight') showSlide(slIdx+1);
    });
  })();
  </script>
</Base>

<style>
  /* ── Layout ───────────────────────────────────── */
  .fauna-layout {
    display: grid;
    grid-template-columns: 40% 60%;
    height: clamp(560px, 78vh, 820px);
    border-top: 1px solid rgba(74,86,104,.1);
  }

  /* ── Sidebar ──────────────────────────────────── */
