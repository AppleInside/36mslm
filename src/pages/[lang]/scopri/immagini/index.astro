---
import { readdirSync } from 'node:fs';
import { resolve } from 'node:path';
import Base from '../../../../layouts/Base.astro';
import PageHeader from '../../../../components/PageHeader.astro';
import type { Lang } from '../../../../i18n/ui';

export function getStaticPaths() {
  return [{ params: { lang: 'it' } }, { params: { lang: 'en' } }];
}

const lang = Astro.params.lang as Lang;

const RECIPES = /^(Bargnolino|Chiacchiere|Crafen|Dolce-di|Liquore|Nocino|Prugnolino|Salsa|Spumini|Straccadenti|Torta|Tortell|Zucchini|Abbonamento)/i;
const SYSTEM  = /^(logo|pexels|cropped)/i;

function caption(filename: string): string {
  return filename
    .replace(/\.jpg$/i, '')
    .replace(/[-_]+/g, ' ')
    .replace(/\bFILEminimizer\b/gi, '')
    .replace(/\s+/g, ' ')
    .trim()
    .replace(/^\w/, c => c.toUpperCase());
}

const files = readdirSync(resolve('public/media/storico'))
  .filter(f => /\.jpg$/i.test(f) && !RECIPES.test(f) && !SYSTEM.test(f))
  .sort();

const photos = files.map(f => ({
  src: `/media/storico/${f}`,
  caption: caption(f),
}));
---

<Base title={lang === 'it' ? 'Immagini e ricordi' : 'Images & memories'}>
  <PageHeader
    eyebrow={lang === 'it' ? '— Memoria —' : '— Memory —'}
    bg="/media/storico/leggevano-il-giornale-in-piazza.jpg"
  >
    {lang === 'it' ? <>Immagini <em>e ricordi</em></> : <>Images <em>and memories</em></>}
  </PageHeader>

  <p class="intro">
    {lang === 'it'
      ? `${photos.length} fotografie d'archivio di Polesine Parmense. Un paese, le sue facce, i suoi decenni.`
      : `${photos.length} archive photographs of Polesine Parmense. A village, its faces, its decades.`}
  </p>

  <div class="gallery">
    {photos.map(p => (
      <figure class="gf" data-src={p.src} data-caption={p.caption}>
        <img src={p.src} alt={p.caption} loading="lazy" draggable="false" />
        <figcaption>{p.caption}</figcaption>
      </figure>
    ))}
  </div>

  <div id="lb" aria-modal="true" role="dialog" aria-label={lang === 'it' ? 'Immagine ingrandita' : 'Enlarged image'}>
    <button id="lb-close" aria-label="Chiudi">✕</button>
    <figure id="lb-fig">
      <div class="lb-wrap">
        <img id="lb-img" src="" alt="" draggable="false" />
        <div class="lb-shield"></div>
      </div>
      <figcaption id="lb-cap"></figcaption>
    </figure>
  </div>
</Base>

<style>
  .intro {
    padding: .9rem 1.25rem .1rem;
    font-family: theme('fontFamily.mono');
    font-size: .75rem;
    text-transform: uppercase;
    letter-spacing: .12em;
    color: theme('colors.ink-soft');
  }
  @media (min-width: 1050px) { .intro { padding: 1rem 4rem .1rem; } }

  .gallery {
    columns: 2;
    column-gap: .6rem;
    padding: 1rem 1.25rem 5rem;
  }
  @media (min-width: 600px)  { .gallery { columns: 3; } }
  @media (min-width: 900px)  { .gallery { columns: 4; column-gap: .75rem; } }
  @media (min-width: 1050px) { .gallery { columns: 5; padding: 1.25rem 4rem 6rem; } }

  .gf {
    break-inside: avoid;
    margin: 0 0 .6rem;
    position: relative;
    overflow: hidden;
    border-radius: 8px;
    background: theme('colors.paper-2');
    cursor: zoom-in;
  }
  .gf img {
    width: 100%;
    display: block;
    transition: transform .5s cubic-bezier(.2,.7,.2,1), filter .4s ease;
    filter: sepia(18%) saturate(0.85);
  }
  .gf:hover img {
    transform: scale(1.04);
    filter: sepia(0%) saturate(1);
  }
  figcaption {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    background: linear-gradient(transparent, rgba(15,22,28,0.78));
    color: rgba(232,244,248,0.92);
    font-size: .68rem;
    font-family: theme('fontFamily.mono');
    letter-spacing: .06em;
    padding: 1.5rem .6rem .5rem;
    opacity: 0;
    transform: translateY(4px);
    transition: opacity .3s ease, transform .3s ease;
  }
  .gf:hover figcaption {
    opacity: 1;
    transform: translateY(0);
  }
  /* transparent overlay intercepts right-click on the img */
  .gf::after {
    content: '';
    position: absolute; inset: 0;
    z-index: 2;
  }

  /* ── Lightbox ─────────────────────────────────────── */
  #lb {
    display: none;
    position: fixed; inset: 0; z-index: 200;
    background: rgba(8, 14, 20, 0.92);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    align-items: center; justify-content: center;
    padding: 1.5rem;
    cursor: zoom-out;
  }
  #lb.open { display: flex; }

  #lb-fig {
    margin: 0;
    display: flex; flex-direction: column; align-items: center;
    max-width: min(90vw, 1100px);
    animation: lb-in .25s cubic-bezier(.2,.7,.2,1) both;
    cursor: default;
  }
  @keyframes lb-in {
    from { opacity: 0; transform: scale(.94); }
    to   { opacity: 1; transform: scale(1); }
  }

  .lb-wrap {
    position: relative;
    line-height: 0;
  }
  #lb-img {
    display: block;
    max-height: 80vh; max-width: 100%;
    object-fit: contain;
    border-radius: 6px;
    box-shadow: 0 24px 80px rgba(0,0,0,.6);
  }
  .lb-shield {
    position: absolute; inset: 0;
    z-index: 1;
    cursor: default;
  }

  #lb-fig figcaption {
    position: static;
    background: none;
    opacity: 1; transform: none;
    margin-top: .75rem;
    color: rgba(232,244,248,.65);
    font-size: .75rem;
    font-family: theme('fontFamily.mono');
    letter-spacing: .1em;
    text-align: center;
    padding: 0;
    max-width: 60ch;
  }

  #lb-close {
    position: fixed; top: 1.25rem; right: 1.5rem;
    background: rgba(255,255,255,.12);
    border: 1px solid rgba(255,255,255,.22);
    color: rgba(232,244,248,.85);
    width: 40px; height: 40px; border-radius: 50%;
    font-size: 1rem; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: background .2s;
    z-index: 1;
  }
  #lb-close:hover { background: rgba(255,255,255,.24); }
</style>

<script>
  const lb    = document.getElementById('lb')!;
  const lbImg = document.getElementById('lb-img') as HTMLImageElement;
  const lbCap = document.getElementById('lb-cap')!;

  document.querySelectorAll<HTMLElement>('.gf').forEach(fig => {
    fig.addEventListener('click', () => {
      const src     = fig.dataset.src ?? '';
      const caption = fig.dataset.caption ?? '';
      lbImg.src = src;
      lbImg.alt = caption;
      lbCap.textContent = caption;
      lb.classList.add('open');
      document.body.style.overflow = 'hidden';
    });
  });

  function close() {
    lb.classList.remove('open');
    document.body.style.overflow = '';
    lbImg.src = '';
  }

  lb.addEventListener('click', e => { if (e.target === lb) close(); });
  document.getElementById('lb-close')!.addEventListener('click', close);
  document.addEventListener('keydown', e => { if (e.key === 'Escape') close(); });

  // Block right-click "Save image as" on gallery and lightbox
  document.querySelector('.gallery')!.addEventListener('contextmenu', e => e.preventDefault());
  lb.addEventListener('contextmenu', e => e.preventDefault());
</script>
