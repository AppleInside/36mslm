---
export const prerender = false;

import Base from '../../../../layouts/Base.astro';
import PageHeader from '../../../../components/PageHeader.astro';
import { getItineraries } from '../../../../server/db';
import type { Lang } from '../../../../i18n/ui';

const lang = Astro.params.lang as Lang;
const itineraries = await getItineraries(lang);

const counts = {
  all:           itineraries.length,
  naturalistico: itineraries.filter(i => i.category === 'naturalistico').length,
  storico:       itineraries.filter(i => i.category === 'storico').length,
  sportivo:      itineraries.filter(i => i.category === 'sportivo').length,
};

const catLabel: Record<string, string> = {
  naturalistico: lang === 'it' ? 'Naturalistico' : 'Nature',
  storico:       lang === 'it' ? 'Storico'       : 'Historical',
  sportivo:      lang === 'it' ? 'Sportivo'      : 'Sport',
};

const diffLabel: Record<string, string> = {
  facile:      lang === 'it' ? 'Facile'      : 'Easy',
  medio:       lang === 'it' ? 'Medio'       : 'Moderate',
  impegnativo: lang === 'it' ? 'Impegnativo' : 'Challenging',
};

const accent: Record<string, string> = {
  naturalistico: '#2d6a4f',
  storico:       '#8b4e14',
  sportivo:      '#1e4e8a',
};

function fmtDuration(it: typeof itineraries[number]): string {
  if (it.duration_label) return it.duration_label;
  const h = Math.floor((it.duration_min ?? 0) / 60);
  const m = (it.duration_min ?? 0) % 60;
  return h > 0 ? `${h}h${m > 0 ? ' ' + m + 'min' : ''}` : `${m}min`;
}

const itinerariesJson = Object.fromEntries(
  itineraries.map(it => [
    it.slug,
    {
      title:       it.title,
      category:    it.category,
      description: it.description ?? null,
      distance_km: it.distance_km,
      duration:    fmtDuration(it),
      difficulty:  it.difficulty,
      terrain:     it.terrain ?? null,
      coords:      it.coords ?? [],
      bbox:        it.bbox ?? null,
      color:       accent[it.category],
      mode:        it.mode ?? ['piedi'],
    },
  ])
);
---

<Base title={lang === 'it' ? 'Itinerari' : 'Itineraries'}>
  <PageHeader
    eyebrow={lang === 'it' ? '— Scopri il Po —' : '— Discover the Po —'}
    bg="/media/storico/Guareschi-sul-Po.jpg"
  >
    {lang === 'it' ? <>Itinerari del <em>fiume</em></> : <>River <em>itineraries</em></>}
  </PageHeader>

  <!-- ── Filter tabs ─────────────────────────────── -->
  <nav class="filtri" aria-label={lang === 'it' ? 'Filtra per categoria' : 'Filter by category'}>
    <div class="filtri-inner">
      <span class="filtri-label" aria-hidden="true">{lang === 'it' ? 'Filtra' : 'Filter'}</span>
      <button class="filtri-btn attivo" data-filter="all">
        <span class="filtri-dot" style="background:theme('colors.ink-soft')"></span>
        {lang === 'it' ? 'Tutti' : 'All'} <span class="cnt">{counts.all}</span>
      </button>
      {counts.naturalistico > 0 && (
        <button class="filtri-btn" data-filter="naturalistico" data-color="#2d6a4f">
          <span class="filtri-dot" style="background:#2d6a4f"></span>
          {lang === 'it' ? 'Naturalistici' : 'Nature'} <span class="cnt">{counts.naturalistico}</span>
        </button>
      )}
      {counts.storico > 0 && (
        <button class="filtri-btn" data-filter="storico" data-color="#8b4e14">
          <span class="filtri-dot" style="background:#8b4e14"></span>
          {lang === 'it' ? 'Storici' : 'Historical'} <span class="cnt">{counts.storico}</span>
        </button>
      )}
      {counts.sportivo > 0 && (
        <button class="filtri-btn" data-filter="sportivo" data-color="#1e4e8a">
          <span class="filtri-dot" style="background:#1e4e8a"></span>
          {lang === 'it' ? 'Sportivi' : 'Sport'} <span class="cnt">{counts.sportivo}</span>
        </button>
      )}
    </div>
  </nav>

  <!-- ── Cards ──────────────────────────────────── -->
  <section class="lista" aria-label="Itinerari">
    {itineraries.map((it, i) => {
      const cat   = it.category;
      const mapId = 'map-' + it.slug;
      const acc   = accent[cat];
      return (
        <div
          class="scheda-wrap"
          data-category={cat}
          data-order={i % 2 === 0 ? 'odd' : 'even'}
          data-slug={it.slug}
        >
          <article class="scheda" style={`--accent:${acc}`}>

            <!-- Coloured profile band -->
            <div class="profilo">
              <span class="profilo-icona" aria-hidden="true">
                {cat === 'naturalistico' && (
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <path d="M8 13C5.5 11 2.5 8.5 2.5 5.5a5.5 5.5 0 0 1 11 0C13.5 8.5 10.5 11 8 13z" fill="rgba(255,255,255,.85)"/>
                    <line x1="8" y1="13" x2="8" y2="7" stroke="rgba(255,255,255,.45)" stroke-width="1.1"/>
                  </svg>
                )}
                {cat === 'storico' && (
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <rect x="3" y="6" width="10" height="8" rx=".5" stroke="rgba(255,255,255,.85)" stroke-width="1.2" fill="none"/>
                    <path d="M3 6L8 3l5 3" stroke="rgba(255,255,255,.85)" stroke-width="1.2" stroke-linejoin="round" fill="none"/>
                    <rect x="6" y="9" width="4" height="5" fill="rgba(255,255,255,.8)"/>
                  </svg>
                )}
                {cat === 'sportivo' && (
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <circle cx="4.5" cy="11" r="2.5" stroke="rgba(255,255,255,.85)" stroke-width="1.2" fill="none"/>
                    <circle cx="11.5" cy="11" r="2.5" stroke="rgba(255,255,255,.85)" stroke-width="1.2" fill="none"/>
                    <path d="M4.5 11L7 6l2 2 2-4" stroke="rgba(255,255,255,.85)" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                  </svg>
                )}
              </span>
              <span class="profilo-label">{catLabel[cat]}</span>
            </div>

            <!-- Card body: text + map -->
            <div class="scheda-body">
              <div class="scheda-testo">
                <div class="titolo-row">
                  <h2 class="scheda-titolo">{it.title}</h2>
                  <div class="mode-icons">
                    {it.mode?.includes('piedi') && (
                      <span class="mode-icon" title={lang === 'it' ? 'A piedi' : 'On foot'}>
                        <svg width="13" height="16" viewBox="0 0 13 18" fill="none" aria-hidden="true">
                          <circle cx="8.5" cy="2" r="1.8" fill="currentColor"/>
                          <path d="M8.5 3.8 L7 8.5 M7 8.5 L4.5 12.5 M7 8.5 L10 11.5 M10 11.5 L8.5 15.5 M4.5 12.5 L4 16 M8 6 L11 8 M7.5 6.5 L5 8.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </span>
                    )}
                    {it.mode?.includes('bici') && (
                      <span class="mode-icon" title={lang === 'it' ? 'In bicicletta' : 'By bike'}>
                        <svg width="16" height="12" viewBox="0 0 20 14" fill="none" aria-hidden="true">
                          <circle cx="4.5" cy="10" r="3.5" stroke="currentColor" stroke-width="1.5"/>
                          <circle cx="15.5" cy="10" r="3.5" stroke="currentColor" stroke-width="1.5"/>
                          <path d="M4.5 10 L9 3 L13.5 3 M15.5 10 L11 5.5 L9 3 M11 5.5 L13.5 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                          <path d="M13.5 3 L15.5 1.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                        </svg>
                      </span>
                    )}
                  </div>
                </div>

                <div class="pills">
                  <span class="pill">
                    <svg width="11" height="11" viewBox="0 0 11 11" fill="none" aria-hidden="true">
                      <path d="M1.5 5.5h8M8 2.5l3 3-3 3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    {it.distance_km}&thinsp;km
                  </span>
                  <span class="pill">
                    <svg width="11" height="11" viewBox="0 0 11 11" fill="none" aria-hidden="true">
                      <circle cx="5.5" cy="5.5" r="4" stroke="currentColor" stroke-width="1.1"/>
                      <path d="M5.5 3v2.5l1.5 1.5" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/>
                    </svg>
                    {fmtDuration(it)}
                  </span>
                  <span class={`pill pill--diff pill--${it.difficulty}`}>
                    {diffLabel[it.difficulty]}
                  </span>
                  {it.terrain && (
                    <span class="pill pill--terrain">{it.terrain}</span>
                  )}
                </div>

                {it.description && (
                  <p class="scheda-desc">{it.description}</p>
                )}

                <button class="scheda-open-btn" aria-label={lang === 'it' ? 'Apri dettagli' : 'Open details'}>
                  {lang === 'it' ? 'Vedi itinerario' : 'View itinerary'}
                  <span aria-hidden="true">→</span>
                </button>
              </div>

              <div class="scheda-mappa-area">
                <div
                  class="scheda-mappa"
                  id={mapId}
                  data-coords={JSON.stringify(it.coords ?? [])}
                  data-bbox={it.bbox ? JSON.stringify(it.bbox) : ''}
                  data-color={acc}
                  aria-label={`Mappa: ${it.title}`}
                ></div>
              </div>
            </div>

          </article>
        </div>
      );
    })}
  </section>

  <!-- ── Leaflet ─────────────────────────────────── -->
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <script is:inline>
    window.addEventListener('load', function () {
      document.querySelectorAll('.scheda-mappa').forEach(function (el) {
        var coords = JSON.parse(el.dataset.coords || '[]');
        var bbox   = el.dataset.bbox ? JSON.parse(el.dataset.bbox) : null;
        var color  = el.dataset.color || '#4a6670';
        if (!coords.length) return;

        var map = L.map(el, {
          zoomControl: false,
          scrollWheelZoom: false,
          attributionControl: false,
          dragging: false,
        });

        L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
          maxZoom: 18,
        }).addTo(map);

        var line = L.polyline(coords, { color: color, weight: 4, opacity: 0.9 }).addTo(map);

        var dot = L.divIcon({
          html: '<div style="width:9px;height:9px;background:' + color + ';border:2px solid white;border-radius:50%;box-shadow:0 1px 4px rgba(0,0,0,.4)"></div>',
          iconSize: [9, 9], iconAnchor: [4, 4], className: '',
        });
        L.marker(coords[0], { icon: dot }).addTo(map);

        if (bbox) {
          map.fitBounds([[bbox[0], bbox[1]], [bbox[2], bbox[3]]]);
        } else {
          map.fitBounds(line.getBounds().pad(0.18));
        }
      });
    });

    // Filter + reorder
    document.addEventListener('DOMContentLoaded', function () {
      var btns  = document.querySelectorAll('.filtri-btn');
      var wraps = document.querySelectorAll('.scheda-wrap');
      var nav   = document.querySelector('.filtri');

      function applyFilter(filter, accentCol) {
        var idx = 0;
        wraps.forEach(function (w) {
          var match = filter === 'all' || w.dataset.category === filter;
          w.style.display = match ? '' : 'none';
          if (match) { w.dataset.order = idx % 2 === 0 ? 'odd' : 'even'; idx++; }
        });
        btns.forEach(function (b) {
          b.classList.toggle('attivo', b.dataset.filter === filter);
        });
        if (nav && accentCol) {
          nav.style.setProperty('--active-color', accentCol);
        }
      }

      if (nav) nav.style.setProperty('--active-color', '#4a6670');

      btns.forEach(function (btn) {
        btn.addEventListener('click', function () {
          applyFilter(btn.dataset.filter, btn.dataset.color || '#4a6670');
        });
      });
    });
  </script>

  <!-- ── Modal JS (mobile) ──────────────────────── -->
  <script is:inline define:vars={{ itinerariesJson, lang }}>
    (function () {
      var MOBILE_BP = 700;
      function isMobile() { return window.innerWidth < MOBILE_BP; }

      var catLabels = {
        naturalistico: lang === 'it' ? 'Naturalistico' : 'Nature',
        storico:       lang === 'it' ? 'Storico'       : 'Historical',
        sportivo:      lang === 'it' ? 'Sportivo'      : 'Sport',
      };
      var diffLabels = {
        facile:      lang === 'it' ? 'Facile'      : 'Easy',
        medio:       lang === 'it' ? 'Medio'       : 'Moderate',
        impegnativo: lang === 'it' ? 'Impegnativo' : 'Challenging',
      };

      var overlay  = document.getElementById('itModal');
      var band     = document.getElementById('itBand');
      var catEl    = document.getElementById('itCat');
      var titleEl  = document.getElementById('itTitle');
      var pillsEl  = document.getElementById('itPills');
      var descEl   = document.getElementById('itDesc');
      var mapEl    = document.getElementById('itMap');
      var linksEl  = document.getElementById('itLinks');
      var closeBtn = document.getElementById('itClose');
      var _map     = null;

      function svgDist() {
        return '<svg width="11" height="11" viewBox="0 0 11 11" fill="none" aria-hidden="true"><path d="M1.5 5.5h8M8 2.5l3 3-3 3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>';
      }
      function svgClock() {
        return '<svg width="11" height="11" viewBox="0 0 11 11" fill="none" aria-hidden="true"><circle cx="5.5" cy="5.5" r="4" stroke="currentColor" stroke-width="1.1"/><path d="M5.5 3v2.5l1.5 1.5" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/></svg>';
      }

      function pillDiffClass(d) {
        if (d === 'facile')      return 'pill--diff pill--facile';
        if (d === 'medio')       return 'pill--diff pill--medio';
        if (d === 'impegnativo') return 'pill--diff pill--impegnativo';
        return '';
      }

      function openModal(data) {
        band.style.background = data.color;
        catEl.textContent     = catLabels[data.category] || data.category;
        titleEl.textContent   = data.title;

        pillsEl.innerHTML =
          '<span class="pill">' + svgDist() + data.distance_km + '&thinsp;km</span>' +
          '<span class="pill">' + svgClock() + data.duration + '</span>' +
          '<span class="pill ' + pillDiffClass(data.difficulty) + '">' + (diffLabels[data.difficulty] || data.difficulty) + '</span>' +
          (data.terrain ? '<span class="pill pill--terrain">' + data.terrain + '</span>' : '');

        descEl.textContent = data.description || '';
        descEl.style.display = data.description ? '' : 'none';

        // map buttons
        var start = data.coords && data.coords[0];
        if (start) {
          var lat = start[0], lng = start[1];
          var appleHref  = 'https://maps.apple.com/?ll=' + lat + ',' + lng + '&q=' + encodeURIComponent(data.title);
          var googleHref = 'https://www.google.com/maps/dir/?api=1&destination=' + lat + ',' + lng;
          linksEl.innerHTML =
            '<a class="it-map-btn it-map-btn--apple" href="' + appleHref + '" target="_blank" rel="noopener">' +
              '<img src="/icons/apple-icon-4.png" width="16" height="16" alt=""> Apple Maps' +
            '</a>' +
            '<a class="it-map-btn it-map-btn--google" href="' + googleHref + '" target="_blank" rel="noopener">' +
              '<img src="/icons/google-logo.png" width="16" height="16" alt=""> Google Maps' +
            '</a>';
        } else {
          linksEl.innerHTML = '';
        }

        overlay.classList.add('open');
        document.body.style.overflow = 'hidden';

        // Leaflet map
        requestAnimationFrame(function () {
          if (_map) { _map.remove(); _map = null; }
          mapEl.innerHTML = '';
          if (!data.coords || !data.coords.length) return;
          _map = L.map(mapEl, {
            zoomControl: false, scrollWheelZoom: false,
            attributionControl: false, dragging: false,
          });
          L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', { maxZoom: 18 }).addTo(_map);
          var line = L.polyline(data.coords, { color: data.color, weight: 4, opacity: 0.9 }).addTo(_map);
          var dot = L.divIcon({
            html: '<div style="width:9px;height:9px;background:' + data.color + ';border:2px solid white;border-radius:50%;box-shadow:0 1px 4px rgba(0,0,0,.4)"></div>',
            iconSize: [9, 9], iconAnchor: [4, 4], className: '',
          });
          L.marker(data.coords[0], { icon: dot }).addTo(_map);
          if (data.bbox) {
            _map.fitBounds([[data.bbox[0], data.bbox[1]], [data.bbox[2], data.bbox[3]]]);
          } else {
            _map.fitBounds(line.getBounds().pad(0.18));
          }
          setTimeout(function () { _map.invalidateSize(); }, 60);
        });
      }

      function closeModal() {
        overlay.classList.remove('open');
        document.body.style.overflow = '';
      }

      // Card click → open modal (mobile only)
      document.querySelectorAll('.scheda-wrap').forEach(function (wrap) {
        wrap.addEventListener('click', function (e) {
          if (!isMobile()) return;
          e.preventDefault();
          var data = itinerariesJson[wrap.dataset.slug];
          if (data) openModal(data);
        });
      });

      closeBtn.addEventListener('click', closeModal);
      overlay.addEventListener('click', function (e) {
        if (e.target === overlay) closeModal();
      });
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') closeModal();
      });
    })();
  </script>
</Base>

<!-- ── Itinerary modal (mobile) ──────────────────── -->
<div class="it-overlay" id="itModal" aria-modal="true" role="dialog">
  <div class="it-box">
    <div class="it-band" id="itBand">
      <span class="it-cat" id="itCat"></span>
      <button class="it-close" id="itClose" aria-label="Chiudi">×</button>
    </div>
    <div class="it-scroll">
      <h2 class="it-title" id="itTitle"></h2>
      <div class="pills it-pills" id="itPills"></div>
      <div class="it-map" id="itMap"></div>
      <p class="it-desc" id="itDesc"></p>
      <div class="it-links" id="itLinks"></div>
    </div>
  </div>
</div>

<style>
  /* ── Modal overlay ────────────────────────────── */
  .it-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(10,18,24,.55);
    z-index: 900;
    align-items: flex-end;
    justify-content: center;
  }
  .it-overlay.open { display: flex; }

  .it-box {
    width: 100%;
    max-height: 92dvh;
    border-radius: 1rem 1rem 0 0;
    background: theme('colors.paper');
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .it-band {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: .7rem 1.25rem;
    flex-shrink: 0;
  }
  .it-cat {
    font-family: theme('fontFamily.mono');
    font-size: .62rem;
    text-transform: uppercase;
    letter-spacing: .28em;
    color: rgba(255,255,255,.9);
    font-weight: 600;
  }
  .it-close {
    background: rgba(255,255,255,.2);
    border: none;
    color: #fff;
    font-size: 1.4rem;
    line-height: 1;
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .it-scroll {
    overflow-y: auto;
    padding: 1.25rem 1.25rem 2rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .it-title {
    font-family: theme('fontFamily.hand');
    font-size: 1.9rem;
    font-weight: 400;
    margin: 0;
    color: theme('colors.ink');
    line-height: 1.15;
  }

  .it-pills { flex-wrap: wrap; }

  .it-map {
    border-radius: 10px;
    overflow: hidden;
    height: 220px;
    box-shadow: 0 1px 8px rgba(0,0,0,.12);
    flex-shrink: 0;
  }

  .it-desc {
    font-size: .94rem;
    line-height: 1.78;
    color: #4a5568;
    margin: 0;
  }

  .it-links {
    display: flex;
    gap: .7rem;
    flex-wrap: wrap;
    margin-top: .25rem;
  }
  :global(.it-map-btn) {
    display: inline-flex;
    align-items: center;
    gap: .45rem;
    padding: .55rem 1rem;
    border-radius: .45rem;
    font-family: theme('fontFamily.mono');
    font-size: .75rem;
    text-decoration: none;
    background: theme('colors.paper');
    border: 1px solid theme('colors.rule');
    color: theme('colors.ink');
    white-space: nowrap;
  }
  :global(.it-map-btn img) { width: 16px; height: 16px; object-fit: contain; }
</style>

<style>
  /* ── Filter nav ───────────────────────────────── */
  .filtri {
    --active-color: #4a6670;
    background: theme('colors.sabbia');
    border-bottom: 1px solid rgba(31,42,42,.1);
    position: sticky;
    top: 0;
    z-index: 20;
  }
  .filtri-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: .85rem 2rem;
    display: flex;
    gap: .55rem;
    flex-wrap: wrap;
    align-items: center;
  }
  .filtri-label {
    font-family: theme('fontFamily.mono');
    font-size: .62rem;
    text-transform: uppercase;
    letter-spacing: .22em;
    color: theme('colors.ink-soft');
    opacity: .55;
    margin-right: .35rem;
  }
  .filtri-btn {
    font-family: theme('fontFamily.mono');
    font-size: .7rem;
    text-transform: uppercase;
    letter-spacing: .14em;
    color: theme('colors.ink');
    background: rgba(255,255,255,.55);
    border: 1.5px solid rgba(31,42,42,.15);
    border-radius: 999px;
    padding: .45rem 1rem .45rem .85rem;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: .5rem;
    white-space: nowrap;
    transition: background .18s, border-color .18s, color .18s, box-shadow .18s;
    box-shadow: 0 1px 3px rgba(0,0,0,.06);
  }
  .filtri-btn:hover {
    background: rgba(255,255,255,.85);
    border-color: rgba(31,42,42,.28);
  }
  .filtri-btn.attivo {
    background: var(--active-color);
    border-color: var(--active-color);
    color: #fff;
    box-shadow: 0 2px 10px rgba(0,0,0,.18);
  }
  .filtri-btn .filtri-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: currentColor;
