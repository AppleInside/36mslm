---
import Base from '../../../../layouts/Base.astro';
import PageHeader from '../../../../components/PageHeader.astro';
import type { Lang } from '../../../../i18n/ui';
import { sayings } from '../../../../data/dialetto';

export function getStaticPaths() {
  return [{ params: { lang: 'it' } }, { params: { lang: 'en' } }];
}

const lang = Astro.params.lang as Lang;

const nProverbi    = sayings.filter(s => s.type === 'proverbio').length;
const nModiDiDire  = sayings.filter(s => s.type === 'modo-di-dire').length;

const eyebrowLabel = (type: string) =>
  type === 'proverbio'
    ? (lang === 'it' ? 'Proverbio' : 'Proverb')
    : (lang === 'it' ? 'Modo di dire' : 'Saying');
---

<Base title={lang === 'it' ? 'Il dialetto e i modi di dire' : 'Dialect and sayings'}>
  <PageHeader
    eyebrow={lang === 'it' ? '— Memoria —' : '— Memory —'}
    bg="/media/storico/Giovanni-Guareschi-al-bar-in-piazza.jpg"
  >
    {lang === 'it'
      ? <>Proverbi e <em>modi di dire</em></>
      : <>Proverbs and <em>sayings</em></>}
  </PageHeader>

  <div class="filters-bar">
    <button class="fil active" data-filter="all">
      {lang === 'it' ? 'Tutti' : 'All'} ({sayings.length})
    </button>
    <button class="fil" data-filter="proverbio">
      {lang === 'it' ? 'Proverbi' : 'Proverbs'} ({nProverbi})
    </button>
    <button class="fil" data-filter="modo-di-dire">
      {lang === 'it' ? 'Modi di dire' : 'Sayings'} ({nModiDiDire})
    </button>
  </div>

  <div class="sayings-grid" id="sayingsGrid">
    {sayings.map((s, i) => (
      <article class:list={['sc', s.type === 'proverbio' && 'sc--proverbio']} data-type={s.type}>
        <header class="sc-head">
          <span class="sc-eyebrow">{eyebrowLabel(s.type)}</span>
          <span class="sc-num">{String(i + 1).padStart(2, '0')}</span>
        </header>
        <p class="sc-dialect">"{s.dialect}"</p>
        <p class="sc-italian">→ {s.italian}</p>
        <p class="sc-desc">{s.desc}</p>
        <audio class="sc-audio" controls preload="none">
          <source src={`/media/dialetto/${s.id}.mp3`} type="audio/mpeg" />
        </audio>
      </article>
    ))}
  </div>

  <p class="attribution">
    {lang === 'it'
      ? <>Proverbi e modi di dire del dialetto di Polesine Parmense — voce di <strong>Giacomo Sartori</strong> e <strong>Davide Maestri</strong></>
      : <>Proverbs and sayings in the Polesine Parmense dialect — voice of <strong>Giacomo Sartori</strong> and <strong>Davide Maestri</strong></>}
  </p>
</Base>

<style>
  /* ── Filters ── */
  .filters-bar {
    display: flex;
    flex-wrap: wrap;
    gap: .5rem;
    padding: .75rem 1.25rem .1rem;
  }
  .fil {
    padding: .35rem 1rem;
    border-radius: 999px;
    border: 1px solid theme('colors.acquadeep');
    background: transparent;
    color: theme('colors.acquadeep');
    font-family: theme('fontFamily.mono');
    font-size: .68rem;
    text-transform: uppercase;
    letter-spacing: .1em;
    cursor: pointer;
    transition: background .2s ease, color .2s ease;
  }
  .fil:hover { background: rgba(74,102,112,0.08); }
  .fil.active { background: theme('colors.acquadeep'); color: #fff; }

  .sayings-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: .9rem;
    padding: 1.25rem 1.25rem 5rem;
  }
  @media (min-width: 600px) {
    .sayings-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 960px) {
    .sayings-grid { grid-template-columns: repeat(3, 1fr); gap: 1rem; }
  }
  @media (min-width: 1050px) {
    .filters-bar  { padding: .75rem 4rem .1rem; }
    .sayings-grid { padding: 1.25rem 4rem 6rem; }
  }

  /* ── Card ── */
  .sc {
    background: #fff;
    border: 1px solid theme('colors.rule');
    border-radius: 14px;
    padding: 1rem 1.1rem .85rem;
    display: flex;
    flex-direction: column;
    gap: .55rem;
    box-shadow: 0 2px 10px rgba(31,42,42,0.05);
    transition: box-shadow .2s ease, transform .2s cubic-bezier(.2,.7,.2,1);
  }
  .sc:hover {
    box-shadow: 0 8px 24px rgba(31,42,42,0.1);
    transform: translateY(-2px);
  }
  .sc {
    border-left: 3px solid #4a6670;
  }
  .sc--proverbio {
    border-left: 3px solid theme('colors.gold');
    background: linear-gradient(135deg, rgba(216,161,74,0.04) 0%, #fff 60%);
  }

  .sc-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .sc-eyebrow {
    font-family: theme('fontFamily.mono');
    font-size: .62rem;
    text-transform: uppercase;
    letter-spacing: .14em;
    color: theme('colors.acquadeep');
    font-weight: 600;
  }
  .sc--proverbio .sc-eyebrow { color: theme('colors.gold-deep'); }
  .sc-mic { color: theme('colors.acquadeep'); opacity: .6; }

  .sc-num {
    font-family: theme('fontFamily.mono');
    font-size: .62rem;
    color: theme('colors.ink-soft');
    opacity: .5;
    letter-spacing: .04em;
  }

  .sc-dialect {
    font-family: theme('fontFamily.hand');
    font-size: 1.45rem;
    font-weight: 700;
    font-style: italic;
    color: theme('colors.acquadeep');
    line-height: 1.2;
    margin: 0;
  }

  .sc-italian {
    font-style: italic;
    font-size: .9rem;
    color: theme('colors.gold-deep');
    margin: 0;
    line-height: 1.3;
  }

  .sc-desc {
    font-size: .85rem;
    line-height: 1.55;
    color: theme('colors.ink-soft');
    margin: 0;
    flex: 1;
  }

  .sc-audio {
    width: 100%;
    height: 36px;
    margin-top: .15rem;
    accent-color: theme('colors.brand');
  }

  /* ── Attribution ── */
  .attribution {
    text-align: center;
    font-size: .78rem;
    color: theme('colors.ink-soft');
    padding: 0 1.25rem 3rem;
    line-height: 1.6;
  }
  .attribution strong { color: theme('colors.ink'); font-weight: 600; }

  @media (min-width: 1050px) {
    .attribution { padding-bottom: 4rem; }
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('.fil').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.fil').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const filter = btn.dataset.filter;
      document.querySelectorAll<HTMLElement>('.sc').forEach(card => {
        card.style.display = (filter === 'all' || card.dataset.type === filter) ? '' : 'none';
      });
    });
  });
</script>
