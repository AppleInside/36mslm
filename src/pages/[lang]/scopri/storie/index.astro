---
import { readdirSync } from 'node:fs';
import { resolve } from 'node:path';
import Base from '../../../../layouts/Base.astro';
import PageHeader from '../../../../components/PageHeader.astro';
import type { Lang } from '../../../../i18n/ui';

export function getStaticPaths() {
  return [{ params: { lang: 'it' } }, { params: { lang: 'en' } }];
}

const lang = Astro.params.lang as Lang;

const files = readdirSync(resolve('public/media/dialetto'))
  .filter(f => f.endsWith('.mp3'))
  .sort();

const tracks = files.map(f => ({
  id: f.replace('.mp3', ''),
  label: f.replace('.mp3', '').replace(/-/g, ' '),
  src: `/media/dialetto/${f}`,
}));
---

<Base title={lang === 'it' ? 'Il dialetto e i modi di dire' : 'Dialect and sayings'}>
  <PageHeader eyebrow={lang === 'it' ? '— Memoria —' : '— Memory —'}>
    {lang === 'it'
      ? <>Il dialetto e <em>i modi di dire</em></>
      : <>The dialect and <em>its sayings</em></>}
  </PageHeader>

  <div class="attribution">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
      <path d="M12 2a3 3 0 0 1 3 3v7a3 3 0 0 1-6 0V5a3 3 0 0 1 3-3z"/>
      <path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
      <line x1="12" y1="19" x2="12" y2="22"/>
    </svg>
    <span>
      {lang === 'it'
        ? <><strong>55 modi di dire</strong> del dialetto di Polesine Parmense &mdash; voce di <strong>Giacomo Sartori</strong></>
        : <><strong>55 sayings</strong> in the Polesine Parmense dialect &mdash; voice of <strong>Giacomo Sartori</strong></>}
    </span>
  </div>

  <div class="tracks-grid" id="tracksGrid">
    {tracks.map(track => (
      <button
        class="track-card"
        data-id={track.id}
        data-src={track.src}
        aria-label={`Ascolta: ${track.label}`}
      >
        <span class="tc-play" aria-hidden="true">
          <svg class="icon-play" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><polygon points="5,3 19,12 5,21"/></svg>
          <svg class="icon-pause" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>
        </span>
        <span class="tc-label">{track.label}</span>
        <span class="tc-bar"><span class="tc-fill"></span></span>
      </button>
    ))}
  </div>
</Base>

<style>
  /* ── Attribution banner ── */
  .attribution {
    display: flex;
    align-items: flex-start;
    gap: .65rem;
    padding: 1rem 1.25rem 0;
    color: theme('colors.ink-soft');
    font-size: .88rem;
    line-height: 1.5;
  }
  .attribution svg { flex-shrink: 0; margin-top: .1rem; color: theme('colors.acquadeep'); }
  .attribution strong { color: theme('colors.ink'); }

  @media (min-width: 1050px) {
    .attribution { padding: 1.25rem 4rem 0; }
  }

  /* ── Grid ── */
  .tracks-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: .55rem;
    padding: 1.25rem 1.25rem 5rem;
  }
  @media (min-width: 500px) {
    .tracks-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 780px) {
    .tracks-grid { grid-template-columns: repeat(3, 1fr); gap: .65rem; }
  }
  @media (min-width: 1050px) {
    .tracks-grid { padding: 1.5rem 4rem 6rem; grid-template-columns: repeat(4, 1fr); gap: .75rem; }
  }

  /* ── Card ── */
  .track-card {
    display: grid;
    grid-template-columns: 44px 1fr;
    grid-template-rows: auto 3px;
    align-items: center;
    column-gap: .75rem;
    background: #fff;
    border: 1px solid theme('colors.rule');
    border-radius: 12px;
    padding: .75rem .9rem .6rem;
    cursor: pointer;
    text-align: left;
    transition: box-shadow .2s ease, transform .2s cubic-bezier(.2,.7,.2,1), border-color .2s ease;
  }
  .track-card:hover {
    box-shadow: 0 6px 22px rgba(31,42,42,0.1);
    transform: translateY(-2px);
    border-color: theme('colors.acquadeep');
  }
  .track-card.playing {
    border-color: theme('colors.brand');
    background: rgba(15,113,184,0.04);
  }
  .track-card.playing .tc-play {
    background: theme('colors.brand');
    color: #fff;
  }

  /* play/pause button */
  .tc-play {
    grid-row: 1;
    grid-column: 1;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: theme('colors.paper-2');
    color: theme('colors.acquadeep');
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: background .2s ease, color .2s ease;
  }
  .track-card:hover .tc-play {
    background: theme('colors.acquadeep');
    color: #fff;
  }
  .icon-pause { display: none; }
  .track-card.playing .icon-play { display: none; }
  .track-card.playing .icon-pause { display: block; }

  /* label */
  .tc-label {
    grid-row: 1;
    grid-column: 2;
    font-family: theme('fontFamily.hand');
    font-size: 1.15rem;
    font-weight: 700;
    line-height: 1.2;
    color: theme('colors.ink');
    text-transform: lowercase;
  }

  /* progress bar */
  .tc-bar {
    grid-row: 2;
    grid-column: 1 / -1;
    margin-top: .55rem;
    height: 3px;
    background: theme('colors.rule');
    border-radius: 99px;
    overflow: hidden;
  }
  .tc-fill {
    display: block;
    height: 100%;
    width: 0%;
    background: theme('colors.brand');
    border-radius: 99px;
    transition: width .25s linear;
  }
</style>

<script define:vars={{ tracks }}>
  let currentAudio = null;
  let currentCard = null;

  function stopCurrent() {
    if (currentAudio) {
      currentAudio.pause();
      currentAudio.currentTime = 0;
    }
    if (currentCard) {
      currentCard.classList.remove('playing');
      currentCard.querySelector('.tc-fill').style.width = '0%';
    }
    currentAudio = null;
    currentCard = null;
  }

  document.querySelectorAll('.track-card').forEach(card => {
    const audio = new Audio(card.dataset.src);
    const fill = card.querySelector('.tc-fill');

    audio.addEventListener('timeupdate', () => {
      if (audio.duration) {
        fill.style.width = (audio.currentTime / audio.duration * 100) + '%';
      }
    });
    audio.addEventListener('ended', () => {
      card.classList.remove('playing');
      fill.style.width = '0%';
      currentAudio = null;
      currentCard = null;
    });

    card.addEventListener('click', () => {
      if (currentCard === card) {
        stopCurrent();
        return;
      }
      stopCurrent();
      currentAudio = audio;
      currentCard = card;
      card.classList.add('playing');
      audio.play();
    });
  });
</script>
