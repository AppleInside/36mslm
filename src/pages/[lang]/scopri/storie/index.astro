---
import Base from '../../../../layouts/Base.astro';
import PageHeader from '../../../../components/PageHeader.astro';
import type { Lang } from '../../../../i18n/ui';
import { sayings } from '../../../../data/dialetto';

export function getStaticPaths() {
  return [{ params: { lang: 'it' } }, { params: { lang: 'en' } }];
}

const lang = Astro.params.lang as Lang;
---

<Base title={lang === 'it' ? 'Il dialetto e i modi di dire' : 'Dialect and sayings'}>
  <PageHeader
    eyebrow={lang === 'it' ? '— Memoria —' : '— Memory —'}
    bg="/media/storico/Giovanni-Guareschi-al-bar-in-piazza.jpg"
  >
    {lang === 'it'
      ? <>Il dialetto e <em>i modi di dire</em></>
      : <>The dialect and <em>its sayings</em></>}
  </PageHeader>

  <div class="intro">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
      <path d="M12 2a3 3 0 0 1 3 3v7a3 3 0 0 1-6 0V5a3 3 0 0 1 3-3z"/>
      <path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
      <line x1="12" y1="19" x2="12" y2="22"/>
    </svg>
    <span>
      {lang === 'it'
        ? <><strong>55 modi di dire</strong> del dialetto di Polesine Parmense — voce di <strong>Giacomo Sartori</strong></>
        : <><strong>55 sayings</strong> in the Polesine Parmense dialect — voice of <strong>Giacomo Sartori</strong></>}
    </span>
  </div>

  <div class="sayings-grid">
    {sayings.map(s => (
      <article class="sc">
        <header class="sc-head">
          <span class="sc-eyebrow">{lang === 'it' ? 'Modo di dire' : 'Saying'}</span>
          <svg class="sc-mic" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <path d="M12 2a3 3 0 0 1 3 3v7a3 3 0 0 1-6 0V5a3 3 0 0 1 3-3z"/>
            <path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
            <line x1="12" y1="19" x2="12" y2="22"/>
          </svg>
        </header>
        <p class="sc-dialect">"{s.dialect}"</p>
        <p class="sc-italian">→ {s.italian}</p>
        <p class="sc-desc">{s.desc}</p>
        <audio class="sc-audio" controls preload="none">
          <source src={`/media/dialetto/${s.id}.mp3`} type="audio/mpeg" />
        </audio>
      </article>
    ))}
  </div>
</Base>

<style>
  .intro {
    display: flex;
    align-items: flex-start;
    gap: .6rem;
    padding: 1rem 1.25rem .25rem;
    font-size: .87rem;
    color: theme('colors.ink-soft');
    line-height: 1.5;
  }
  .intro svg { flex-shrink: 0; margin-top: .15rem; color: theme('colors.acquadeep'); }
  .intro strong { color: theme('colors.ink'); }

  .sayings-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: .9rem;
    padding: 1.25rem 1.25rem 5rem;
  }
  @media (min-width: 600px) {
    .sayings-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 960px) {
    .sayings-grid { grid-template-columns: repeat(3, 1fr); gap: 1rem; }
  }
  @media (min-width: 1050px) {
    .intro       { padding: 1.25rem 4rem .25rem; }
    .sayings-grid { padding: 1.25rem 4rem 6rem; }
  }

  /* ── Card ── */
  .sc {
    background: #fff;
    border: 1px solid theme('colors.rule');
    border-radius: 14px;
    padding: 1rem 1.1rem .85rem;
    display: flex;
    flex-direction: column;
    gap: .55rem;
    box-shadow: 0 2px 10px rgba(31,42,42,0.05);
    transition: box-shadow .2s ease, transform .2s cubic-bezier(.2,.7,.2,1);
  }
  .sc:hover {
    box-shadow: 0 8px 24px rgba(31,42,42,0.1);
    transform: translateY(-2px);
  }

  .sc-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .sc-eyebrow {
    font-family: theme('fontFamily.mono');
    font-size: .62rem;
    text-transform: uppercase;
    letter-spacing: .14em;
    color: theme('colors.acquadeep');
    font-weight: 600;
  }
  .sc-mic { color: theme('colors.acquadeep'); opacity: .6; }

  .sc-dialect {
    font-family: theme('fontFamily.hand');
    font-size: 1.45rem;
    font-weight: 700;
    font-style: italic;
    color: theme('colors.acquadeep');
    line-height: 1.2;
    margin: 0;
  }

  .sc-italian {
    font-style: italic;
    font-size: .9rem;
    color: theme('colors.gold-deep');
    margin: 0;
    line-height: 1.3;
  }

  .sc-desc {
    font-size: .85rem;
    line-height: 1.55;
    color: theme('colors.ink-soft');
    margin: 0;
    flex: 1;
  }

  .sc-audio {
    width: 100%;
    height: 36px;
    margin-top: .15rem;
    accent-color: theme('colors.brand');
  }
</style>
