---
import Base from '../../../../layouts/Base.astro';
import PageHeader from '../../../../components/PageHeader.astro';
import PageBody from '../../../../components/PageBody.astro';
import NoticeCard from '../../../../components/NoticeCard.astro';
import { getCollection } from 'astro:content';
import { byLang, sortByDateDesc } from '../../../../lib/content';
import type { Lang } from '../../../../i18n/ui';

export function getStaticPaths() {
  return [{ params: { lang: 'it' } }, { params: { lang: 'en' } }];
}

const lang = Astro.params.lang as Lang;
const all = await getCollection('notices');
const notices = sortByDateDesc(byLang(all, lang));
---
<Base title={lang === 'it' ? 'Bacheca' : 'Notice board'}>
  <PageHeader eyebrow={lang === 'it' ? '— Comunicazioni —' : '— Notices —'}>
    {lang === 'it' ? <>Bacheca <em>e avvisi</em></> : <>Notice <em>board</em></>}
  </PageHeader>
  <PageBody>
    <div class="grid gap-4 md:grid-cols-2">
      {notices.map((e) => <NoticeCard entry={e} />)}
    </div>
  </PageBody>
</Base>
