---
export const prerender = false;
import Base from '../../../layouts/Base.astro';
import type { Lang } from '../../../i18n/ui';

const lang  = Astro.params.lang as Lang;
const ok    = Astro.url.searchParams.get('ok');
const err   = Astro.url.searchParams.get('err');

const it = lang === 'it';

const t = {
  title:       it ? 'Segnalazioni' : 'Reports',
  intro:       it
    ? 'Hai un evento da proporre, una storia da raccontare o una foto storica da condividere? Compila il modulo e ti risponderemo.'
    : 'Got an event to suggest, a story to share, or a historic photo to contribute? Fill out the form and we will get back to you.',
  name:        it ? 'Nome e cognome' : 'Full name',
  email:       'Email',
  subject:     it ? 'Tipo di segnalazione' : 'Type of report',
  subjects:    it
    ? ['Proponi un evento', 'Segnala un locale', 'Foto storica', 'Altro']
    : ['Propose an event', 'Report a venue', 'Historic photo', 'Other'],
  body:        it ? 'Messaggio' : 'Message',
  bodyHint:    it ? 'Descrivi la tua segnalazione con il maggior dettaglio possibile.' : 'Describe your report in as much detail as possible.',
  send:        it ? 'Invia segnalazione' : 'Send report',
  ok:          it ? 'Segnalazione ricevuta. Grazie!' : 'Report received. Thank you!',
  err:         it ? 'Qualcosa è andato storto. Riprova.' : 'Something went wrong. Please try again.',
};
---

<Base title={t.title}>
  <article class="mx-auto max-w-md px-5 py-16">
    <h1 class="text-5xl">{t.title}</h1>

    <p class="mt-6 text-base text-testo/70 leading-relaxed">{t.intro}</p>

    {ok && (
      <div class="ok-card">
        <svg class="ok-icon" width="52" height="52" viewBox="0 0 52 52" fill="none" aria-hidden="true">
          <circle cx="26" cy="26" r="24" stroke="currentColor" stroke-width="1.6"/>
          <path d="M16 26L22 32L36 18" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <p class="ok-title">{t.ok}</p>
        <p class="ok-sub">{it ? 'Ti risponderemo il prima possibile.' : "We'll get back to you soon."}</p>
      </div>
    )}

    {err && (
      <div class="mt-6 flex items-center gap-2 rounded-lg border border-red-300/40 bg-red-50 px-4 py-3 text-sm text-red-600">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.3"/>
          <line x1="8" y1="5" x2="8" y2="9" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
          <circle cx="8" cy="11" r="0.8" fill="currentColor"/>
        </svg>
        {t.err}
      </div>
    )}

    {!ok && (
      <form method="POST" action="/api/report" class="mt-8 grid gap-6">
        <input type="hidden" name="lang" value={lang} />

        <label class="grid gap-1 text-sm font-medium">
          <span>{t.name} <span class="text-red-400">*</span></span>
          <input
            name="name"
            type="text"
            required
            maxlength="120"
            autocomplete="name"
            class="rounded border border-argento bg-sabbia px-3 py-2.5 text-sm focus:border-pioppo focus:outline-none"
          />
        </label>

        <label class="grid gap-1 text-sm font-medium">
          <span>Email <span class="text-red-400">*</span></span>
          <input
            name="email"
            type="email"
            required
            maxlength="200"
            autocomplete="email"
            class="rounded border border-argento bg-sabbia px-3 py-2.5 text-sm focus:border-pioppo focus:outline-none"
          />
        </label>

        <label class="grid gap-1 text-sm font-medium">
          <span>{t.subject} <span class="text-red-400">*</span></span>
          <select
            name="subject"
            required
            class="rounded border border-argento bg-sabbia px-3 py-2.5 text-sm focus:border-pioppo focus:outline-none"
          >
            <option value="" disabled selected>{it ? 'Seleziona…' : 'Select…'}</option>
            {t.subjects.map(s => <option value={s}>{s}</option>)}
          </select>
        </label>

        <label class="grid gap-1 text-sm font-medium">
          <span>{t.body} <span class="text-red-400">*</span></span>
          <textarea
            name="body"
            required
            rows="6"
            maxlength="5000"
            class="rounded border border-argento bg-sabbia px-3 py-2 text-sm focus:border-pioppo focus:outline-none resize-y"
          ></textarea>
          <span class="text-xs text-testo/40">{t.bodyHint}</span>
        </label>

        <div class="mt-2">
          <button type="submit" id="sg-submit" class="sg-btn" disabled>
            <span class="sg-label">{t.send}</span>
            <span class="sg-arrow" aria-hidden="true">→</span>
          </button>
        </div>
      </form>
    )}
  </article>
</Base>

<style>
  .ok-card {
    margin-top: 2.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.75rem;
    padding: 2.5rem 2rem 3rem;
    border-radius: 1rem;
    border: 1px solid theme('colors.pioppo' / 30%);
    background: theme('colors.pioppo' / 8%);
  }
  .ok-icon {
    color: theme('colors.pioppo');
    margin-bottom: 0.25rem;
  }
  .ok-title {
    font-family: theme('fontFamily.hand');
    font-size: 1.75rem;
    font-weight: 700;
    color: theme('colors.pioppo');
    line-height: 1.2;
    margin: 0;
  }
  .ok-sub {
    font-size: 0.93rem;
    color: theme('colors.testo' / 55%);
    margin: 0;
    line-height: 1.6;
  }

  .sg-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    border: none;
    border-radius: 999px;
    padding: 0.625rem 1.5rem;
    font-size: 0.875rem;
    font-family: inherit;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.18s, color 0.18s, transform 0.12s, gap 0.18s;
  }

  .sg-btn:not(:disabled) {
    background: theme('colors.pioppo');
    color: #fff;
  }
  .sg-btn:not(:disabled):hover {
    background: color-mix(in srgb, theme('colors.pioppo') 85%, black);
    transform: translateY(-1px);
    gap: 0.75rem;
  }
  .sg-btn:not(:disabled):active {
    transform: translateY(0);
  }

  .sg-btn:disabled {
    background: theme('colors.pioppo' / 18%);
    color: theme('colors.testo' / 35%);
    cursor: not-allowed;
  }

  .sg-arrow {
    display: inline-block;
    transition: transform 0.15s;
  }
  .sg-btn:disabled .sg-arrow {
    opacity: 0;
    width: 0;
    overflow: hidden;
  }
</style>

<script>
  const form = document.querySelector('form[action="/api/report"]') as HTMLFormElement | null;
  if (form) {
    const btn = document.getElementById('sg-submit') as HTMLButtonElement;
    const required = Array.from(form.querySelectorAll<HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement>('[required]'));

    function check() {
      btn.disabled = !required.every(el => el.value.trim().length > 0);
    }

    required.forEach(el => {
      el.addEventListener('input', check);
      el.addEventListener('change', check);
    });
    check();
  }
</script>
