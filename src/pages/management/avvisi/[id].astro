---
export const prerender = false;
import Management from '../../../layouts/Management.astro';
import { sql } from '../../../server/db';

const userDisplayName = Astro.locals.userDisplayName;
const { id } = Astro.params;

type NoticeRow = {
  id: number;
  title: string;
  slug: string;
  body: string;
  date: Date | null;
  priority: boolean;
  cta: string | null;
  tags: string[];
  expires_at: Date | null;
  status: 'draft' | 'published';
  publish_at: Date | null;
};

const rows = await sql<NoticeRow[]>`
  SELECT id, title, slug, body, date, priority, cta, tags, expires_at, status, publish_at
  FROM notices WHERE id = ${Number(id)} AND lang = 'it' LIMIT 1
`;
const notice = rows[0];
if (!notice) return Astro.redirect('/management/avvisi?err=1', 302);

function toDateStr(d: Date | null) {
  if (!d) return '';
  const v = d instanceof Date ? d.toISOString() : String(d);
  return v.slice(0, 10);
}

const dateStr      = toDateStr(notice.date);
const expiresStr   = toDateStr(notice.expires_at);
const tagsStr      = (notice.tags ?? []).join(', ');
const publishAtStr = notice.publish_at
  ? (notice.publish_at instanceof Date ? notice.publish_at.toISOString() : String(notice.publish_at)).slice(0, 16)
  : '';
---

<Management title={`Modifica: ${notice.title}`} userDisplayName={userDisplayName}>
  <div class="form-page">

    <div class="form-header">
      <a href="/management/avvisi" class="back-link">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M9 2L4 7L9 12" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Lista avvisi
      </a>
      <h1 class="form-title">Modifica avviso</h1>
    </div>

    <form method="POST" action={`/api/management/avvisi/${notice.id}/update`} class="form-card">

      <div class="row-2">
        <div class="field">
          <label for="title">Titolo <span class="req">*</span></label>
          <input id="title" name="title" type="text" required value={notice.title} autocomplete="off" />
        </div>
        <div class="field">
          <label for="slug">Slug <span class="req">*</span></label>
          <input id="slug" name="slug" type="text" required pattern="[a-z0-9-]+" value={notice.slug} class="mono" autocomplete="off" />
          <span class="hint">Attenzione: modificare lo slug rompe i link esistenti.</span>
        </div>
      </div>

      <div class="field">
        <label for="body">Testo (Markdown) <span class="req">*</span></label>
        <div class="md-split">
          <textarea id="body" name="body" rows="10" required class="mono">{notice.body}</textarea>
          <div id="md-preview" class="md-preview">
            <span class="preview-placeholder">Anteprima…</span>
          </div>
        </div>
      </div>

      <div class="row-3">
        <div class="field">
          <label for="date">Data avviso</label>
          <input id="date" name="date" type="date" value={dateStr} />
        </div>
        <div class="field">
          <label for="expires_at">Scade il</label>
          <input id="expires_at" name="expires_at" type="date" value={expiresStr} />
        </div>
        <div class="field">
          <label for="cta">Link CTA</label>
          <input id="cta" name="cta" type="text" value={notice.cta ?? ''} placeholder="https://…" />
        </div>
      </div>

      <div class="field">
        <label for="tags">Tag</label>
        <input id="tags" name="tags" type="text" value={tagsStr} placeholder="escursione, soci, assemblea" autocomplete="off" />
        <span class="hint">Separati da virgola.</span>
      </div>

      <div class="row-3 row-align-end">
        <div class="field">
          <label for="status">Stato</label>
          <select id="status" name="status">
            <option value="draft"     selected={notice.status === 'draft'}>Bozza</option>
            <option value="published" selected={notice.status === 'published'}>Pubblicato</option>
          </select>
        </div>
        <div class="field">
          <label for="publish_at">Pubblica il <span class="req">⏱</span></label>
          <input id="publish_at" name="publish_at" type="datetime-local" value={publishAtStr} />
          <span class="hint">Lascia vuoto per pubblicare subito.</span>
        </div>
        <div class="field">
          <label style="visibility:hidden" aria-hidden="true">&nbsp;</label>
          <label class="checkbox-label">
            <input name="priority" type="checkbox" value="on" checked={notice.priority} class="checkbox" />
            <span class="checkbox-text">Priorità alta</span>
          </label>
        </div>
      </div>

      <div class="form-footer">
        <a href="/management/avvisi" class="btn-cancel">Annulla</a>
        <button type="submit" class="btn-submit">Salva modifiche</button>
      </div>

    </form>
  </div>
</Management>

<script>
  import { marked } from 'marked';

  const bodyTextarea = document.getElementById('body') as HTMLTextAreaElement;
  const preview      = document.getElementById('md-preview');

  function updatePreview() {
    if (!preview) return;
    const text = bodyTextarea?.value ?? '';
    preview.innerHTML = text
      ? String(marked.parse(text))
      : '<span class="preview-placeholder">Anteprima…</span>';
  }

  bodyTextarea?.addEventListener('input', updatePreview);
  updatePreview();
</script>

<style>
  .form-page {
    max-width: 820px;
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
    animation: page-in 0.4s cubic-bezier(0.22,1,0.36,1) both;
  }

  @keyframes page-in {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .form-header {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.4rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid rgba(232,220,200,0.06);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(232,220,200,0.35);
    text-decoration: none;
    transition: color 0.2s;
    flex-shrink: 0;
  }

  .back-link:hover { color: rgba(232,220,200,0.7); }

  .form-title {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 1.9rem;
    font-weight: 300;
    color: #E8DCC8;
    letter-spacing: -0.01em;
  }

  .form-card {
    background: rgba(232,220,200,0.02);
    border: 1px solid rgba(232,220,200,0.07);
    border-radius: 8px;
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .field { display: flex; flex-direction: column; gap: 0.4rem; }

  .field label {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.65rem;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(232,220,200,0.4);
  }

  .req { color: rgba(216,161,74,0.7); }

  .field input,
  .field textarea,
  .field select {
    background: rgba(232,220,200,0.04);
    border: 1px solid rgba(232,220,200,0.10);
    border-radius: 4px;
    padding: 0.65rem 0.75rem;
    font-family: 'Fraunces', Georgia, serif;
    font-size: 0.95rem;
    font-weight: 300;
    color: #E8DCC8;
    outline: none;
    transition: border-color 0.2s, background 0.2s;
    width: 100%;
  }

  .field input.mono,
  .field textarea.mono {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.82rem;
  }

  .field input::placeholder,
  .field textarea::placeholder { color: rgba(232,220,200,0.2); }

  .field input:focus,
  .field textarea:focus,
  .field select:focus {
    border-color: rgba(216,161,74,0.45);
    background: rgba(232,220,200,0.06);
  }

  .field select option { background: #0D2220; }

  .hint {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.62rem;
    color: rgba(232,220,200,0.25);
    letter-spacing: 0.03em;
  }

  .md-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .md-preview {
    background: rgba(232,220,200,0.03);
    border: 1px solid rgba(232,220,200,0.08);
    border-radius: 4px;
    padding: 0.75rem;
    min-height: 200px;
    font-family: 'Fraunces', Georgia, serif;
    font-size: 0.9rem;
    font-weight: 300;
    color: rgba(232,220,200,0.7);
    line-height: 1.7;
    overflow-y: auto;
  }

  .preview-placeholder {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    color: rgba(232,220,200,0.18);
  }

  .row-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }
  .row-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1.25rem; }
  .row-align-end { align-items: end; }

  .checkbox-label {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    cursor: pointer;
    padding-bottom: 0.1rem;
  }

  .checkbox { width: 16px; height: 16px; accent-color: #D8A14A; cursor: pointer; flex-shrink: 0; }

  .checkbox-text {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    color: rgba(232,220,200,0.6);
  }

  .form-footer {
    display: flex;
    justify-content: flex-end;
    gap: 0.75rem;
    padding-top: 0.5rem;
    border-top: 1px solid rgba(232,220,200,0.06);
  }

  .btn-cancel {
    padding: 0.6rem 1.1rem;
    background: none;
    border: 1px solid rgba(232,220,200,0.12);
    border-radius: 3px;
    color: rgba(232,220,200,0.45);
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    transition: border-color 0.2s, color 0.2s;
  }

  .btn-cancel:hover { border-color: rgba(232,220,200,0.3); color: rgba(232,220,200,0.7); }

  .btn-submit {
    padding: 0.6rem 1.4rem;
    background: #D8A14A;
    border: none;
    border-radius: 3px;
    color: #1A0E00;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.2s, transform 0.15s;
  }

  .btn-submit:hover { background: #E8B05A; transform: translateY(-1px); }

  @media (max-width: 700px) {
    .row-2, .row-3 { grid-template-columns: 1fr; }
    .md-split       { grid-template-columns: 1fr; }
    .md-preview     { min-height: 120px; }
  }
</style>
