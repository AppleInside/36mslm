---
export const prerender = false;
import Management from '../../../layouts/Management.astro';
import { sql } from '../../../server/db';

const userDisplayName = Astro.locals.userDisplayName;

type NoticeRow = {
  id: number;
  title: string;
  date: string | null;
  expires_at: string | null;
  priority: boolean;
  status: 'draft' | 'published';
  publish_at: Date | null;
};

const notices = await sql<NoticeRow[]>`
  SELECT id, title, date::text, expires_at::text, priority, status, publish_at
  FROM notices
  WHERE lang = 'it'
  ORDER BY priority DESC, created_at DESC
`;

const ok  = Astro.url.searchParams.get('ok');
const err = Astro.url.searchParams.get('err');

const now      = new Date();
const todayStr = now.toISOString().slice(0, 10);

function isExpired(d: string | null) {
  return d ? d < todayStr : false;
}

function fmtDate(d: string | null) {
  if (!d) return '—';
  return new Date(d + 'T00:00:00').toLocaleDateString('it-IT', {
    day: '2-digit', month: 'short', year: 'numeric'
  });
}
---

<Management title="Avvisi" userDisplayName={userDisplayName}>

  <div class="page">

    <div class="page-header">
      <div>
        <h1 class="page-title">Avvisi</h1>
        <p class="page-count">
          {notices.length === 0 ? 'Nessun avviso' : `${notices.length} ${notices.length === 1 ? 'avviso' : 'avvisi'}`}
        </p>
      </div>
      <a href="/management/avvisi/nuovo" class="btn-primary">
        <svg width="11" height="11" viewBox="0 0 11 11" fill="none" aria-hidden="true">
          <path d="M5.5 1V10M1 5.5H10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        Nuovo avviso
      </a>
    </div>

    {ok && (
      <div class="flash flash--ok" role="status">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <circle cx="7" cy="7" r="6.5" stroke="currentColor"/>
          <path d="M4.5 7L6.5 9L9.5 5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Operazione completata con successo.
      </div>
    )}
    {err && (
      <div class="flash flash--err" role="alert">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <circle cx="7" cy="7" r="6.5" stroke="currentColor"/>
          <line x1="7" y1="4" x2="7" y2="7.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
          <circle cx="7" cy="9.5" r="0.75" fill="currentColor"/>
        </svg>
        Si è verificato un errore. Riprova.
      </div>
    )}

    {notices.length === 0 && (
      <div class="empty">
        <svg class="empty-icon" width="52" height="52" viewBox="0 0 52 52" fill="none" aria-hidden="true">
          <rect x="8" y="8" width="36" height="36" rx="3" stroke="currentColor" stroke-width="1.4"/>
          <path d="M16 20H36M16 27H30M16 34H24" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" opacity="0.7"/>
          <path d="M36 30L44 38M41 35L44 38L41 41" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" opacity="0.5"/>
        </svg>
        <p class="empty-title">Nessun avviso ancora</p>
        <p class="empty-sub">Pubblica comunicazioni, avvisi urgenti e bacheca per i soci.</p>
        <a href="/management/avvisi/nuovo" class="btn-primary">Crea avviso</a>
      </div>
    )}

    {notices.length > 0 && (
      <div class="table-wrap">
        <table class="table">
          <thead>
            <tr>
              <th>Titolo</th>
              <th class="hide-sm">Data avviso</th>
              <th class="hide-md">Scade il</th>
              <th>Priorità</th>
              <th>Stato</th>
              <th class="th-actions">Azioni</th>
            </tr>
          </thead>
          <tbody>
            {notices.map((n, i) => {
              const expired = isExpired(n.expires_at);
              return (
              <tr style={`--i:${i}`} class={expired ? 'row--expired' : ''}>
                <td>
                  <span class="n-title">{n.title}</span>
                  {expired && <span class="expired-label">scaduto</span>}
                </td>
                <td class="hide-sm">
                  <span class="n-date">{fmtDate(n.date)}</span>
                </td>
                <td class="hide-md">
                  <span class={n.expires_at ? (expired ? 'n-expired-date' : 'n-date') : 'n-none'}>
                    {fmtDate(n.expires_at)}
                  </span>
                </td>
                <td>
                  {n.priority
                    ? <span class="badge badge--priority">Alta</span>
                    : <span class="n-none">—</span>
                  }
                </td>
                <td>
                  {n.status === 'published' && n.publish_at && new Date(n.publish_at) > now
                    ? <span class="badge badge--amber">Programmato</span>
                    : n.status === 'published'
                      ? <span class="badge badge--teal">Pubblicato</span>
                      : <span class="badge badge--dim">Bozza</span>
                  }
                </td>
                <td>
                  <div class="row-actions">
                    <a href={`/management/avvisi/${n.id}`} class="act-edit" title="Modifica">
                      <svg width="18" height="18" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                        <path d="M9.5 2.5L11.5 4.5L5 11H3V9L9.5 2.5Z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/>
                        <path d="M8 4L10 6" stroke="currentColor" stroke-width="1.2"/>
                      </svg>
                    </a>
                    <form
                      method="POST"
                      action={`/api/management/avvisi/${n.id}/delete`}
                      onsubmit="return confirm('Eliminare questo avviso?')"
                    >
                      <button type="submit" class="act-delete" title="Elimina">
                        <svg width="18" height="18" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                          <path d="M2 4H12M5 4V2.5C5 2.22 5.22 2 5.5 2H8.5C8.78 2 9 2.22 9 2.5V4M5.5 6.5V10.5M8.5 6.5V10.5M3 4L3.6 11.5C3.63 11.8 3.88 12 4.18 12H9.82C10.12 12 10.37 11.8 10.4 11.5L11 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
            )})}
          </tbody>
        </table>
      </div>
    )}

  </div>

</Management>

<style>
  .page {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    animation: page-in 0.45s cubic-bezier(0.22,1,0.36,1) both;
  }

  @keyframes page-in {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .page-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid rgba(232,220,200,0.06);
  }

  .page-title {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 2.1rem;
    font-weight: 300;
    color: #E8DCC8;
    line-height: 1;
    letter-spacing: -0.01em;
  }

  .page-count {
    margin-top: 0.4rem;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(232,220,200,0.3);
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.65rem 1.25rem;
    background: #D8A14A;
    color: #1A0E00;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-decoration: none;
    border: none;
    border-radius: 3px;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.2s, transform 0.15s;
  }

  .btn-primary:hover {
    background: #E8B05A;
    transform: translateY(-1px);
  }

  .flash {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.75rem 1rem;
    border-radius: 4px;
    border: 1px solid;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.85rem;
    letter-spacing: 0.03em;
  }

  .flash--ok  { color: #7BC4B4; background: rgba(74,102,112,0.1);  border-color: rgba(74,102,112,0.28); }
  .flash--err { color: #E07B5A; background: rgba(224,123,90,0.07); border-color: rgba(224,123,90,0.22); }

  .empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.8rem;
    padding: 4rem 2rem;
    text-align: center;
  }

  .empty-icon  { color: rgba(232,220,200,0.15); margin-bottom: 0.5rem; }

  .empty-title {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 1.35rem;
    font-weight: 300;
    color: rgba(232,220,200,0.5);
  }

  .empty-sub {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.82rem;
    letter-spacing: 0.04em;
    color: rgba(232,220,200,0.28);
    max-width: 320px;
    line-height: 1.65;
    margin-bottom: 0.5rem;
  }

  .table-wrap {
    border: 1px solid rgba(232,220,200,0.07);
    border-radius: 6px;
    overflow: hidden;
    background: rgba(232,220,200,0.015);
  }

  .table {
    width: 100%;
    border-collapse: collapse;
    font-family: 'IBM Plex Mono', monospace;
  }

  .table thead tr {
    background: rgba(232,220,200,0.04);
    border-bottom: 1px solid rgba(232,220,200,0.07);
  }

  .table th {
    padding: 0.75rem 1rem;
    text-align: left;
    font-size: 0.68rem;
    font-weight: 400;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(232,220,200,0.3);
    white-space: nowrap;
    border-right: 1px solid rgba(232,220,200,0.06);
  }

  .table th:last-child { border-right: none; }
  .th-actions { text-align: right; }

  .table tbody tr {
    border-bottom: 1px solid rgba(232,220,200,0.04);
    transition: background 0.18s;
    animation: row-in 0.4s cubic-bezier(0.22,1,0.36,1) both;
    animation-delay: calc(var(--i, 0) * 40ms + 80ms);
  }

  @keyframes row-in {
    from { opacity: 0; transform: translateX(-6px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  .table tbody tr:last-child { border-bottom: none; }
  .table tbody tr:hover { background: rgba(74,102,112,0.10); }

  .table td {
    padding: 0.9rem 1rem;
    vertical-align: middle;
    border-right: 1px solid rgba(232,220,200,0.04);
  }

  .table td:last-child { border-right: none; }

  .row--expired { opacity: 0.45; }
  .row--expired:hover { opacity: 0.65; background: rgba(74,102,112,0.06); }

  .n-title {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 1.05rem;
    font-weight: 300;
    color: #E8DCC8;
    letter-spacing: 0.01em;
  }

  .expired-label {
    display: inline-block;
    margin-left: 0.5rem;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.58rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(224,123,90,0.5);
    vertical-align: middle;
  }

  .n-date         { font-size: 0.82rem; color: rgba(232,220,200,0.55); letter-spacing: 0.04em; white-space: nowrap; }
  .n-expired-date { font-size: 0.82rem; color: rgba(224,123,90,0.5);  letter-spacing: 0.04em; white-space: nowrap; }
  .n-none         { color: rgba(232,220,200,0.2); font-size: 0.85rem; }

  .badge {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.65rem;
    border-radius: 20px;
    font-size: 0.68rem;
    font-weight: 400;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    border: 1px solid;
    white-space: nowrap;
  }

  .badge--teal     { background: rgba(74,102,112,0.18);  color: #7BC4B4;  border-color: rgba(74,102,112,0.32); }
  .badge--dim      { background: rgba(232,220,200,0.04); color: rgba(232,220,200,0.38); border-color: rgba(232,220,200,0.10); }
  .badge--priority { background: rgba(216,161,74,0.12);  color: #D8A14A;  border-color: rgba(216,161,74,0.25); }
  .badge--amber    { background: rgba(251,146,60,0.10);  color: #FB923C;  border-color: rgba(251,146,60,0.28); }

  .row-actions {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.4rem;
  }

  .act-edit,
  .act-delete {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 5px;
    border: 1px solid transparent;
    background: none;
    cursor: pointer;
    font-family: inherit;
    padding: 0;
    transition: background 0.18s, border-color 0.18s, color 0.18s;
  }

  .act-edit  { color: rgba(216,161,74,0.55); text-decoration: none; }
  .act-edit:hover  { color: #D8A14A; background: rgba(216,161,74,0.10); border-color: rgba(216,161,74,0.22); }

  .act-delete { color: rgba(224,123,90,0.45); }
  .act-delete:hover { color: #E07B5A; background: rgba(224,123,90,0.10); border-color: rgba(224,123,90,0.22); }

  @media (max-width: 900px) { .hide-md { display: none; } }
  @media (max-width: 600px) {
    .hide-sm { display: none; }
    .page-title { font-size: 1.6rem; }
  }
</style>
