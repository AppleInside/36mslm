---
export const prerender = false;
import Management from '../../../layouts/Management.astro';

const userDisplayName = Astro.locals.userDisplayName;
---

<Management title="Nuovo itinerario" userDisplayName={userDisplayName}>
  <div class="form-page">

    <div class="form-header">
      <a href="/management/itinerari" class="back-link">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M9 2L4 7L9 12" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Lista itinerari
      </a>
      <h1 class="form-title">Nuovo itinerario</h1>
    </div>

    <form method="POST" action="/api/management/itinerari/create" class="form-card">

      <!-- Title + Slug -->
      <div class="row-2">
        <div class="field">
          <label for="title">Titolo <span class="req">*</span></label>
          <input id="title" name="title" type="text" required autocomplete="off" />
        </div>
        <div class="field">
          <label for="slug">Slug <span class="req">*</span></label>
          <input id="slug" name="slug" type="text" required pattern="[a-z0-9-]+" class="mono" autocomplete="off" />
          <span class="hint">Solo lettere minuscole, numeri e trattini.</span>
        </div>
      </div>

      <!-- Category + Difficulty + Terrain -->
      <div class="row-3">
        <div class="field">
          <label for="category">Categoria <span class="req">*</span></label>
          <select id="category" name="category">
            <option value="naturalistico">Naturalistico</option>
            <option value="storico">Storico</option>
            <option value="sportivo">Sportivo</option>
          </select>
        </div>
        <div class="field">
          <label for="difficulty">Difficoltà <span class="req">*</span></label>
          <select id="difficulty" name="difficulty">
            <option value="facile">Facile</option>
            <option value="medio">Medio</option>
            <option value="impegnativo">Impegnativo</option>
          </select>
        </div>
        <div class="field">
          <label for="terrain">Terreno</label>
          <input id="terrain" name="terrain" type="text" placeholder="es. sterrato / erba" autocomplete="off" />
        </div>
      </div>

      <!-- Distance + Duration + Label -->
      <div class="row-3">
        <div class="field">
          <label for="distance_km">Distanza (km)</label>
          <input id="distance_km" name="distance_km" type="number" min="0" step="0.1" class="mono" />
        </div>
        <div class="field">
          <label for="duration_min">Durata (min)</label>
          <input id="duration_min" name="duration_min" type="number" min="0" step="1" class="mono" />
        </div>
        <div class="field">
          <label for="duration_label">Etichetta durata</label>
          <input id="duration_label" name="duration_label" type="text" placeholder="es. 1h 30min" autocomplete="off" />
        </div>
      </div>

      <!-- Description -->
      <div class="field">
        <label for="description">Descrizione breve</label>
        <textarea id="description" name="description" rows="3"></textarea>
      </div>

      <!-- ── Mappa tracciato ── -->
      <div class="field">
        <div class="map-header">
          <label>Tracciato</label>
          <div class="map-meta">
            <span id="waypoint-count" class="wp-count">0 waypoints</span>
            <button type="button" id="clear-route" class="btn-clear">Cancella tutto</button>
          </div>
        </div>
        <span class="hint">Clicca sulla mappa per aggiungere waypoints · Trascina per spostare · Tasto destro per rimuovere</span>
        <div id="route-map" class="route-map"></div>
        <input type="hidden" name="coords_json" id="coords_json" value="[]" />
      </div>

      <!-- Mode + Status -->
      <div class="row-2">
        <div class="field">
          <label>Modalità</label>
          <div class="checkbox-group">
            <label class="checkbox-label">
              <input name="mode_piedi" type="checkbox" value="on" class="checkbox" />
              <span class="checkbox-text">A piedi</span>
            </label>
            <label class="checkbox-label">
              <input name="mode_bici" type="checkbox" value="on" class="checkbox" />
              <span class="checkbox-text">In bici</span>
            </label>
          </div>
        </div>
        <div class="field">
          <label for="status">Stato</label>
          <select id="status" name="status">
            <option value="draft">Bozza</option>
            <option value="published">Pubblicato</option>
          </select>
        </div>
      </div>

      <!-- Body markdown -->
      <div class="field">
        <label for="body">Corpo (Markdown)</label>
        <div class="md-split">
          <textarea id="body" name="body" rows="10" class="mono"></textarea>
          <div id="md-preview" class="md-preview">
            <span class="preview-placeholder">Anteprima…</span>
          </div>
        </div>
      </div>

      <div class="form-footer">
        <a href="/management/itinerari" class="btn-cancel">Annulla</a>
        <button type="submit" class="btn-submit">Crea itinerario</button>
      </div>

    </form>
  </div>
</Management>

<script>
  import { marked } from 'marked';
  import L from 'leaflet';
  import 'leaflet/dist/leaflet.css';

  // ── Leaflet icon fix for Vite bundling ────────────────────────────────────
  const iconBase = 'https://unpkg.com/leaflet@1.9.4/dist/images/';
  L.Icon.Default.mergeOptions({
    iconRetinaUrl: iconBase + 'marker-icon-2x.png',
    iconUrl:       iconBase + 'marker-icon.png',
    shadowUrl:     iconBase + 'marker-shadow.png',
  });

  // ── Markdown preview ──────────────────────────────────────────────────────
  const bodyEl  = document.getElementById('body') as HTMLTextAreaElement;
  const preview = document.getElementById('md-preview');
  function updatePreview() {
    if (!preview) return;
    const text = bodyEl?.value ?? '';
    preview.innerHTML = text ? String(marked.parse(text)) : '<span class="preview-placeholder">Anteprima…</span>';
  }
  bodyEl?.addEventListener('input', updatePreview);

  // ── Slug auto-generation ──────────────────────────────────────────────────
  const titleEl = document.getElementById('title') as HTMLInputElement;
  const slugEl  = document.getElementById('slug') as HTMLInputElement;
  titleEl?.addEventListener('input', () => {
    if (slugEl && !slugEl.dataset.edited) {
      slugEl.value = titleEl.value
        .toLowerCase()
        .replace(/[àáâãäå]/g,'a').replace(/[èéêë]/g,'e').replace(/[ìíîï]/g,'i')
        .replace(/[òóôõö]/g,'o').replace(/[ùúûü]/g,'u').replace(/[^a-z0-9]+/g,'-')
        .replace(/^-+|-+$/g,'');
    }
  });
  slugEl?.addEventListener('input', () => { slugEl.dataset.edited = 'true'; });

  // ── Leaflet map ───────────────────────────────────────────────────────────
  const map = L.map('route-map').setView([44.935, 10.125], 13);
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
    maxZoom: 19,
  }).addTo(map);

  const coordsInput  = document.getElementById('coords_json') as HTMLInputElement;
  const countEl      = document.getElementById('waypoint-count')!;
  const clearBtn     = document.getElementById('clear-route')!;
  const markers: L.Marker[] = [];
  const polyline = L.polyline([], { color: '#D8A14A', weight: 3, opacity: 0.85 }).addTo(map);

  function makeIcon(n: number) {
    return L.divIcon({
      html: `<div class="wp-marker">${n}</div>`,
      className: '',
      iconSize: [26, 26],
      iconAnchor: [13, 13],
    });
  }

  function sync() {
    const coords = markers.map(m => {
      const ll = m.getLatLng();
      return [+ll.lat.toFixed(6), +ll.lng.toFixed(6)];
    });
    coordsInput.value = JSON.stringify(coords);
    countEl.textContent = `${coords.length} waypoint${coords.length !== 1 ? 's' : ''}`;
    polyline.setLatLngs(coords as [number, number][]);
    markers.forEach((m, i) => m.setIcon(makeIcon(i + 1)));
  }

  function addMarker(latlng: L.LatLng) {
    const marker = L.marker(latlng, { draggable: true, icon: makeIcon(markers.length + 1) }).addTo(map);
    marker.on('drag dragend', sync);
    marker.on('contextmenu', () => {
      map.removeLayer(marker);
      markers.splice(markers.indexOf(marker), 1);
      sync();
    });
    markers.push(marker);
    sync();
  }

  map.on('click', (e: L.LeafletMouseEvent) => addMarker(e.latlng));

  clearBtn.addEventListener('click', () => {
    markers.forEach(m => map.removeLayer(m));
    markers.length = 0;
    sync();
  });
</script>

<style>
  .form-page { max-width: 860px; display: flex; flex-direction: column; gap: 1.75rem; animation: page-in 0.4s cubic-bezier(0.22,1,0.36,1) both; }
  @keyframes page-in { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

  .form-header { display: flex; flex-direction: column; align-items: flex-start; gap: 0.4rem; padding-bottom: 1.5rem; border-bottom: 1px solid rgba(232,220,200,0.06); }
  .back-link { display: inline-flex; align-items: center; gap: 0.35rem; font-family: 'IBM Plex Mono', monospace; font-size: 0.72rem; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(232,220,200,0.35); text-decoration: none; transition: color 0.2s; flex-shrink: 0; }
  .back-link:hover { color: rgba(232,220,200,0.7); }
  .form-title { font-family: 'Fraunces', Georgia, serif; font-size: 1.9rem; font-weight: 300; color: #E8DCC8; letter-spacing: -0.01em; }

  .form-card { background: rgba(232,220,200,0.02); border: 1px solid rgba(232,220,200,0.07); border-radius: 8px; padding: 1.75rem; display: flex; flex-direction: column; gap: 1.5rem; }

  .field { display: flex; flex-direction: column; gap: 0.4rem; }
  .field label { font-family: 'IBM Plex Mono', monospace; font-size: 0.65rem; font-weight: 400; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(232,220,200,0.4); }
  .req { color: rgba(216,161,74,0.7); }

  .field input:not([type="checkbox"]),
  .field textarea,
  .field select {
    background: rgba(232,220,200,0.04);
    border: 1px solid rgba(232,220,200,0.10);
    border-radius: 4px;
    padding: 0.65rem 0.75rem;
    font-family: 'Fraunces', Georgia, serif;
    font-size: 0.95rem;
    font-weight: 300;
    color: #E8DCC8;
    outline: none;
    transition: border-color 0.2s, background 0.2s;
    width: 100%;
  }
  .field input.mono, .field textarea.mono { font-family: 'IBM Plex Mono', monospace; font-size: 0.82rem; }
  .field input::placeholder, .field textarea::placeholder { color: rgba(232,220,200,0.2); }
  .field input:not([type="checkbox"]):focus, .field textarea:focus, .field select:focus { border-color: rgba(216,161,74,0.45); background: rgba(232,220,200,0.06); }
  .field select option { background: #0D2220; }
  .hint { font-family: 'IBM Plex Mono', monospace; font-size: 0.62rem; color: rgba(232,220,200,0.25); letter-spacing: 0.03em; }

  /* Map */
  .map-header { display: flex; align-items: center; justify-content: space-between; gap: 1rem; }
  .map-meta { display: flex; align-items: center; gap: 0.75rem; }
  .wp-count { font-family: 'IBM Plex Mono', monospace; font-size: 0.68rem; letter-spacing: 0.12em; color: rgba(232,220,200,0.35); }
  .btn-clear { font-family: 'IBM Plex Mono', monospace; font-size: 0.68rem; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(224,123,90,0.55); background: none; border: 1px solid rgba(224,123,90,0.2); border-radius: 3px; padding: 0.25rem 0.65rem; cursor: pointer; transition: color 0.15s, border-color 0.15s; }
  .btn-clear:hover { color: #E07B5A; border-color: rgba(224,123,90,0.4); }
  .route-map { width: 100%; height: 400px; border-radius: 6px; overflow: hidden; border: 1px solid rgba(232,220,200,0.10); margin-top: 0.4rem; }

  /* Leaflet waypoint markers */
  :global(.wp-marker) {
    width: 26px; height: 26px;
    background: #D8A14A;
    border: 2px solid #1A0E00;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.7rem; font-weight: 500;
    color: #1A0E00;
    cursor: grab;
    box-shadow: 0 2px 6px rgba(0,0,0,0.45);
  }
  :global(.wp-marker:active) { cursor: grabbing; }
  :global(.leaflet-container) { background: #0f1e1c; }

  /* Markdown split */
  .md-split { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
  .md-preview { background: rgba(232,220,200,0.03); border: 1px solid rgba(232,220,200,0.08); border-radius: 4px; padding: 0.75rem; min-height: 200px; font-family: 'Fraunces', Georgia, serif; font-size: 0.9rem; font-weight: 300; color: rgba(232,220,200,0.7); line-height: 1.7; overflow-y: auto; }
  .preview-placeholder { font-family: 'IBM Plex Mono', monospace; font-size: 0.65rem; letter-spacing: 0.1em; color: rgba(232,220,200,0.18); }

  .row-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; }
  .row-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 2rem; }

  .checkbox-group { display: flex; gap: 1.25rem; padding: 0.65rem 0; }
  .checkbox-label { display: flex; align-items: center; gap: 0.6rem; cursor: pointer; }
  .checkbox { width: 16px !important; height: 16px !important; accent-color: #D8A14A; cursor: pointer; flex-shrink: 0; }
  .checkbox-text { font-family: 'IBM Plex Mono', monospace; font-size: 0.78rem; letter-spacing: 0.06em; color: rgba(232,220,200,0.6); }

  .form-footer { display: flex; justify-content: flex-end; gap: 0.75rem; padding-top: 0.5rem; border-top: 1px solid rgba(232,220,200,0.06); }
  .btn-cancel { padding: 0.6rem 1.1rem; background: none; border: 1px solid rgba(232,220,200,0.12); border-radius: 3px; color: rgba(232,220,200,0.45); font-family: 'IBM Plex Mono', monospace; font-size: 0.72rem; letter-spacing: 0.14em; text-transform: uppercase; text-decoration: none; transition: border-color 0.2s, color 0.2s; }
  .btn-cancel:hover { border-color: rgba(232,220,200,0.3); color: rgba(232,220,200,0.7); }
  .btn-submit { padding: 0.6rem 1.4rem; background: #D8A14A; border: none; border-radius: 3px; color: #1A0E00; font-family: 'IBM Plex Mono', monospace; font-size: 0.72rem; font-weight: 500; letter-spacing: 0.14em; text-transform: uppercase; cursor: pointer; transition: background 0.2s, transform 0.15s; }
  .btn-submit:hover { background: #E8B05A; transform: translateY(-1px); }

  @media (max-width: 700px) {
    .row-2, .row-3 { grid-template-columns: 1fr; }
    .md-split { grid-template-columns: 1fr; }
    .md-preview { min-height: 120px; }
    .route-map { height: 280px; }
  }
</style>
