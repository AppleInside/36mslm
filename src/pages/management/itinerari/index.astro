---
export const prerender = false;
import Management from '../../../layouts/Management.astro';
import { sql } from '../../../server/db';

const userDisplayName = Astro.locals.userDisplayName;

type ItineraryRow = {
  id: number;
  title: string;
  category: string;
  difficulty: string;
  distance_km: number | null;
  duration_min: number | null;
  status: 'draft' | 'published';
};

const itineraries = await sql<ItineraryRow[]>`
  SELECT id, title, category, difficulty, distance_km, duration_min, status
  FROM itineraries
  WHERE lang = 'it'
  ORDER BY id DESC
`;

const ok  = Astro.url.searchParams.get('ok');
const err = Astro.url.searchParams.get('err');

const categoryLabel: Record<string, string> = {
  naturalistico: 'Nat.',
  storico: 'Stor.',
  sportivo: 'Sport.',
};

const difficultyLabel: Record<string, string> = {
  facile: 'Facile',
  medio: 'Medio',
  impegnativo: 'Impegn.',
};
---

<Management title="Itinerari" userDisplayName={userDisplayName}>

  <div class="page">

    <div class="page-header">
      <div>
        <h1 class="page-title">Itinerari</h1>
        <p class="page-count">
          {itineraries.length === 0 ? 'Nessun itinerario' : `${itineraries.length} ${itineraries.length === 1 ? 'itinerario' : 'itinerari'}`}
        </p>
      </div>
      <a href="/management/itinerari/nuovo" class="btn-primary">
        <svg width="11" height="11" viewBox="0 0 11 11" fill="none" aria-hidden="true">
          <path d="M5.5 1V10M1 5.5H10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        Nuovo itinerario
      </a>
    </div>

    {ok && (
      <div class="flash flash--ok" role="status">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <circle cx="7" cy="7" r="6.5" stroke="currentColor"/>
          <path d="M4.5 7L6.5 9L9.5 5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Operazione completata con successo.
      </div>
    )}
    {err && (
      <div class="flash flash--err" role="alert">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <circle cx="7" cy="7" r="6.5" stroke="currentColor"/>
          <line x1="7" y1="4" x2="7" y2="7.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
          <circle cx="7" cy="9.5" r="0.75" fill="currentColor"/>
        </svg>
        Si è verificato un errore. Riprova.
      </div>
    )}

    {itineraries.length === 0 && (
      <div class="empty">
        <svg class="empty-icon" width="52" height="52" viewBox="0 0 52 52" fill="none" aria-hidden="true">
          <path d="M8 40C8 40 16 24 26 18C36 12 44 10 44 10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>
          <circle cx="14" cy="36" r="3" stroke="currentColor" stroke-width="1.4"/>
          <circle cx="38" cy="16" r="3" stroke="currentColor" stroke-width="1.4"/>
        </svg>
        <p class="empty-title">Nessun itinerario ancora</p>
        <p class="empty-sub">Aggiungi il primo percorso del territorio.</p>
        <a href="/management/itinerari/nuovo" class="btn-primary">Crea itinerario</a>
      </div>
    )}

    {itineraries.length > 0 && (
      <div class="table-wrap">
        <table class="table">
          <thead>
            <tr>
              <th>Titolo</th>
              <th class="hide-md">Categoria</th>
              <th class="hide-md">Difficoltà</th>
              <th class="hide-sm">Distanza</th>
              <th>Stato</th>
              <th class="th-actions">Azioni</th>
            </tr>
          </thead>
          <tbody>
            {itineraries.map((it, i) => (
              <tr style={`--i:${i}`}>
                <td><span class="ev-title">{it.title}</span></td>
                <td class="hide-md">
                  <span class="badge badge--dim">{categoryLabel[it.category] ?? it.category}</span>
                </td>
                <td class="hide-md">
                  <span class={`badge badge--diff-${it.difficulty}`}>{difficultyLabel[it.difficulty] ?? it.difficulty}</span>
                </td>
                <td class="hide-sm">
                  <span class="ev-meta">
                    {it.distance_km != null ? `${it.distance_km} km` : '—'}
                    {it.duration_min != null ? ` · ${it.duration_min} min` : ''}
                  </span>
                </td>
                <td>
                  {it.status === 'published'
                    ? <span class="badge badge--teal">Pubblicato</span>
                    : <span class="badge badge--dim">Bozza</span>
                  }
                </td>
                <td>
                  <div class="row-actions">
                    <a href={`/management/itinerari/${it.id}`} class="act-edit" title="Modifica">
                      <svg width="18" height="18" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                        <path d="M9.5 2.5L11.5 4.5L5 11H3V9L9.5 2.5Z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/>
                        <path d="M8 4L10 6" stroke="currentColor" stroke-width="1.2"/>
                      </svg>
                    </a>
                    <form
                      method="POST"
                      action={`/api/management/itinerari/${it.id}/delete`}
                      class="delete-form"
                      data-title={it.title}
                    >
                      <button type="button" class="act-delete" title="Elimina" data-delete-trigger>
                        <svg width="18" height="18" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                          <path d="M2 4H12M5 4V2.5C5 2.22 5.22 2 5.5 2H8.5C8.78 2 9 2.22 9 2.5V4M5.5 6.5V10.5M8.5 6.5V10.5M3 4L3.6 11.5C3.63 11.8 3.88 12 4.18 12H9.82C10.12 12 10.37 11.8 10.4 11.5L11 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}

  </div>

  <div id="delete-modal" class="modal-backdrop" aria-hidden="true">
    <div class="modal" role="dialog" aria-modal="true" aria-labelledby="modal-title">
      <div class="modal-icon">
        <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
          <path d="M3 7H19M8 7V5C8 4.45 8.45 4 9 4H13C13.55 4 14 4.45 14 5V7M9 11V16M13 11V16M4.5 7L5.4 18C5.45 18.56 5.92 19 6.5 19H15.5C16.08 19 16.55 18.56 16.6 18L17.5 7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <div class="modal-body">
        <h2 class="modal-title" id="modal-title">Elimina itinerario</h2>
        <p class="modal-text">
          Stai per eliminare <strong id="modal-item-name"></strong>. L'operazione non può essere annullata.
        </p>
      </div>
      <div class="modal-actions">
        <button type="button" class="modal-cancel" id="modal-cancel">Annulla</button>
        <button type="button" class="modal-confirm" id="modal-confirm">Elimina</button>
      </div>
    </div>
  </div>

</Management>

<script>
  let pendingForm: HTMLFormElement | null = null;
  const modal      = document.getElementById('delete-modal')!;
  const nameEl     = document.getElementById('modal-item-name')!;
  const cancelBtn  = document.getElementById('modal-cancel')!;
  const confirmBtn = document.getElementById('modal-confirm')!;

  function openModal(form: HTMLFormElement) {
    pendingForm = form;
    nameEl.textContent = form.dataset.title ?? 'questo itinerario';
    modal.setAttribute('aria-hidden', 'false');
    modal.classList.add('is-open');
    cancelBtn.focus();
  }
  function closeModal() {
    pendingForm = null;
    modal.setAttribute('aria-hidden', 'true');
    modal.classList.remove('is-open');
  }

  document.querySelectorAll<HTMLButtonElement>('[data-delete-trigger]').forEach(btn => {
    btn.addEventListener('click', () => {
      const form = btn.closest<HTMLFormElement>('.delete-form');
      if (form) openModal(form);
    });
  });
  cancelBtn.addEventListener('click', closeModal);
  confirmBtn.addEventListener('click', () => { pendingForm?.submit(); closeModal(); });
  modal.addEventListener('click', e => { if (e.target === modal) closeModal(); });
  document.addEventListener('keydown', e => { if (e.key === 'Escape' && modal.classList.contains('is-open')) closeModal(); });

  document.querySelectorAll<HTMLElement>('.flash').forEach(el => {
    setTimeout(() => {
      el.style.transition = 'opacity 0.5s, transform 0.5s';
      el.style.opacity = '0';
      el.style.transform = 'translateY(-4px)';
      setTimeout(() => el.remove(), 500);
    }, 4000);
  });
</script>

<style>
  .page { display: flex; flex-direction: column; gap: 1.5rem; animation: page-in 0.45s cubic-bezier(0.22,1,0.36,1) both; }
  @keyframes page-in { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

  .page-header { display: flex; align-items: flex-end; justify-content: space-between; gap: 1rem; padding-bottom: 1.5rem; border-bottom: 1px solid rgba(232,220,200,0.06); }
  .page-title { font-family: 'Fraunces', Georgia, serif; font-size: 2.1rem; font-weight: 300; color: #E8DCC8; line-height: 1; letter-spacing: -0.01em; }
  .page-count { margin-top: 0.4rem; font-family: 'IBM Plex Mono', monospace; font-size: 0.72rem; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(232,220,200,0.3); }

  .btn-primary { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.65rem 1.25rem; background: #D8A14A; color: #1A0E00; font-family: 'IBM Plex Mono', monospace; font-size: 0.78rem; font-weight: 500; letter-spacing: 0.14em; text-transform: uppercase; text-decoration: none; border: none; border-radius: 3px; cursor: pointer; white-space: nowrap; transition: background 0.2s, transform 0.15s; }
  .btn-primary:hover { background: #E8B05A; transform: translateY(-1px); }

  .flash { display: flex; align-items: center; gap: 0.55rem; padding: 0.75rem 1rem; border-radius: 4px; border: 1px solid; font-family: 'IBM Plex Mono', monospace; font-size: 0.85rem; letter-spacing: 0.03em; }
  .flash--ok  { color: #7BC4B4; background: rgba(74,102,112,0.1); border-color: rgba(74,102,112,0.28); }
  .flash--err { color: #E07B5A; background: rgba(224,123,90,0.07); border-color: rgba(224,123,90,0.22); }

  .empty { display: flex; flex-direction: column; align-items: center; gap: 0.8rem; padding: 4rem 2rem; text-align: center; }
  .empty-icon { color: rgba(232,220,200,0.15); margin-bottom: 0.5rem; }
  .empty-title { font-family: 'Fraunces', Georgia, serif; font-size: 1.35rem; font-weight: 300; color: rgba(232,220,200,0.5); }
  .empty-sub { font-family: 'IBM Plex Mono', monospace; font-size: 0.82rem; letter-spacing: 0.04em; color: rgba(232,220,200,0.28); max-width: 300px; line-height: 1.65; margin-bottom: 0.5rem; }

  .table-wrap { border: 1px solid rgba(232,220,200,0.07); border-radius: 6px; overflow: hidden; background: rgba(232,220,200,0.015); }
  .table { width: 100%; border-collapse: collapse; font-family: 'IBM Plex Mono', monospace; }
  .table thead tr { background: rgba(232,220,200,0.04); border-bottom: 1px solid rgba(232,220,200,0.07); }
  .table th { padding: 0.75rem 1rem; text-align: left; font-size: 0.68rem; font-weight: 400; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(232,220,200,0.3); white-space: nowrap; border-right: 1px solid rgba(232,220,200,0.06); }
  .table th:last-child { border-right: none; }
  .th-actions { text-align: right; }
  .table tbody tr { border-bottom: 1px solid rgba(232,220,200,0.04); transition: background 0.18s; animation: row-in 0.4s cubic-bezier(0.22,1,0.36,1) both; animation-delay: calc(var(--i, 0) * 40ms + 80ms); }
  @keyframes row-in { from { opacity: 0; transform: translateX(-6px); } to { opacity: 1; transform: translateX(0); } }
  .table tbody tr:last-child { border-bottom: none; }
  .table tbody tr:hover { background: rgba(74,102,112,0.10); }
  .table td { padding: 0.9rem 1rem; vertical-align: middle; border-right: 1px solid rgba(232,220,200,0.04); }
  .table td:last-child { border-right: none; }

  .ev-title { font-family: 'Fraunces', Georgia, serif; font-size: 1.05rem; font-weight: 300; color: #E8DCC8; letter-spacing: 0.01em; }
  .ev-meta { font-size: 0.82rem; color: rgba(232,220,200,0.4); letter-spacing: 0.02em; }

  .badge { display: inline-flex; align-items: center; padding: 0.25rem 0.65rem; border-radius: 20px; font-size: 0.68rem; font-weight: 400; letter-spacing: 0.12em; text-transform: uppercase; border: 1px solid; white-space: nowrap; }
  .badge--teal { background: rgba(74,102,112,0.18); color: #7BC4B4; border-color: rgba(74,102,112,0.32); }
  .badge--dim  { background: rgba(232,220,200,0.04); color: rgba(232,220,200,0.38); border-color: rgba(232,220,200,0.10); }
  .badge--diff-facile      { background: rgba(123,196,180,0.10); color: #7BC4B4; border-color: rgba(123,196,180,0.25); }
  .badge--diff-medio       { background: rgba(216,161,74,0.10); color: #D8A14A; border-color: rgba(216,161,74,0.25); }
  .badge--diff-impegnativo { background: rgba(224,123,90,0.10); color: #E07B5A; border-color: rgba(224,123,90,0.25); }

  .row-actions { display: flex; align-items: center; justify-content: flex-end; gap: 0.4rem; }
  .act-edit, .act-delete { display: flex; align-items: center; justify-content: center; width: 38px; height: 38px; border-radius: 5px; border: 1px solid transparent; background: none; cursor: pointer; font-family: inherit; padding: 0; transition: background 0.18s, border-color 0.18s, color 0.18s; }
  .act-edit { color: rgba(216,161,74,0.55); text-decoration: none; }
  .act-edit:hover { color: #D8A14A; background: rgba(216,161,74,0.10); border-color: rgba(216,161,74,0.22); }
  .act-delete { color: rgba(224,123,90,0.45); }
  .act-delete:hover { color: #E07B5A; background: rgba(224,123,90,0.10); border-color: rgba(224,123,90,0.22); }

  @media (max-width: 900px) { .hide-md { display: none; } }
  @media (max-width: 600px) { .hide-sm { display: none; } .page-title { font-size: 1.6rem; } }

  .modal-backdrop { position: fixed; inset: 0; background: rgba(11,25,24,0.75); backdrop-filter: blur(3px); display: flex; align-items: center; justify-content: center; z-index: 999; opacity: 0; pointer-events: none; transition: opacity 0.2s; }
  .modal-backdrop.is-open { opacity: 1; pointer-events: auto; }
  .modal { background: #111f1e; border: 1px solid rgba(232,220,200,0.1); border-radius: 8px; padding: 1.75rem; width: 100%; max-width: 400px; margin: 1rem; display: flex; flex-direction: column; gap: 1.25rem; box-shadow: 0 24px 64px rgba(0,0,0,0.5); transform: translateY(8px) scale(0.98); transition: transform 0.22s cubic-bezier(0.22,1,0.36,1); }
  .modal-backdrop.is-open .modal { transform: translateY(0) scale(1); }
  .modal-icon { width: 42px; height: 42px; border-radius: 6px; background: rgba(224,123,90,0.10); border: 1px solid rgba(224,123,90,0.20); display: flex; align-items: center; justify-content: center; color: #E07B5A; flex-shrink: 0; }
  .modal-body { display: flex; flex-direction: column; gap: 0.5rem; }
  .modal-title { font-family: 'Fraunces', Georgia, serif; font-size: 1.2rem; font-weight: 300; color: #E8DCC8; letter-spacing: -0.01em; }
  .modal-text { font-family: 'IBM Plex Mono', monospace; font-size: 0.8rem; line-height: 1.65; letter-spacing: 0.02em; color: rgba(232,220,200,0.45); }
  .modal-text strong { color: rgba(232,220,200,0.75); font-weight: 400; }
  .modal-actions { display: flex; justify-content: flex-end; gap: 0.5rem; }
  .modal-cancel { padding: 0.6rem 1rem; background: none; border: 1px solid rgba(232,220,200,0.12); border-radius: 4px; font-family: 'IBM Plex Mono', monospace; font-size: 0.72rem; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(232,220,200,0.4); cursor: pointer; transition: border-color 0.15s, color 0.15s, background 0.15s; }
  .modal-cancel:hover { border-color: rgba(232,220,200,0.25); color: rgba(232,220,200,0.7); background: rgba(232,220,200,0.04); }
  .modal-confirm { padding: 0.6rem 1.1rem; background: rgba(224,123,90,0.15); border: 1px solid rgba(224,123,90,0.30); border-radius: 4px; font-family: 'IBM Plex Mono', monospace; font-size: 0.72rem; letter-spacing: 0.1em; text-transform: uppercase; color: #E07B5A; cursor: pointer; transition: background 0.15s, border-color 0.15s; }
  .modal-confirm:hover { background: rgba(224,123,90,0.25); border-color: rgba(224,123,90,0.50); }
</style>
