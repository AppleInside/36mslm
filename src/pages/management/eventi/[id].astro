---
export const prerender = false;
import Management from '../../../layouts/Management.astro';
import { sql } from '../../../server/db';

const userDisplayName = Astro.locals.userDisplayName;
const { id } = Astro.params;
const ok  = Astro.url.searchParams.get('ok');
const err = Astro.url.searchParams.get('err');

type EventRow = {
  id: number; title: string; slug: string; date: Date;
  time_start: string | null; time_end: string | null;
  location: string | null; description: string | null;
  cover_url: string | null; signup_required: boolean;
  status: 'draft' | 'published';
};

const rows = await sql<EventRow[]>`
  SELECT id, title, slug, date, time_start, time_end, location, description, cover_url, signup_required, status
  FROM events WHERE id = ${Number(id)} AND lang = 'it' LIMIT 1
`;
const event = rows[0];
if (!event) return Astro.redirect('/management/eventi?err=1', 302);

const dateStr = event.date instanceof Date
  ? event.date.toISOString().slice(0, 10)
  : String(event.date).slice(0, 10);
const timeStart = event.time_start?.slice(0, 5) ?? '';
const timeEnd = event.time_end?.slice(0, 5) ?? '';
---
<Management title={`Modifica: ${event.title}`} userDisplayName={userDisplayName}>
  <div class="max-w-2xl mx-auto">

    <div class="flex items-center gap-3 mb-8">
      <a href="/management/eventi" class="text-sm text-testo/50 hover:text-testo transition-colors">← Lista eventi</a>
      <span class="text-testo/20">/</span>
      <h1 class="font-serif text-2xl font-medium">Modifica evento</h1>
    </div>

    {ok === 'saved' && (
      <div class="mb-6 flex items-center gap-2 px-4 py-3 rounded-lg border border-teal-500/30 bg-teal-500/10 text-teal-600 text-sm">
        Modifiche salvate con successo.
      </div>
    )}
    {err === 'notfound' && (
      <div class="mb-6 flex items-center gap-2 px-4 py-3 rounded-lg border border-red-400/30 bg-red-400/10 text-red-500 text-sm">
        Errore: l'evento non è stato trovato nel database. Nessuna modifica applicata.
      </div>
    )}
    {err === 'db' && (
      <div class="mb-6 flex items-center gap-2 px-4 py-3 rounded-lg border border-red-400/30 bg-red-400/10 text-red-500 text-sm">
        Errore database. Riprova.
      </div>
    )}

    <form
      method="POST"
      action={`/api/management/eventi/${event.id}/update`}
      enctype="multipart/form-data"
      class="flex flex-col gap-0"
    >

      <!-- Sezione: Informazioni principali -->
      <section class="bg-white rounded-xl shadow-sm border border-argento p-6 flex flex-col gap-6">
        <h2 class="text-xs font-semibold uppercase tracking-widest text-testo/40">Informazioni principali</h2>

        <div class="flex flex-col gap-1.5">
          <label for="title" class="text-sm font-medium">Titolo <span class="text-red-500">*</span></label>
          <input id="title" name="title" type="text" required value={event.title}
            class="border border-argento rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-pioppo" />
        </div>

        <div class="flex flex-col gap-1.5">
          <label for="slug" class="text-sm font-medium">Slug <span class="text-red-500">*</span></label>
          <input id="slug" name="slug" type="text" required pattern="[a-z0-9-]+" value={event.slug}
            class="border border-argento rounded-lg px-3 py-2.5 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-pioppo" />
          <p class="text-xs text-testo/40">⚠ Modificare lo slug rompe i link esistenti.</p>
        </div>

        <div class="flex flex-col gap-1.5">
          <label for="location" class="text-sm font-medium">Luogo</label>
          <input id="location" name="location" type="text" value={event.location ?? ''}
            placeholder="es. Piazza del Municipio, Polesine Parmense"
            class="border border-argento rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-pioppo" />
        </div>
      </section>

      <!-- Sezione: Data e orari -->
      <section class="bg-white rounded-xl shadow-sm border border-argento border-t-0 p-6 flex flex-col gap-6">
        <h2 class="text-xs font-semibold uppercase tracking-widest text-testo/40">Data e orari</h2>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
          <div class="flex flex-col gap-1.5">
            <label for="date" class="text-sm font-medium">Data <span class="text-red-500">*</span></label>
            <input id="date" name="date" type="date" required value={dateStr}
              class="border border-argento rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-pioppo" />
          </div>
          <div class="flex flex-col gap-1.5">
            <label for="time_start" class="text-sm font-medium">Ora inizio</label>
            <input id="time_start" name="time_start" type="time" value={timeStart}
              class="border border-argento rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-pioppo" />
          </div>
          <div class="flex flex-col gap-1.5">
            <label for="time_end" class="text-sm font-medium">Ora fine</label>
            <input id="time_end" name="time_end" type="time" value={timeEnd}
              class="border border-argento rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-pioppo" />
          </div>
        </div>
      </section>

      <!-- Sezione: Contenuto -->
      <section class="bg-white rounded-xl shadow-sm border border-argento border-t-0 p-6 flex flex-col gap-6">
        <h2 class="text-xs font-semibold uppercase tracking-widest text-testo/40">Contenuto</h2>

        <div class="flex flex-col gap-1.5">
          <div class="flex items-center justify-between">
            <label for="description" class="text-sm font-medium">Descrizione</label>
            <span class="text-xs text-testo/40">Markdown supportato</span>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
            <textarea id="description" name="description" rows="10"
              class="border border-argento rounded-lg px-3 py-2.5 text-sm font-mono focus:outline-none focus:ring-2 focus:ring-pioppo resize-y"
            >{event.description ?? ''}</textarea>
            <div id="md-preview"
              class="border border-argento rounded-lg px-3 py-2.5 text-sm prose prose-sm max-w-none min-h-[10rem] bg-sabbia/40 overflow-auto">
            </div>
          </div>
        </div>

        <div class="flex flex-col gap-1.5">
          <label for="cover" class="text-sm font-medium">Immagine copertina</label>
          {event.cover_url && (
            <p class="text-xs text-testo/50">
              Immagine attuale: <a href={event.cover_url} target="_blank" class="text-pioppo hover:underline">visualizza →</a>
            </p>
          )}
          <input id="cover" name="cover" type="file" accept="image/*"
            class="text-sm file:mr-3 file:px-3 file:py-1.5 file:rounded-md file:border-0 file:bg-pioppo/10 file:text-pioppo file:text-sm file:cursor-pointer hover:file:bg-pioppo/20 transition-colors" />
          <p class="text-xs text-testo/40">Lascia vuoto per mantenere l'immagine attuale. Max 5 MB.</p>
        </div>
      </section>

      <!-- Sezione: Impostazioni -->
      <section class="bg-white rounded-xl shadow-sm border border-argento border-t-0 p-6 flex flex-col gap-6">
        <h2 class="text-xs font-semibold uppercase tracking-widest text-testo/40">Impostazioni</h2>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 items-start">
          <div class="flex flex-col gap-1.5">
            <label for="status" class="text-sm font-medium">Stato pubblicazione</label>
            <select id="status" name="status"
              class="border border-argento rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-pioppo bg-white">
              <option value="draft" selected={event.status === 'draft'}>Bozza</option>
              <option value="published" selected={event.status === 'published'}>Pubblicato</option>
            </select>
          </div>

          <div class="flex flex-col gap-1.5 sm:pt-6">
            <label class="flex items-center gap-3 cursor-pointer select-none group">
              <input name="signup_required" type="checkbox" value="on"
                checked={event.signup_required}
                class="w-4 h-4 rounded accent-pioppo" />
              <span class="text-sm font-medium">Iscrizioni richieste</span>
            </label>
            <p class="text-xs text-testo/40 ml-7">Abilita il form di iscrizione sulla pagina dell'evento.</p>
          </div>
        </div>
      </section>

      <!-- Azioni -->
      <div class="flex justify-end gap-3 pt-5">
        <a href="/management/eventi"
          class="px-5 py-2.5 text-sm rounded-lg border border-argento hover:bg-argento/30 transition-colors">
          Annulla
        </a>
        <button type="submit"
          class="px-5 py-2.5 text-sm font-medium bg-pioppo hover:bg-pioppo/90 text-white rounded-lg transition-colors shadow-sm">
          Salva modifiche
        </button>
      </div>

    </form>
  </div>
</Management>

<script>
  import { marked } from 'marked';

  const descTextarea = document.getElementById('description') as HTMLTextAreaElement;
  const preview = document.getElementById('md-preview');

  function updatePreview() {
    if (!preview) return;
    const text = descTextarea?.value ?? '';
    preview.innerHTML = text ? String(marked.parse(text)) : '<span class="text-testo/30 text-xs">Anteprima...</span>';
  }

  descTextarea?.addEventListener('input', updatePreview);
  updatePreview();
</script>
