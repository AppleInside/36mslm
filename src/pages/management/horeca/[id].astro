---
export const prerender = false;
import Management from '../../../layouts/Management.astro';
import { sql } from '../../../server/db';

const userDisplayName = Astro.locals.userDisplayName;
const { id } = Astro.params;

type PlaceRow = {
  id: number;
  title: string;
  slug: string;
  kind: string;
  address: string;
  phone: string | null;
  website: string | null;
  tripadvisor: string | null;
  michelin: string | null;
  tags: string[];
  body: string | null;
  status: 'draft' | 'published';
};

const rows = await sql<PlaceRow[]>`
  SELECT id, title, slug, kind, address, phone, website, tripadvisor, michelin, tags, body, status
  FROM places WHERE id = ${Number(id)} AND lang = 'it' LIMIT 1
`;
const p = rows[0];
if (!p) return Astro.redirect('/management/horeca?err=1', 302);

const tagsStr = (p.tags ?? []).join(', ');
---

<Management title={`Modifica: ${p.title}`} userDisplayName={userDisplayName}>
  <div class="form-page">

    <div class="form-header">
      <a href="/management/horeca" class="back-link">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M9 2L4 7L9 12" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Horeca
      </a>
      <h1 class="form-title">Modifica posto</h1>
    </div>

    <form method="POST" action={`/api/management/horeca/${p.id}/update`} class="form-card">

      <!-- Nome · Slug -->
      <div class="row-3c">
        <div class="field span-2">
          <label for="title">Nome <span class="req">*</span></label>
          <input id="title" name="title" type="text" required value={p.title} autocomplete="off" />
        </div>
        <div class="field">
          <label for="slug">Slug <span class="req">*</span></label>
          <input id="slug" name="slug" type="text" required pattern="[a-z0-9-]+" value={p.slug} class="mono" autocomplete="off" />
          <span class="hint">Modificare lo slug rompe i link esistenti.</span>
        </div>
      </div>

      <!-- Indirizzo · Telefono -->
      <div class="row-3c">
        <div class="field span-2">
          <label for="address">Indirizzo</label>
          <input id="address" name="address" type="text" value={p.address} autocomplete="off" />
        </div>
        <div class="field">
          <label for="phone">Telefono</label>
          <input id="phone" name="phone" type="text" value={p.phone ?? ''} autocomplete="off" />
        </div>
      </div>

      <!-- Tipo · Sito web · TripAdvisor · Stato -->
      <div class="row-4c">
        <div class="field">
          <label for="kind">Tipo <span class="req">*</span></label>
          <select id="kind" name="kind">
            <option value="ristorante"  selected={p.kind === 'ristorante'}>Ristorante</option>
            <option value="agriturismo" selected={p.kind === 'agriturismo'}>Agriturismo</option>
            <option value="b&b"         selected={p.kind === 'b&b'}>B&amp;B</option>
            <option value="azienda"     selected={p.kind === 'azienda'}>Azienda</option>
            <option value="altro"       selected={p.kind === 'altro'}>Altro</option>
          </select>
        </div>
        <div class="field">
          <label for="website">Sito web</label>
          <input id="website" name="website" type="text" value={p.website ?? ''} placeholder="https://…" autocomplete="off" />
        </div>
        <div class="field">
          <label for="tripadvisor">TripAdvisor</label>
          <input id="tripadvisor" name="tripadvisor" type="text" value={p.tripadvisor ?? ''} placeholder="https://tripadvisor.com/…" autocomplete="off" />
        </div>
        <div class="field">
          <label for="status">Stato</label>
          <select id="status" name="status">
            <option value="draft"     selected={p.status === 'draft'}>Bozza</option>
            <option value="published" selected={p.status === 'published'}>Pubblicato</option>
          </select>
        </div>
      </div>

      <!-- Michelin -->
      <div class="field">
        <label>Guida Michelin</label>
        <div class="michelin-picker">
          <label class="mpick-option">
            <input type="radio" name="michelin" value="" checked={!p.michelin} />
            <span class="mpick-content"><span class="mpick-none">—</span></span>
            <span class="mpick-label">Nessuna</span>
          </label>
          <label class="mpick-option">
            <input type="radio" name="michelin" value="listed" checked={p.michelin === 'listed'} />
            <span class="mpick-content">
              <img src="/icons/michelin-guide.png" class="mpick-img" alt="" />
            </span>
            <span class="mpick-label">In Guida</span>
          </label>
          <label class="mpick-option">
            <input type="radio" name="michelin" value="1" checked={p.michelin === '1'} />
            <span class="mpick-content">
              <img src="/icons/michelin-star.png" class="mpick-img" alt="" />
            </span>
            <span class="mpick-label">1 stella</span>
          </label>
          <label class="mpick-option">
            <input type="radio" name="michelin" value="2" checked={p.michelin === '2'} />
            <span class="mpick-content">
              <img src="/icons/michelin-star.png" class="mpick-img" alt="" />
              <img src="/icons/michelin-star.png" class="mpick-img mpick-img-sm" alt="" />
            </span>
            <span class="mpick-label">2 stelle</span>
          </label>
          <label class="mpick-option">
            <input type="radio" name="michelin" value="3" checked={p.michelin === '3'} />
            <span class="mpick-content">
              <img src="/icons/michelin-star.png" class="mpick-img mpick-img-sm" alt="" />
              <img src="/icons/michelin-star.png" class="mpick-img mpick-img-sm" alt="" />
              <img src="/icons/michelin-star.png" class="mpick-img mpick-img-sm" alt="" />
            </span>
            <span class="mpick-label">3 stelle</span>
          </label>
        </div>
      </div>

      <!-- Tag -->
      <div class="field">
        <label for="tags">Tag</label>
        <input id="tags" name="tags" type="text" value={tagsStr} placeholder="culatello, tradizione, po" autocomplete="off" />
        <span class="hint">Separati da virgola.</span>
      </div>

      <!-- Corpo markdown -->
      <div class="field">
        <label for="body">Descrizione (Markdown)</label>
        <div class="md-split">
          <textarea id="body" name="body" rows="10" class="mono">{p.body ?? ''}</textarea>
          <div id="md-preview" class="md-preview">
            <span class="preview-placeholder">Anteprima…</span>
          </div>
        </div>
      </div>

      <div class="form-footer">
        <a href="/management/horeca" class="btn-cancel">Annulla</a>
        <button type="submit" class="btn-submit">Salva modifiche</button>
      </div>

    </form>
  </div>
</Management>

<script>
  import { marked } from 'marked';
  const bodyEl  = document.getElementById('body') as HTMLTextAreaElement;
  const preview = document.getElementById('md-preview');

  function updatePreview() {
    if (!preview) return;
    const text = bodyEl?.value ?? '';
    preview.innerHTML = text
      ? String(marked.parse(text))
      : '<span class="preview-placeholder">Anteprima…</span>';
  }
  bodyEl?.addEventListener('input', updatePreview);
  updatePreview();
</script>

<style>
  .form-page { max-width: 920px; display: flex; flex-direction: column; gap: 1.75rem; animation: page-in 0.4s cubic-bezier(0.22,1,0.36,1) both; }
  @keyframes page-in { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

  .form-header { display: flex; flex-direction: column; align-items: flex-start; gap: 0.4rem; padding-bottom: 1.5rem; border-bottom: 1px solid rgba(232,220,200,0.06); }
  .back-link { display: inline-flex; align-items: center; gap: 0.35rem; font-family: 'IBM Plex Mono', monospace; font-size: 0.72rem; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(232,220,200,0.35); text-decoration: none; transition: color 0.2s; flex-shrink: 0; }
  .back-link:hover { color: rgba(232,220,200,0.7); }
  .form-title { font-family: 'Fraunces', Georgia, serif; font-size: 1.9rem; font-weight: 300; color: #E8DCC8; letter-spacing: -0.01em; }

  .form-card { background: rgba(232,220,200,0.02); border: 1px solid rgba(232,220,200,0.07); border-radius: 8px; padding: 1.75rem; display: flex; flex-direction: column; gap: 1.75rem; }

  .field { display: flex; flex-direction: column; gap: 0.4rem; }
  .field label { font-family: 'IBM Plex Mono', monospace; font-size: 0.65rem; font-weight: 400; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(232,220,200,0.4); }
  .req { color: rgba(216,161,74,0.7); }

  .field input,
  .field textarea,
  .field select {
    background: rgba(232,220,200,0.04);
    border: 1px solid rgba(232,220,200,0.10);
    border-radius: 4px;
    padding: 0.65rem 0.75rem;
    font-family: 'Fraunces', Georgia, serif;
    font-size: 0.95rem;
    font-weight: 300;
    color: #E8DCC8;
    outline: none;
    transition: border-color 0.2s, background 0.2s;
    width: 100%;
  }
  .field input.mono, .field textarea.mono { font-family: 'IBM Plex Mono', monospace; font-size: 0.82rem; }
  .field input::placeholder, .field textarea::placeholder { color: rgba(232,220,200,0.2); }
  .field input:focus, .field textarea:focus, .field select:focus { border-color: rgba(216,161,74,0.45); background: rgba(232,220,200,0.06); }
  .field select option { background: #0D2220; }
  .hint { font-family: 'IBM Plex Mono', monospace; font-size: 0.62rem; color: rgba(232,220,200,0.25); letter-spacing: 0.03em; }

  /* Grid layouts */
  .row-3c { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 2rem; align-items: start; }
  .row-4c { display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 2rem; align-items: start; }
  .span-2 { grid-column: span 2; }

  .md-split { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
  .md-preview { background: rgba(232,220,200,0.03); border: 1px solid rgba(232,220,200,0.08); border-radius: 4px; padding: 0.75rem; min-height: 200px; font-family: 'Fraunces', Georgia, serif; font-size: 0.9rem; font-weight: 300; color: rgba(232,220,200,0.7); line-height: 1.7; overflow-y: auto; }
  .preview-placeholder { font-family: 'IBM Plex Mono', monospace; font-size: 0.65rem; letter-spacing: 0.1em; color: rgba(232,220,200,0.18); }

  .form-footer { display: flex; justify-content: flex-end; gap: 0.75rem; padding-top: 0.5rem; border-top: 1px solid rgba(232,220,200,0.06); }
  .btn-cancel { padding: 0.6rem 1.1rem; background: none; border: 1px solid rgba(232,220,200,0.12); border-radius: 3px; color: rgba(232,220,200,0.45); font-family: 'IBM Plex Mono', monospace; font-size: 0.72rem; letter-spacing: 0.14em; text-transform: uppercase; text-decoration: none; transition: border-color 0.2s, color 0.2s; }
  .btn-cancel:hover { border-color: rgba(232,220,200,0.3); color: rgba(232,220,200,0.7); }
  .btn-submit { padding: 0.6rem 1.4rem; background: #D8A14A; border: none; border-radius: 3px; color: #1A0E00; font-family: 'IBM Plex Mono', monospace; font-size: 0.72rem; font-weight: 500; letter-spacing: 0.14em; text-transform: uppercase; cursor: pointer; transition: background 0.2s, transform 0.15s; }
  .btn-submit:hover { background: #E8B05A; transform: translateY(-1px); }

  /* ── Michelin picker ── */
  .michelin-picker { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .mpick-option {
    display: flex; flex-direction: column; align-items: center; gap: 0.4rem;
    padding: 0.7rem 1rem 0.6rem;
    background: rgba(232,220,200,0.03);
    border: 1px solid rgba(232,220,200,0.10);
    border-radius: 6px; cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
    min-width: 80px;
  }
  .mpick-option:has(input:checked) {
    border-color: rgba(226,35,26,0.55);
    background: rgba(226,35,26,0.07);
  }
  .mpick-option input[type="radio"] { display: none; }
  .mpick-content {
    display: flex; align-items: center; gap: 2px;
    height: 26px;
  }
  .mpick-img { width: 22px; height: 22px; object-fit: contain; display: block; }
  .mpick-img-sm { width: 16px; height: 16px; }
  .mpick-none {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 1rem; color: rgba(232,220,200,0.2);
    line-height: 1;
  }
  .mpick-label {
    font-family: 'IBM Plex Mono', monospace; font-size: 0.57rem;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: rgba(232,220,200,0.35);
  }
  .mpick-option:has(input:checked) .mpick-label { color: rgba(226,35,26,0.85); }

  @media (max-width: 800px) {
    .row-3c, .row-4c { grid-template-columns: 1fr 1fr; }
    .span-2 { grid-column: span 2; }
  }
  @media (max-width: 560px) {
    .row-3c, .row-4c { grid-template-columns: 1fr; }
    .span-2 { grid-column: span 1; }
    .md-split { grid-template-columns: 1fr; }
    .md-preview { min-height: 120px; }
  }
</style>
