---
export const prerender = false;
import Management from '../../layouts/Management.astro';

const userId = Astro.locals.userId!;
const userDisplayName = Astro.locals.userDisplayName;

const pages = [
  {
    label: 'Pagina eventi',
    href: '/it/eventi',
    key: 'eventi',
    desc: 'Calendario e lista eventi in programma.',
    actions: ['Modifica la copertina della pagina'],
  },
  {
    label: 'Bacheca avvisi',
    href: '/it/eventi/bacheca',
    key: 'eventi-bacheca',
    desc: 'Avvisi, comunicazioni e circolari pubbliche.',
    actions: ['Modifica la copertina della pagina'],
  },
  {
    label: 'Fauna & Flora',
    href: '/it/scopri/fauna',
    key: 'scopri-fauna',
    desc: 'Mappa interattiva e schede sulle specie del territorio.',
    actions: ['Modifica la copertina della pagina'],
  },
  {
    label: 'Itinerari',
    href: '/it/scopri/itinerari',
    key: 'scopri-itinerari',
    desc: 'Percorsi a piedi e in bici lungo il Po.',
    actions: ['Modifica la copertina della pagina'],
  },
  {
    label: 'Ricettario',
    href: '/it/scopri/ricettario',
    key: 'scopri-ricettario',
    desc: 'Ricette tipiche della tradizione locale.',
    actions: ['Modifica la copertina della pagina'],
  },
  {
    label: 'Scopri il territorio',
    href: '/it/scopri',
    key: 'scopri',
    desc: 'Pagina indice della sezione "Scopri".',
    actions: ['Modifica la copertina della pagina'],
  },
  {
    label: 'Chi siamo',
    href: '/it/associazione',
    key: 'associazione',
    desc: 'Presentazione dell\'associazione e dello statuto.',
    actions: ['Modifica la copertina della pagina'],
  },
  {
    label: 'Partecipa',
    href: '/it/partecipa',
    key: 'partecipa',
    desc: 'Come partecipare alle attività e diventare volontario.',
    actions: ['Modifica la copertina della pagina'],
  },
];
---

<Management title="Sito pubblico" userDisplayName={userDisplayName}>
  <div class="page">

    <div class="page-header">
      <div>
        <h1 class="page-title">Sito pubblico</h1>
        <p class="page-sub">Apri una pagina per modificarla direttamente dal sito.</p>
      </div>
    </div>

    <div class="grid">
      {pages.map(p => (
        <div class="card">
          <div class="card-body">
            <p class="card-label">{p.label}</p>
            <p class="card-desc">{p.desc}</p>
            {p.actions.length > 0 && (
              <ul class="card-actions">
                {p.actions.map(a => <li>{a}</li>)}
              </ul>
            )}
          </div>
          <a href={p.href} target="_blank" rel="noopener" class="card-link">
            Apri
            <svg width="11" height="11" viewBox="0 0 11 11" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
              <path d="M2 9L9 2M5 2H9V6"/>
            </svg>
          </a>
        </div>
      ))}
    </div>

  </div>
</Management>

<style>
  .page { display: flex; flex-direction: column; gap: 2rem; }

  .page-header { display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem; }
  .page-title {
    font-family: var(--ff-serif);
    font-size: 1.65rem;
    font-weight: 300;
    color: var(--cream);
    margin: 0 0 .3rem;
  }
  .page-sub {
    font-size: .72rem;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--cream-dim);
    margin: 0;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1rem;
  }

  .card {
    background: var(--cream-ghost);
    border: 1px solid var(--cream-faint);
    border-radius: 8px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transition: border-color .15s;
  }
  .card:hover { border-color: rgba(232,220,200,.22); }

  .card-body { padding: 1.1rem 1.1rem .75rem; flex: 1; display: flex; flex-direction: column; gap: .45rem; }

  .card-label {
    font-size: .78rem;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--cream);
    margin: 0;
    font-weight: 500;
  }

  .card-desc {
    font-size: .78rem;
    color: var(--cream-dim);
    margin: 0;
    line-height: 1.5;
  }

  .card-actions {
    list-style: none;
    padding: 0; margin: .2rem 0 0;
    display: flex; flex-direction: column; gap: .2rem;
  }
  .card-actions li {
    font-size: .68rem;
    color: var(--gold);
    letter-spacing: .06em;
    padding-left: .85rem;
    position: relative;
    opacity: .8;
  }
  .card-actions li::before {
    content: '✦';
    position: absolute;
    left: 0;
    font-size: .5rem;
    top: .15em;
  }

  .card-link {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: .4rem;
    padding: .65rem;
    border-top: 1px solid var(--cream-faint);
    font-size: .65rem;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--cream-dim);
    text-decoration: none;
    transition: background .14s, color .14s;
  }
  .card-link:hover { background: var(--cream-ghost); color: var(--cream); }
</style>
