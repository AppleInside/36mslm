---
export const prerender = false;
import { SITE } from '../../consts';
import { COOKIE_NAME, verifySession } from '../../lib/auth';

const token = Astro.cookies.get(COOKIE_NAME)?.value;
if (token && verifySession(token)) {
  return Astro.redirect('/management/eventi', 302);
}

const err = Astro.url.searchParams.get('err');
---
<!DOCTYPE html>
<html lang="it">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Accesso · {SITE.name}</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;1,9..144,300;1,9..144,400&family=IBM+Plex+Mono:wght@300;400&display=swap"
    />
  </head>
  <body>

    <main>
      <div class="shell" id="shell">

        <div class="brand">
          <img
            src="/media/storico/logo.jpg"
            alt="36 m s.l.m. — Sopra il livello del mare"
            class="logo-img"
          />
          <p class="place">Polesine Parmense</p>
          <span class="divider"></span>
        </div>

        {err && (
          <p class="error" role="alert">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="7" cy="7" r="6.5" stroke="currentColor"/>
              <line x1="7" y1="4" x2="7" y2="7.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
              <circle cx="7" cy="9.5" r="0.75" fill="currentColor"/>
            </svg>
            Credenziali non valide
          </p>
        )}

        <form method="POST" action="/api/management/login" autocomplete="on">
          <div class="field">
            <input
              id="email"
              name="email"
              type="email"
              required
              autocomplete="email"
              placeholder=" "
            />
            <label for="email">Email</label>
            <span class="underline"></span>
          </div>

          <div class="field">
            <input
              id="password"
              name="password"
              type="password"
              required
              autocomplete="current-password"
              placeholder=" "
            />
            <label for="password">Password</label>
            <span class="underline"></span>
          </div>

          <button type="submit">
            <span class="btn-text">Accedi</span>
            <span class="btn-arrow" aria-hidden="true">
              <svg width="18" height="10" viewBox="0 0 18 10" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M1 5H17M17 5L13 1M17 5L13 9" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </button>
        </form>

      </div>
    </main>

    <div class="water-bar" aria-hidden="true"></div>

  </body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:         #0B1918;
    --cream:      #E8DCC8;
    --cream-dim:  rgba(232,220,200,0.45);
    --cream-faint:rgba(232,220,200,0.12);
    --cream-ghost:rgba(232,220,200,0.06);
    --gold:       #D8A14A;
    --gold-deep:  #B5802A;
    --teal:       #4A6670;
    --alga:       #7B8F6F;
    --error:      #E07B5A;
    --ff-serif: 'Fraunces', 'Iowan Old Style', Georgia, serif;
    --ff-mono:  'IBM Plex Mono', ui-monospace, monospace;
  }

  html, body {
    height: 100%;
  }

  body {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    background-color: var(--bg);
    background-image:
      radial-gradient(ellipse 900px 700px at 88% 10%,  rgba(74,102,112,0.45),  transparent 58%),
      radial-gradient(ellipse 700px 600px at  4% 92%,  rgba(123,143,111,0.30), transparent 55%),
      radial-gradient(ellipse 500px 500px at 50% 60%,  rgba(74,102,112,0.10),  transparent 70%),
      url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='200' height='200'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/><feColorMatrix values='0 0 0 0 0.04 0 0 0 0 0.09 0 0 0 0 0.09 0 0 0 0.08 0'/></filter><rect width='100%' height='100%' filter='url(%23n)'/></svg>");
    background-attachment: fixed;
    color: var(--cream);
    font-family: var(--ff-mono);
    -webkit-font-smoothing: antialiased;
  }

  /* ── Main ── */
  main {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1.5rem 5rem;
  }

  .shell {
    width: 100%;
    max-width: 360px;
    animation: rise 0.75s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  @keyframes rise {
    from { opacity: 0; transform: translateY(28px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Brand ── */
  .brand {
    text-align: center;
    margin-bottom: 2.75rem;
  }

  .logo-img {
    display: block;
    width: 200px;
    margin: 0 auto 0.75rem;
    border-radius: 5px;
    box-shadow:
      0 0 32px rgba(15,113,184,0.35),
      0 0 80px rgba(15,113,184,0.15),
      0 4px 24px rgba(0,0,0,0.5);
  }

  .place {
    font-family: var(--ff-mono);
    font-size: 0.6rem;
    font-weight: 300;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--cream-dim);
    margin-bottom: 1.5rem;
  }

  .divider {
    display: block;
    width: 32px;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--teal), transparent);
    margin: 0 auto;
  }

  /* ── Error ── */
  .error {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.72rem;
    letter-spacing: 0.03em;
    color: var(--error);
    margin-bottom: 1.75rem;
    padding: 0.6rem 0.8rem;
    border: 1px solid rgba(224,123,90,0.25);
    border-radius: 4px;
    background: rgba(224,123,90,0.07);
  }

  /* ── Form ── */
  form {
    display: flex;
    flex-direction: column;
    gap: 2.25rem;
  }

  /* ── Fields ── */
  .field {
    position: relative;
  }

  .field input {
    width: 100%;
    background: transparent;
    border: none;
    border-bottom: 1px solid var(--cream-faint);
    padding: 0.65rem 0 0.5rem;
    font-family: var(--ff-mono);
    font-size: 0.9rem;
    font-weight: 300;
    color: var(--cream);
    outline: none;
    transition: border-color 0.3s ease;
    letter-spacing: 0.04em;
  }

  /* Hide browser autofill yellow bg */
  .field input:-webkit-autofill,
  .field input:-webkit-autofill:hover,
  .field input:-webkit-autofill:focus {
    -webkit-text-fill-color: var(--cream);
    -webkit-box-shadow: 0 0 0 1000px var(--bg) inset;
    transition: background-color 5000s ease-in-out 0s;
  }

  .field label {
    position: absolute;
    top: 0.65rem;
    left: 0;
    font-family: var(--ff-mono);
    font-size: 0.65rem;
    font-weight: 300;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--cream-dim);
    pointer-events: none;
    transition: top 0.22s ease, font-size 0.22s ease, color 0.22s ease, letter-spacing 0.22s ease;
  }

  .field input:focus ~ label,
  .field input:not(:placeholder-shown) ~ label {
    top: -1.1rem;
    font-size: 0.58rem;
    letter-spacing: 0.22em;
    color: var(--gold);
  }

  /* Animated underline on focus */
  .field .underline {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--gold);
    transition: width 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .field input:focus ~ .underline {
    width: 100%;
  }

  /* ── Button ── */
  button[type="submit"] {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    margin-top: 0.5rem;
    width: 100%;
    padding: 0.85rem 1.5rem;
    background: var(--gold);
    border: none;
    border-radius: 3px;
    color: #1A0E00;
    font-family: var(--ff-mono);
    font-size: 0.72rem;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    cursor: pointer;
    overflow: hidden;
    transition: background 0.25s ease, transform 0.15s ease;
  }

  button[type="submit"]:hover {
    background: #E8B05A;
    transform: translateY(-1px);
  }

  button[type="submit"]:active {
    transform: translateY(0);
    background: var(--gold-deep);
  }

  .btn-arrow {
    display: flex;
    align-items: center;
    transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1);
  }

  button[type="submit"]:hover .btn-arrow {
    transform: translateX(5px);
  }

  /* ── Water bar ── */
  .water-bar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    height: 44px;
    pointer-events: none;
  }

  .water-bar::before,
  .water-bar::after {
    content: '';
    position: absolute;
    left: 0;
    width: 200%;
    height: 100%;
    background-repeat: repeat-x;
    background-size: 1200px 44px;
  }

  .water-bar::before {
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 1200 44' preserveAspectRatio='none'><path d='M0 22 Q 60 10 120 22 T 240 22 T 360 22 T 480 22 T 600 22 T 720 22 T 840 22 T 960 22 T 1080 22 T 1200 22' fill='none' stroke='%234A6670' stroke-width='1.4' opacity='0.5'/></svg>");
    animation: drift1 28s linear infinite;
  }

  .water-bar::after {
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 1200 44' preserveAspectRatio='none'><path d='M0 30 Q 80 20 160 30 T 320 30 T 480 30 T 640 30 T 800 30 T 960 30 T 1120 30 T 1200 30' fill='none' stroke='%237B8F6F' stroke-width='1' opacity='0.35'/></svg>");
    animation: drift2 38s linear infinite;
  }

  @keyframes drift1 {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  @keyframes drift2 {
    from { transform: translateX(-10%); }
    to   { transform: translateX(-60%); }
  }
</style>
