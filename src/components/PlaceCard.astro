---
import { getLangFromUrl, localizedPath } from '../i18n/utils';

type PlaceRow = {
  slug: string;
  title: string;
  kind: string;
  address: string;
  phone: string | null;
  website: string | null;
  tripadvisor: string | null;
  cover_url: string | null;
  michelin: string | null;
};

const { place } = Astro.props as { place: PlaceRow };
const lang = getLangFromUrl(Astro.url);

const accents: Record<string, string> = {
  ristorante: '#9b3520',
  agriturismo: '#3d6b3f',
  'b&b': '#2a4f7c',
  azienda: '#6b4c20',
  altro: '#4a5568',
};

const kindLabels: Record<string, string> = {
  ristorante:  lang === 'it' ? 'Ristorante'  : 'Restaurant',
  agriturismo: 'Agriturismo',
  'b&b':       'B&B',
  azienda:     lang === 'it' ? 'Azienda'     : 'Shop',
  altro:       lang === 'it' ? 'Altro'        : 'Other',
};

const acc   = accents[place.kind]   ?? accents.altro;
const label = kindLabels[place.kind] ?? place.kind;
const photo = place.cover_url ?? null;

const michelinStars = place.michelin && /^\d$/.test(place.michelin) ? parseInt(place.michelin) : 0;
const michelinListed = place.michelin === 'listed';
---

<div class="place-card" style={`--accent:${acc}`}>

  <!-- Profilo band -->
  <div class="profilo">
    <span class="profilo-icona" aria-hidden="true">
      {place.kind === 'ristorante' && (
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
          <line x1="4.5" y1="2" x2="4.5" y2="5.5" stroke="rgba(255,255,255,.85)" stroke-width="1.2" stroke-linecap="round"/>
          <path d="M2.5 2v3.5a2 2 0 0 0 2 2v4.5" stroke="rgba(255,255,255,.85)" stroke-width="1.2" stroke-linecap="round"/>
          <path d="M9.5 2c1.7 0 2.5 1 2.5 2.5v.5H9.5V12" stroke="rgba(255,255,255,.85)" stroke-width="1.2" stroke-linecap="round" fill="none"/>
        </svg>
      )}
      {place.kind === 'agriturismo' && (
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
          <path d="M7 12C4.5 10 2 7.5 2 5a5 5 0 0 1 10 0c0 2.5-2.5 5-5 7z" fill="rgba(255,255,255,.8)"/>
          <line x1="7" y1="12" x2="7" y2="6" stroke="rgba(255,255,255,.4)" stroke-width="1"/>
        </svg>
      )}
      {place.kind === 'b&b' && (
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
          <path d="M2 7.5L7 3l5 4.5" stroke="rgba(255,255,255,.85)" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
          <rect x="3.5" y="7.5" width="7" height="4.5" stroke="rgba(255,255,255,.85)" stroke-width="1.2" fill="none"/>
          <rect x="5.5" y="9.5" width="3" height="2.5" fill="rgba(255,255,255,.7)"/>
        </svg>
      )}
      {place.kind === 'azienda' && (
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
          <rect x="2" y="4" width="10" height="8" stroke="rgba(255,255,255,.85)" stroke-width="1.2" fill="none"/>
          <path d="M2 4L7 2l5 2" stroke="rgba(255,255,255,.85)" stroke-width="1.2" stroke-linejoin="round" fill="none"/>
          <rect x="5" y="8" width="4" height="4" fill="rgba(255,255,255,.65)"/>
          <rect x="3.5" y="5.5" width="2" height="2" fill="rgba(255,255,255,.6)"/>
          <rect x="8.5" y="5.5" width="2" height="2" fill="rgba(255,255,255,.6)"/>
        </svg>
      )}
      {place.kind === 'altro' && (
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
          <path d="M7 2C5.3 2 4 3.3 4 5c0 2.8 3 7 3 7s3-4.2 3-7c0-1.7-1.3-3-3-3z" stroke="rgba(255,255,255,.85)" stroke-width="1.2" fill="rgba(255,255,255,.25)"/>
          <circle cx="7" cy="5" r="1.2" fill="rgba(255,255,255,.85)"/>
        </svg>
      )}
    </span>
    <span class="profilo-label">{label}</span>
  </div>

  <!-- Body -->
  <div class="corpo">
    <div class="info">
      <h3 class="titolo">
        <a href={localizedPath(lang, `scopri/territorio/dove/${place.slug}`)}>{place.title}</a>
        {michelinStars > 0 && (
          <span class="mich-badge" aria-label={`${michelinStars} stella Michelin`}>
            {Array.from({length: michelinStars}).map(() => (
              <img src="/icons/michelin-star.png" class="mich-img" alt="" />
            ))}
          </span>
        )}
        {michelinListed && (
          <span class="mich-badge" aria-label="Guida Michelin">
            <img src="/icons/michelin-guide.png" class="mich-img" alt="" />
          </span>
        )}
      </h3>
      <p class="indirizzo">{place.address}</p>
      {place.phone && <p class="telefono">{place.phone}</p>}

      {(place.website || place.tripadvisor) && (
        <div class="actions">
          {place.website && (
            <a class="btn-link" href={place.website} target="_blank" rel="noopener noreferrer">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                <circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/>
                <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
              </svg>
              {lang === 'it' ? 'Sito web' : 'Website'}
            </a>
          )}
          {place.tripadvisor && (
            <a class="btn-link btn-link--trip" href={place.tripadvisor} target="_blank" rel="noopener noreferrer">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.1 0 2 .9 2 2s-.9 2-2 2-2-.9-2-2 .9-2 2-2zm-4 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm8 0c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm-4 5c-2.21 0-4-1.79-4-4h8c0 2.21-1.79 4-4 4z"/>
              </svg>
              TripAdvisor
            </a>
          )}
        </div>
      )}
    </div>

    {photo && (
      <div class="photo">
        <img src={photo} alt={place.title} loading="lazy" />
      </div>
    )}
  </div>
</div>

<style>
  .place-card {
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 2px 14px rgba(0,0,0,.07), 0 0 0 1px rgba(0,0,0,.055);
    background: #fff;
  }

  /* ── Profilo band ─────────────────────────────── */
  .profilo {
    background: var(--accent);
    padding: .6rem 1.25rem;
    display: flex;
    align-items: center;
    gap: .5rem;
  }
  .profilo-icona {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }
  .profilo-label {
    font-family: theme('fontFamily.mono');
    font-size: .6rem;
    text-transform: uppercase;
    letter-spacing: .26em;
    color: rgba(255,255,255,.9);
    font-weight: 600;
  }

  /* ── Body ─────────────────────────────────────── */
  .corpo {
    display: flex;
    gap: 0;
  }
  .info {
    flex: 1;
    padding: 1.2rem 1.4rem 1.3rem;
    min-width: 0;
  }
  .titolo {
    font-family: theme('fontFamily.hand');
    font-size: 1.45rem;
    font-weight: 400;
    line-height: 1.2;
    color: theme('colors.ink');
    margin: 0 0 .55rem;
  }
  .titolo a {
    color: inherit;
    text-decoration: none;
    transition: color .15s;
  }
  .titolo a:hover { color: var(--accent); }

  .indirizzo {
    font-family: theme('fontFamily.mono');
    font-size: .74rem;
    color: #718096;
    margin: 0;
    letter-spacing: .01em;
  }
  .telefono {
    font-family: theme('fontFamily.mono');
    font-size: .72rem;
    color: #a0aec0;
    margin: .3rem 0 0;
  }

  /* ── Action buttons ───────────────────────────── */
  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: .4rem;
    margin-top: .85rem;
  }
  .btn-link {
    display: inline-flex;
    align-items: center;
    gap: .3rem;
    padding: .3rem .7rem;
    border-radius: 999px;
    border: 1px solid rgba(0,0,0,.14);
    font-family: theme('fontFamily.mono');
    font-size: .62rem;
    text-transform: uppercase;
    letter-spacing: .1em;
    color: #4a5568;
    text-decoration: none;
    transition: border-color .15s, color .15s, background .15s;
    flex-shrink: 0;
  }
  .btn-link:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 6%, transparent);
  }
  .btn-link--trip { color: #00af87; border-color: rgba(0,175,135,.3); }
  .btn-link--trip:hover { border-color: #00af87; color: #00af87; background: rgba(0,175,135,.06); }

  /* ── Photo ────────────────────────────────────── */
  .photo {
    width: 130px;
    flex-shrink: 0;
    overflow: hidden;
  }
  .photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform .4s ease;
  }
  .place-card:hover .photo img { transform: scale(1.04); }

  @media (max-width: 480px) {
    .photo { display: none; }
  }

  /* ── Michelin badge ───────────────────────────── */
  .mich-badge {
    display: inline-flex;
    align-items: center;
    gap: 1px;
    vertical-align: middle;
    margin-left: .45rem;
    position: relative;
    top: -1px;
  }
  .mich-img {
    width: 18px;
    height: 18px;
    object-fit: contain;
    flex-shrink: 0;
    /* PNG has white background — multiply makes white transparent on light surfaces */
    mix-blend-mode: multiply;
  }
</style>
