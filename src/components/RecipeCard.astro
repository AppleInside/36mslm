---
const { entry } = Astro.props;
const slug = entry.slug.replace(/^(it|en)\//, '');
const cat = entry.data.category || 'dolci';
const catLabels: Record<string, string> = {
  dolci: 'Dolci',
  liquori: 'Liquori e bagne',
  conserve: 'Conserve e salse',
};
---
<article class="rc" data-id={slug} data-cat={cat} role="button" tabindex="0">
  <div class="rc-photo">
    {entry.data.photo
      ? <img src={entry.data.photo} alt={entry.data.title} loading="lazy" />
      : <div class="rc-photo-empty"></div>
    }
    <span class="rc-badge">{catLabels[cat] ?? cat}</span>
  </div>
  <div class="rc-body">
    <h3 class="rc-title">{entry.data.title}</h3>
    {entry.data.author && <p class="rc-author">dell&apos;{entry.data.author}</p>}
    {entry.data.description && <p class="rc-desc">{entry.data.description}</p>}
    <span class="rc-cta">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
      Apri il quaderno
    </span>
  </div>
</article>

<style>
  .rc {
    background: #fff;
    border-radius: 14px;
    box-shadow: 0 2px 14px rgba(31,42,42,0.07);
    overflow: hidden;
    cursor: pointer;
    transition: transform .25s cubic-bezier(.2,.7,.2,1), box-shadow .25s ease;
    display: flex;
    flex-direction: column;
  }
  .rc:hover, .rc:focus-visible {
    transform: translateY(-5px);
    box-shadow: 0 10px 28px rgba(31,42,42,0.14);
    outline: none;
  }
  .rc-photo {
    position: relative;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background: theme('colors.paper-2');
  }
  .rc-photo img {
    width: 100%; height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
    transition: transform .6s cubic-bezier(.2,.7,.2,1);
  }
  .rc:hover .rc-photo img { transform: scale(1.04); }
  .rc-photo-empty { width: 100%; height: 100%; background: theme('colors.paper-2'); }
  .rc-badge {
    position: absolute; top: .75rem; left: .75rem;
    background: rgba(255,255,255,0.88);
    backdrop-filter: blur(4px);
    border-radius: 999px;
    padding: .2rem .7rem;
    font-family: theme('fontFamily.mono');
    font-size: .65rem;
    text-transform: uppercase;
    letter-spacing: .14em;
    color: theme('colors.acquadeep');
    font-weight: 500;
  }
  .rc-body {
    padding: 1.1rem 1.25rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: .3rem;
    flex: 1;
  }
  .rc-title {
    font-family: theme('fontFamily.hand');
    font-size: 1.55rem;
    font-weight: 700;
    line-height: 1.1;
    color: theme('colors.ink');
    margin: 0;
  }
  .rc-author {
    font-style: italic;
    font-size: .82rem;
    color: theme('colors.gold-deep');
    margin: 0;
  }
  .rc-desc {
    font-size: .85rem;
    line-height: 1.5;
    color: theme('colors.ink-soft');
    margin: .2rem 0 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .rc-cta {
    display: flex;
    align-items: center;
    gap: .4rem;
    margin-top: auto;
    padding-top: .75rem;
    border-top: 1px solid theme('colors.rule');
    font-family: theme('fontFamily.mono');
    font-size: .72rem;
    text-transform: uppercase;
    letter-spacing: .12em;
    color: theme('colors.brand');
  }
</style>
