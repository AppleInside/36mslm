---
import { getLangFromUrl, useTranslations, localizedPath } from '../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const itPath = Astro.url.pathname.replace(/^\/(it|en)/, '/it') || '/it/';
const enPath = Astro.url.pathname.replace(/^\/(it|en)/, '/en') || '/en/';

const home = localizedPath(lang, '');

const scopriSlides = [
  {
    eyebrow: lang === 'it' ? '— Territorio —' : '— Territory —',
    title:   lang === 'it' ? 'Itinerari del fiume' : 'River itineraries',
    blurb:   lang === 'it' ? 'Sentieri, anse e argini lungo il grande Po.' : 'Paths, bends and embankments along the great Po.',
    img:     '/media/storico/Guareschi-sul-Po.jpg',
    href:    localizedPath(lang, 'scopri/territorio'),
  },
  {
    eyebrow: lang === 'it' ? '— Dove fermarsi —' : '— Where to stop —',
    title:   lang === 'it' ? 'Luoghi e tappe' : 'Places & stops',
    blurb:   lang === 'it' ? 'Ristoranti, agriturismi e posti dove dormire.' : 'Restaurants, farm stays and places to sleep.',
    img:     '/media/storico/partecipavano-allultima-serata-del-bar-della-Brucata.jpg',
    href:    localizedPath(lang, 'scopri/territorio/dove'),
  },
];
const navItems = [
  {
    key: 'eventi',
    href: localizedPath(lang, 'eventi'),
    label: t('nav.events'),
    lead: {
      eyebrow: lang === 'it' ? 'Prossimo evento · 10 maggio' : 'Next event · May 10',
      headline: lang === 'it'
        ? 'Camminata in <em>golena</em> al risveglio del Po'
        : 'Walk in the <em>floodplain</em> at the river\'s awakening',
      blurb: lang === 'it'
        ? "Sei chilometri tra pioppi e meandri, partenza all'argine alle 06:30."
        : 'Six kilometres among poplars and meanders, leaving from the embankment at 06:30.',
      img: '/media/legacy/wp-content_uploads_2021_09_cercavano-il-fresco-destate-sulla-Via-Alzaia-FILEminimizer.jpg',
      href: localizedPath(lang, 'eventi/2026-05-10-camminata-golena'),
    },
    cols: [
      {
        title: lang === 'it' ? 'Calendario' : 'Calendar',
        links: [
          { label: lang === 'it' ? 'Tutti gli <em>eventi</em>' : 'All <em>events</em>', href: localizedPath(lang, 'eventi/calendario') },
          { label: lang === 'it' ? 'Bacheca <em>e avvisi</em>' : 'Notice <em>board</em>', href: localizedPath(lang, 'partecipa/bacheca') },
          { label: lang === 'it' ? 'Segnala <em>un evento</em>' : 'Report <em>an event</em>', href: localizedPath(lang, 'contatti') },
        ],
      },
      {
        title: lang === 'it' ? 'Per chi viene da fuori' : 'If you come from out of town',
        links: [
          { label: lang === 'it' ? 'Come <em>arrivare</em>' : 'How to <em>get here</em>', href: localizedPath(lang, 'contatti') },
        ],
      },
    ],
  },
  {
    key: 'scopri',
    href: localizedPath(lang, 'scopri'),
    label: lang === 'it' ? 'Scopri il Po' : t('nav.discover'),
    lead: {
      eyebrow: lang === 'it' ? 'Storia in evidenza' : 'Featured story',
      headline: lang === 'it'
        ? 'I nomi dei pioppi nel <em>dialetto</em> di Polesine'
        : 'The names of poplars in the Polesine <em>dialect</em>',
      blurb: lang === 'it'
        ? 'Dal pioppo cipressino al pioppo nero: come li chiamavano i nostri nonni.'
        : 'From the cypress poplar to the black poplar: how our grandparents named them.',
      img: '/media/legacy/wp-content_uploads_2021_09_1953-Giovannino-Guareschi-Polesine-Due-Torri-1.jpg',
      href: localizedPath(lang, 'scopri/storie'),
    },
    cols: [
      {
        title: lang === 'it' ? 'Il territorio' : 'Territory',
        links: [
          { label: lang === 'it' ? 'Itinerari <em>del fiume</em>' : 'River <em>itineraries</em>', href: localizedPath(lang, 'scopri/territorio') },
          { label: lang === 'it' ? 'Fauna <em>e flora</em>' : 'Fauna <em>and flora</em>', href: localizedPath(lang, 'scopri/fauna') },
          { label: lang === 'it' ? 'Dove <em>mangiare o dormire</em>' : 'Where to <em>eat or sleep</em>', href: localizedPath(lang, 'scopri/territorio/dove') },
        ],
      },
      {
        title: lang === 'it' ? 'Memoria' : 'Memory',
        links: [
          { label: lang === 'it' ? 'Ricettario <em>della bassa</em>' : 'Recipes <em>of the lowlands</em>', href: localizedPath(lang, 'scopri/ricettario') },
          { label: lang === 'it' ? 'Dialetto <em>e modi di dire</em>' : 'Dialect <em>and sayings</em>', href: localizedPath(lang, 'scopri/storie') },
          { label: lang === 'it' ? 'Immagini <em>e ricordi</em>' : 'Images <em>and memories</em>', href: localizedPath(lang, 'scopri/immagini') },
        ],
      },
    ],
  },
  {
    key: 'chisiamo',
    href: localizedPath(lang, 'chi-siamo'),
    label: lang === 'it' ? "L'associazione" : 'The association',
    lead: {
      eyebrow: lang === 'it' ? "L'associazione" : 'The association',
      headline: lang === 'it'
        ? 'Un\'associazione <em>di associazioni</em> che vive a 36 metri sul mare'
        : 'An <em>association of associations</em> living 36 metres above sea level',
      blurb: lang === 'it'
        ? 'Sette realtà storiche di Polesine Parmense unite per valorizzare il patrimonio umano e naturale del territorio.'
        : 'Seven historic local organisations united to promote the human and natural heritage of Polesine Parmense.',
      img: '/media/legacy/wp-content_uploads_2021_09_Giovanni-Guareschi-al-bar-in-piazza.jpg',
      href: localizedPath(lang, 'chi-siamo'),
    },
    cols: [
      {
        title: lang === 'it' ? 'Sostieni' : 'Support',
        links: [
          { label: lang === 'it' ? '<em>5×1000</em> all\'associazione' : '<em>5×1000</em> to the association', href: localizedPath(lang, 'partecipa/5x1000') },
          { label: lang === 'it' ? '<em>Volontari</em> per gli eventi' : '<em>Volunteers</em> for events', href: localizedPath(lang, 'partecipa/volontari') },
        ],
      },
      {
        title: lang === 'it' ? 'Documenti' : 'Documents',
        links: [
          { label: lang === 'it' ? "L'<em>associazione</em>" : 'The <em>association</em>', href: localizedPath(lang, 'chi-siamo/storia') },
          { label: lang === 'it' ? 'Lo <em>statuto</em>' : 'The <em>bylaws</em>', href: localizedPath(lang, 'chi-siamo/statuto') },
          { label: lang === 'it' ? '<em>Press kit</em>' : '<em>Press kit</em>', href: localizedPath(lang, 'chi-siamo/press-kit') },
        ],
      },
    ],
  },
  {
    key: 'contatti',
    href: localizedPath(lang, 'contatti'),
    label: t('nav.contact'),
    lead: {
      eyebrow: lang === 'it' ? 'Scrivici' : 'Write to us',
      headline: lang === 'it' ? 'Tre minuti, una <em>email</em>' : 'Three minutes, one <em>email</em>',
      blurb: lang === 'it'
        ? 'Per qualsiasi cosa — eventi, foto, segnalazioni — rispondiamo nel giro di qualche giorno.'
        : 'For anything — events, photos, tips — we reply within a few days.',
      img: '/media/legacy/wp-content_uploads_2021_09_Guareschi-sul-Po.jpg',
      href: localizedPath(lang, 'contatti'),
    },
    cols: [
      {
        title: lang === 'it' ? 'Recapiti' : 'Contacts',
        links: [
          { label: 'info@polesineparmense36.it', href: 'mailto:info@polesineparmense36.it' },
          { label: lang === 'it' ? 'Sede <em>e indirizzo</em>' : 'Office <em>and address</em>', href: localizedPath(lang, 'contatti') },
        ],
      },
      {
        title: lang === 'it' ? 'Sui social' : 'On social',
        links: [
          { label: 'Instagram', href: 'https://instagram.com/' },
          { label: 'Facebook', href: 'https://facebook.com/' },
        ],
      },
    ],
  },
];
---

<header class="topbar">
  <a class="marca" href={home} aria-label="36 m s.l.m.">
    <img src="/logo.jpg" alt="36 m s.l.m." />
    <span class="marca-sub">APS<br/>Polesine Parmense</span>
  </a>

  <nav class="nav" id="nav" aria-label={lang === 'it' ? 'Navigazione principale' : 'Main navigation'}>
    {navItems.map((item) => (
      <div class="nav-item" data-pane={item.key}>
        <a href={item.href} aria-haspopup="true" aria-expanded="false"><span class="label">{item.label}</span></a>
      </div>
    ))}
    <span class="indicator" id="indicator" aria-hidden="true"></span>
  </nav>

  <div class="lang" id="lang-toggle" data-active={lang}>
    <span class="lang-pill" aria-hidden="true"></span>
    <a href={itPath} class={lang === 'it' ? 'on' : ''} data-lang="it"><span class="flag flag-it" aria-hidden="true"></span>IT</a>
    <a href={enPath} class={lang === 'en' ? 'on' : ''} data-lang="en"><span class="flag flag-gb" aria-hidden="true"></span>EN</a>
  </div>

  <button class="burger" id="burger" aria-label="Menu" aria-expanded="false" aria-controls="drawer" aria-hidden="false">
    <span class="b1" aria-hidden="true"></span>
    <span class="b2" aria-hidden="true"></span>
    <span class="b3" aria-hidden="true"></span>
  </button>

  <div class="megapanel" id="megapanel" role="region" aria-label={lang === 'it' ? 'Sottomenu' : 'Submenu'}>
    {navItems.map((item) => (
      <div class="pane" data-pane={item.key}>
        {item.key === 'scopri' ? (
          <div class="carousel-lead" id="scopriCarousel">
            {scopriSlides.map((slide, i) => (
              <a class:list={['cs', i === 0 && 'cs--active']} href={slide.href} data-slide={i}>
                <img src={slide.img} alt={slide.title} loading="lazy" />
                <div class="cs-content">
                  <p class="cs-eyebrow">{slide.eyebrow}</p>
                  <h4>{slide.title}</h4>
                  <p class="cs-blurb">{slide.blurb}</p>
                </div>
              </a>
            ))}
            <div class="cs-dots">
              {scopriSlides.map((_, i) => (
                <button class:list={['cs-dot', i === 0 && 'cs-dot--active']} data-dot={i} aria-label={`Slide ${i + 1}`}></button>
              ))}
            </div>
          </div>
        ) : (
          <a class="lead" href={item.lead.href}>
            <p class="eyebrow">{item.lead.eyebrow}</p>
            <h4 set:html={item.lead.headline}></h4>
            <p class="blurb">{item.lead.blurb}</p>
            <div class="pic"><img src={item.lead.img} alt="" loading="lazy" /></div>
          </a>
        )}
        {item.cols.map((col) => (
          <div class="links">
            <h5>{col.title}</h5>
            {col.links.map((l) => (
              <a href={l.href}><span set:html={l.label}></span><span class="arrow" aria-hidden="true">→</span></a>
            ))}
          </div>
        ))}
      </div>
    ))}
  </div>
</header>

<div class="drawer-overlay" id="drawerOverlay" aria-hidden="true"></div>

<div class="drawer" id="drawer" role="dialog" aria-modal="true" aria-label={lang === 'it' ? 'Menu di navigazione' : 'Navigation menu'}>
  <!-- Header strip -->
  <div class="drawer-head">
    <a class="drawer-marca" href={localizedPath(lang, '')} aria-label="36 m s.l.m.">
      <img src="/logo.jpg" alt="36 m s.l.m." class="drawer-logo" />
    </a>
    <button class="drawer-close" id="drawerClose" aria-label="Chiudi">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <path d="M2 2l12 12M14 2L2 14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
      </svg>
    </button>
  </div>

  <!-- Nav links -->
  <nav class="drawer-nav" aria-label={lang === 'it' ? 'Navigazione principale' : 'Main navigation'}>
    <ol class="drawer-list">
      {navItems.map((item, i) => (
        <li class="drawer-item" style={`--i:${i}`}>
          <a class="drawer-toggle" href={item.href}>
            <span class="drawer-label">{item.label}</span>
            <span class="drawer-arrow" aria-hidden="true">→</span>
          </a>
        </li>
      ))}
    </ol>
  </nav>

  <!-- Footer -->
  <div class="drawer-foot">
    <div class="drawer-langs">
      <a href={itPath} class:list={['drawer-lang', lang === 'it' && 'on']}>
        <span class="flag flag-it" aria-hidden="true"></span> IT
      </a>
      <span class="drawer-lang-sep">/</span>
      <a href={enPath} class:list={['drawer-lang', lang === 'en' && 'on']}>
        <span class="flag flag-gb" aria-hidden="true"></span> EN
      </a>
    </div>
    <a href="mailto:info@polesineparmense36.it" class="drawer-email">info@polesineparmense36.it</a>
  </div>
</div>

<style>
  /* ── Mobile-first base ─────────────────────────────── */
  .topbar {
    position: sticky; top: 0; z-index: 50;
    display: flex; align-items: center; justify-content: space-between;
    padding: 1rem 1.25rem;
    background: rgba(28,46,56,0.92);
    backdrop-filter: blur(16px) saturate(1.2);
    -webkit-backdrop-filter: blur(16px) saturate(1.2);
    border-top: 2px solid rgba(216,161,74,0.55);
    border-bottom: 1px solid rgba(255,255,255,0.07);
    box-shadow: 0 2px 24px rgba(0,0,0,0.18);
  }
  .marca { display: inline-flex; align-items: center; gap: .75rem; text-decoration: none; color: #E8F4F8; }
  .marca img {
    height: 40px; width: auto; display: block;
    border-radius: 3px;
    transition: transform .5s cubic-bezier(.2,.7,.2,1), box-shadow .3s ease;
  }
  .marca-sub {
    display: none;
    font-family: theme('fontFamily.mono');
    font-size: .6rem; text-transform: uppercase; letter-spacing: .2em;
    color: rgba(232,244,248,0.38);
    border-left: 1px solid rgba(232,244,248,0.18);
    padding-left: .75rem; line-height: 1.4;
  }

  /* Mobile: show burger, hide nav/lang/megapanel */
  .nav       { display: none; }
  .lang      { display: none; }
  .megapanel { display: none; }
  .burger {
    display: inline-flex; flex-direction: column;
    align-items: flex-end; justify-content: center; gap: 5px;
    width: 44px; height: 44px; padding: 0 11px;
    background: transparent; border: none;
    cursor: pointer; flex-shrink: 0;
    transition: gap .25s ease;
  }
  .burger .b1, .burger .b2, .burger .b3 {
    display: block; height: 1.5px;
    background: rgba(232,244,248,.75);
    border-radius: 2px;
    transform-origin: right center;
    transition: width .25s ease, transform .3s cubic-bezier(.2,.7,.2,1), opacity .2s ease, background .2s ease;
  }
  .burger .b1 { width: 22px; }
  .burger .b2 { width: 14px; }
  .burger .b3 { width: 18px; }
  .burger:hover .b1, .burger:hover .b2, .burger:hover .b3 {
    background: theme('colors.gold');
  }
  .burger:hover .b1 { width: 22px; }
  .burger:hover .b2 { width: 22px; }
  .burger:hover .b3 { width: 22px; }
  /* Open → × */
  .burger.open { gap: 0; }
  .burger.open .b1 { width: 20px; transform: translateY(1px) rotate(-45deg); background: rgba(232,244,248,.9); }
  .burger.open .b2 { opacity: 0; width: 0; }
  .burger.open .b3 { width: 20px; transform: translateY(-1px) rotate(45deg); background: rgba(232,244,248,.9); }
  .burger:focus-visible { outline: 2px solid theme('colors.gold'); outline-offset: 3px; border-radius: 4px; }

  /* Flags */
  .flag {
    display: inline-block; width: 18px; height: 13px;
    border-radius: 2px; flex-shrink: 0;
    background-size: cover; background-position: center;
    box-shadow: 0 0 0 1px rgba(0,0,0,0.18);
  }
  .flag-it {
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 3 2'><rect width='1' height='2' fill='%23009246'/><rect x='1' width='1' height='2' fill='%23fff'/><rect x='2' width='1' height='2' fill='%23CE2B37'/></svg>");
  }
  .flag-gb {
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 60 40'><rect width='60' height='40' fill='%23012169'/><path d='M0,0 L60,40 M60,0 L0,40' stroke='%23fff' stroke-width='8'/><path d='M0,0 L60,40 M60,0 L0,40' stroke='%23C8102E' stroke-width='4'/><rect x='23' width='14' height='40' fill='%23fff'/><rect y='13' width='60' height='14' fill='%23fff'/><rect x='25' width='10' height='40' fill='%23C8102E'/><rect y='15' width='60' height='10' fill='%23C8102E'/></svg>");
  }

  /* Mobile drawer */
  /* ── Drawer overlay ──────────────────────────────── */
  .drawer-overlay {
    display: none;
    position: fixed; inset: 0;
    background: rgba(8,14,20,.55);
    backdrop-filter: blur(3px);
    -webkit-backdrop-filter: blur(3px);
    z-index: 59;
    opacity: 0;
    transition: opacity .35s ease;
  }
  .drawer-overlay.open { display: block; opacity: 1; }

  /* ── Mobile drawer ────────────────────────────────── */
  .drawer {
    position: fixed; top: 0; right: 0; bottom: 0;
    width: min(88vw, 340px);
    background: rgba(18,30,40,0.97);
    backdrop-filter: blur(20px) saturate(1.2);
    -webkit-backdrop-filter: blur(20px) saturate(1.2);
    border-left: 1px solid rgba(255,255,255,.08);
    box-shadow: -8px 0 48px rgba(0,0,0,.45);
    z-index: 60;
    display: flex; flex-direction: column;
    transform: translateX(100%);
    transition: transform .42s cubic-bezier(.2,.7,.2,1);
    overflow: hidden;
  }
  .drawer.open { transform: translateX(0); }

  /* Head strip */
  .drawer-head {
    flex-shrink: 0;
    display: flex; align-items: center; justify-content: space-between;
    padding: .9rem 1rem .9rem 1.3rem;
    border-bottom: 1px solid rgba(255,255,255,.1);
    border-top: 2px solid rgba(216,161,74,.5);
  }
  .drawer-marca {
    text-decoration: none; display: flex; align-items: baseline; gap: .3rem;
  }
  .drawer-logo {
    height: 44px; width: auto; display: block;
    border-radius: 3px;
  }
  .drawer-close {
    position: relative; z-index: 1;
    background: rgba(255,255,255,.12);
    border: 1px solid rgba(255,255,255,.2);
    color: rgba(232,244,248,.85);
    width: 36px; height: 36px;
    border-radius: 50%; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    transition: background .2s;
  }
  .drawer-close:hover { background: rgba(255,255,255,.22); }
  .drawer-close:focus-visible { outline: 2px solid theme('colors.gold'); outline-offset: 2px; }

  /* Nav list */
  .drawer-nav { flex: 1; overflow-y: auto; padding: .35rem 0; }
  .drawer-list { list-style: none; padding: 0; margin: 0; }
  .drawer-item { border-bottom: 1px solid rgba(255,255,255,.07); }

  /* Stagger animation */
  @keyframes drawer-item-in {
    from { opacity: 0; transform: translateX(20px); }
    to   { opacity: 1; transform: translateX(0); }
  }
  .drawer.open .drawer-item {
    animation: drawer-item-in .35s both;
    animation-delay: calc(.06s + var(--i) * .06s);
  }

  /* Each link row */
  .drawer-toggle {
    width: 100%; display: flex;
    align-items: center; justify-content: space-between; gap: .5rem;
    padding: 1.1rem 1.3rem;
    color: rgba(232,244,248,.75);
    text-decoration: none;
    transition: background .18s, color .18s;
  }
  .drawer-toggle:hover {
    background: rgba(255,255,255,.06);
    color: #E8F4F8;
  }
  .drawer-toggle:hover .drawer-arrow { transform: translateX(4px); color: theme('colors.gold'); }
  .drawer-toggle:focus-visible { outline: 2px solid theme('colors.gold'); outline-offset: -2px; }

  .drawer-label {
    font-family: theme('fontFamily.hand');
    font-size: 2.2rem; font-weight: 700; line-height: 1.1;
    color: inherit;
  }
  .drawer-arrow {
    font-size: .85rem;
    color: rgba(232,244,248,.3);
    transition: transform .2s, color .2s;
  }

  /* Footer */
  .drawer-foot {
    flex-shrink: 0;
    padding: .9rem 1.1rem;
    border-top: 1px solid rgba(255,255,255,.1);
    background: rgba(0,0,0,.25);
    display: flex; justify-content: space-between; align-items: center;
    gap: .75rem;
  }
  .drawer-langs {
    display: flex; align-items: center; gap: .4rem;
  }
  .drawer-lang-sep {
    color: rgba(232,244,248,.25);
    font-family: theme('fontFamily.mono'); font-size: .72rem;
  }
  .drawer-lang {
    display: inline-flex; align-items: center; gap: .35rem;
    text-decoration: none;
    font-family: theme('fontFamily.mono'); font-size: .7rem;
    text-transform: uppercase; letter-spacing: .16em;
    color: rgba(232,244,248,.45);
    padding: .3rem .5rem; border-radius: .3rem;
    transition: color .18s, background .18s;
  }
  .drawer-lang:hover { color: #E8F4F8; }
  .drawer-lang.on {
    color: theme('colors.gold');
    background: rgba(216,161,74,.12);
  }
  .drawer-email {
    font-family: theme('fontFamily.mono');
    font-size: .62rem; letter-spacing: .04em;
    color: rgba(232,244,248,.28);
    text-decoration: none;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    transition: color .18s;
  }
  .drawer-email:hover { color: rgba(232,244,248,.65); }

  /* ── Unused leftovers (kept for desktop panes) ────── */
  .drawer-sub-main {
    display: block; padding: .6rem 0 .9rem;
    text-decoration: none;
    font-family: theme('fontFamily.mono');
    font-size: .72rem; text-transform: uppercase; letter-spacing: .18em;
    color: theme('colors.brand'); border-bottom: 1px dashed theme('colors.rule');
    margin-bottom: .75rem;
  }
  .drawer-sub-main em { font-style: italic; font-family: theme('fontFamily.serif'); text-transform: none; font-size: .9rem; }
  .drawer-col { margin-bottom: .85rem; }
  .drawer-col-title {
    font-family: theme('fontFamily.mono');
    font-size: .65rem; text-transform: uppercase; letter-spacing: .2em;
    color: theme('colors.ink-soft'); margin: 0 0 .35rem; font-weight: 500;
  }
  .drawer-col-link {
    display: block; padding: .45rem 0;
    text-decoration: none; color: theme('colors.ink');
    font-family: theme('fontFamily.serif'); font-size: 1.1rem;
    border-bottom: 1px solid theme('colors.rule');
    transition: color .2s ease, padding-left .2s ease;
  }
  .drawer-col-link:hover { color: theme('colors.brand'); padding-left: .4rem; }
  .drawer-col-link :global(em) { font-style: italic; color: theme('colors.acquadeep'); }


  /* ── Desktop (≥ 1001px) ────────────────────────────── */
  @media (min-width: 1001px) {
    .topbar {
      display: grid;
      grid-template-columns: auto 1fr auto auto;
      gap: 2rem;
      padding: 1.3rem 2.5rem;
    }
    .marca img { height: 50px; }
    .marca:hover img { transform: rotate(-2deg) scale(1.03); box-shadow: 0 4px 16px rgba(0,0,0,0.35); }
    .marca-sub { display: block; }

    .nav {
      display: flex; justify-content: center; align-items: stretch;
      gap: 0; position: relative;
    }
    .nav-item { position: relative; padding: .95rem 1.6rem; }
    .nav-item > a {
      text-decoration: none;
      color: rgba(232,244,248,0.72);
      display: inline-flex; align-items: baseline;
      font-family: theme('fontFamily.hand');
      font-size: 1.8rem; line-height: 1; font-weight: 700;
      letter-spacing: .01em;
      transition: color .25s ease;
      border-radius: 4px;
    }
    .nav-item > a:focus-visible {
      outline: 2px solid theme('colors.gold');
      outline-offset: 4px;
    }
    @keyframes acqua-appare {
      from { opacity: 0; }
      to   { opacity: 1; }
    }
    @keyframes acqua-scorre {
      from { background-position-x: 0; }
      to   { background-position-x: 70px; }
    }

    @keyframes barca-entra {
      0%   { transform: translateX(calc(-50% - 80px)) translateY(4px); opacity: 0; }
      55%  { transform: translateX(-50%) translateY(-2px); opacity: 1; }
      75%  { transform: translateX(-50%) translateY(1px); opacity: 1; }
      90%  { transform: translateX(-50%) translateY(-0.5px); opacity: 1; }
      100% { transform: translateX(-50%) translateY(0); opacity: 1; }
    }
    @keyframes barca-bob {
      0%, 100% { transform: translateX(-50%) translateY(0); opacity: 1; }
      50%       { transform: translateX(-50%) translateY(-2.5px); opacity: 1; }
    }

    .nav-item > a .label { position: relative; }

    .nav-item > a .label::before {
      content: "";
      position: absolute; left: 50%; bottom: -1.38rem;
      width: 70px; height: 8px;
      background: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 70 8'><path d='M0 3 C 12 0 23 0 35 3 C 47 6 58 6 70 3' fill='none' stroke='%234A6670' stroke-width='1.3' opacity='0.6'/><path d='M0 5.5 C 10 3 25 3 35 5.5 C 45 8 60 8 70 5.5' fill='none' stroke='%234A6670' stroke-width='0.8' opacity='0.3'/></svg>") repeat-x;
      background-size: 70px 8px;
      opacity: 0;
      pointer-events: none;
      transform: translateX(-50%);
      transition: opacity 0.25s ease;
    }
    .nav-item:hover > a .label::before {
      animation: acqua-appare .35s .15s ease forwards,
                 acqua-scorre 2.2s .5s linear infinite;
    }
    .nav-item.active > a .label::before {
      opacity: 1;
      animation: acqua-scorre 2.2s linear infinite;
    }

    .nav-item > a .label::after {
      content: "";
      position: absolute; left: 50%; bottom: -1.05rem;
      width: 62px; height: 16px;
      background: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 70 18'><path d='M5 9 L 65 9 L 63 14 C 50 15 25 15 7 14 Z' fill='%23D8A14A'/><path d='M65 9 L 70 11.5 L 63 14' fill='%23D8A14A'/><path d='M5 6 L 9 6 L 9 9 L 5 9 Z' fill='%23D8A14A'/><line x1='18' y1='1' x2='18' y2='9' stroke='%23D8A14A' stroke-width='1.4'/><path d='M18 3 Q 42 1 62 6' fill='none' stroke='%23D8A14A' stroke-width='0.9' stroke-dasharray='3,2' opacity='0.6'/></svg>") no-repeat center / contain;
      opacity: 0;
      pointer-events: none;
      transform: translateX(calc(-50% - 80px)) translateY(4px);
      transition: opacity 0.25s ease;
    }
    .nav-item:hover > a { color: #E8F4F8; }
    .nav-item.active > a { color: #FFE0A0; }
    .nav-item:hover > a .label::after {
      animation: barca-entra .55s cubic-bezier(.2,.8,.2,1) forwards,
                 barca-bob 1.8s .7s ease-in-out infinite;
    }
    .nav-item.active > a .label::after {
      opacity: 1;
      transform: translateX(-50%) translateY(0);
      animation: none;
    }

    .nav .indicator { display: none; }

    .megapanel {
      display: block;
      position: absolute; left: 0; right: 0; top: 100%;
      background: theme('colors.paper');
      border-bottom: 1px solid theme('colors.rule');
      box-shadow: 0 24px 40px -20px rgba(31,42,42,0.14);
      transform: translateY(-12px); opacity: 0; pointer-events: none;
      transition: transform .35s cubic-bezier(.2,.7,.2,1), opacity .25s ease;
    }
    .megapanel.open { transform: translateY(0); opacity: 1; pointer-events: auto; }
    .pane {
      display: none;
      grid-template-columns: 1.1fr 1fr 1fr;
      gap: 2rem; padding: 1.6rem 2.5rem 1.8rem;
      max-width: 1400px; margin: 0 auto;
    }
    .pane.show { display: grid; }
    .lead {
      border-right: 1px dashed theme('colors.rule');
      padding-right: 1.5rem; text-decoration: none; color: inherit;
    }
    .lead .eyebrow {
      font-family: theme('fontFamily.mono');
      font-size: .75rem; text-transform: uppercase; letter-spacing: .22em;
      color: theme('colors.brand'); margin-bottom: .5rem;
    }
    .lead h4 {
      font-family: theme('fontFamily.serif');
      font-weight: 300; font-size: 1.5rem; line-height: 1.1;
      margin: 0 0 .5rem 0; letter-spacing: -0.01em;
    }
    .lead h4 :global(em) { font-style: italic; color: theme('colors.acquadeep'); }
    .lead .blurb { font-style: italic; color: theme('colors.ink-soft'); max-width: 36ch; margin: 0 0 .85rem 0; font-size: 1rem; }
    .lead .pic { aspect-ratio: 16 / 7; overflow: hidden; border-radius: 4px; background: theme('colors.paper-2'); }
    .lead .pic img {
      width: 100%; height: 100%; object-fit: cover; filter: saturate(.9);
      transition: transform .9s cubic-bezier(.2,.7,.2,1);
    }
    .lead:hover .pic img { transform: scale(1.04); }
    .lead:focus-visible {
      outline: 2px solid theme('colors.brand');
      outline-offset: 4px;
      border-radius: 6px;
    }

    .links { display: flex; flex-direction: column; gap: .15rem; }
    .links h5 {
      font-family: theme('fontFamily.mono');
      font-size: .75rem; text-transform: uppercase; letter-spacing: .22em;
      color: theme('colors.ink-soft'); margin: 0 0 .45rem 0; font-weight: 500;
    }
    .links a {
      text-decoration: none; color: theme('colors.ink');
      font-family: theme('fontFamily.serif');
      font-size: 1.15rem; padding: .42rem 0;
      border-bottom: 1px solid theme('colors.rule');
      display: flex; justify-content: space-between; align-items: center;
      transition: padding .25s ease, color .25s ease;
      border-radius: 3px;
    }
    .links a:hover { padding-left: .5rem; color: theme('colors.brand'); }
    .links a:focus-visible {
      outline: 2px solid theme('colors.brand');
      outline-offset: 2px;
      padding-left: .5rem;
      color: theme('colors.brand');
    }
    .links a :global(em) { font-style: italic; color: theme('colors.acquadeep'); }
    .links a .arrow {
      font-family: theme('fontFamily.mono'); color: theme('colors.brand');
      opacity: 0; transform: translateX(-6px);
      transition: opacity .25s ease, transform .3s ease;
    }
    .links a:hover .arrow,
    .links a:focus-visible .arrow { opacity: 1; transform: translateX(0); }

    .lang {
      position: relative;
      display: flex; gap: .15rem;
      font-family: theme('fontFamily.mono'); font-size: .82rem;
      background: rgba(255,255,255,0.10);
      border: 1px solid rgba(232,244,248,0.18);
      border-radius: 999px; padding: .2rem;
    }
    /* sliding pill */
    .lang-pill {
      position: absolute;
      top: .2rem; bottom: .2rem; left: .2rem;
      width: calc(50% - .275rem);
      border-radius: 999px;
      background: theme('colors.brand');
      transition: transform .4s cubic-bezier(.34, 1.56, .64, 1);
      pointer-events: none;
      overflow: hidden;
    }
    .lang-pill::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(
        105deg,
        transparent 35%,
        rgba(255,255,255,0.22) 50%,
        transparent 65%
      );
      background-size: 250% 100%;
      animation: lang-shimmer 3.5s ease-in-out infinite;
    }
    @keyframes lang-shimmer {
      0%   { background-position: 250% center; }
      45%  { background-position: -250% center; }
      100% { background-position: -250% center; }
    }
    .lang[data-active="en"] .lang-pill {
      transform: translateX(calc(100% + .15rem));
    }
    .lang a {
      position: relative; z-index: 1;
      padding: .35rem .75rem; text-decoration: none;
      color: rgba(232,244,248,0.70);
      border-radius: 999px;
      display: flex; align-items: center; gap: .4rem;
      transition: color .25s ease;
    }
    .lang a.on { color: #E8F4F8; }
    .lang a:not(.on):hover { color: #E8F4F8; }
    .lang a:focus-visible { outline: 2px solid theme('colors.gold'); outline-offset: 2px; }

    .burger { display: none; }

    /* ── Carousel scopri ── */
    .carousel-lead {
      position: relative;
      border-right: 1px dashed theme('colors.rule');
      padding-right: 1.5rem;
      min-height: 190px;
    }
    .cs {
      position: absolute;
      inset: 0 2rem 0 0;
      border-radius: 8px;
      overflow: hidden;
      opacity: 0;
      pointer-events: none;
      transition: opacity .55s ease;
      text-decoration: none;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
    }
    .cs--active { opacity: 1; pointer-events: auto; }
    .cs img {
      position: absolute; inset: 0;
      width: 100%; height: 100%;
      object-fit: cover;
      filter: saturate(.75) brightness(.92);
      transition: transform .9s cubic-bezier(.2,.7,.2,1);
    }
    .cs--active img { transform: scale(1.04); }
    .cs-content {
      position: relative; z-index: 1;
      background: linear-gradient(transparent, rgba(15,22,28,0.82));
      padding: 1.8rem 1rem .75rem;
      color: #E8F4F8;
    }
    .cs-eyebrow {
      font-family: theme('fontFamily.mono');
      font-size: .72rem;
      text-transform: uppercase;
      letter-spacing: .2em;
      color: theme('colors.gold');
      margin: 0 0 .35rem;
    }
    .cs h4 {
      font-family: theme('fontFamily.serif');
      font-weight: 300;
      font-size: 1.25rem;
      line-height: 1.1;
      margin: 0 0 .2rem;
      color: #E8F4F8;
    }
    .cs-blurb {
      font-size: .85rem;
      font-style: italic;
      color: rgba(232,244,248,0.75);
      margin: 0;
      line-height: 1.35;
    }
    .cs-dots {
      position: absolute;
      bottom: .75rem; right: 2.65rem;
      display: flex; gap: .4rem; z-index: 2;
    }
    .cs-dot {
      width: 6px; height: 6px;
      border-radius: 50%;
      border: none; padding: 0;
      background: rgba(232,244,248,0.35);
      cursor: pointer;
      transition: background .25s ease, transform .25s ease;
    }
    .cs-dot--active {
      background: theme('colors.gold');
      transform: scale(1.35);
    }
  }
</style>

<script>
  (function () {
    const nav = document.getElementById('nav');
    if (!nav) return;
    const items = nav.querySelectorAll('.nav-item');
    const indicator = document.getElementById('indicator') as HTMLElement | null;
    const panel = document.getElementById('megapanel');
    const panes = panel?.querySelectorAll('.pane') ?? [];
    const topbar = document.querySelector('.topbar');
    let hoverTimer: number | null = null;

    function setExpanded(key: string | null) {
      items.forEach((item) => {
        const a = item.querySelector('a');
        if (a) a.setAttribute('aria-expanded', (item as HTMLElement).dataset.pane === key ? 'true' : 'false');
      });
    }
    function showPane(key: string | null) {
      panes.forEach((p) => p.classList.toggle('show', (p as HTMLElement).dataset.pane === key));
      panel?.classList.add('open');
      setExpanded(key);
    }
    function closePanel() {
      panel?.classList.remove('open');
      panes.forEach((p) => p.classList.remove('show'));
      setExpanded(null);
    }
    function moveIndicator(item: Element) {
      if (!indicator) return;
      const navRect = nav.getBoundingClientRect();
      const r = item.getBoundingClientRect();
      indicator.style.left = (r.left - navRect.left + r.width * 0.18) + 'px';
      indicator.style.width = (r.width * 0.64) + 'px';
    }

    items.forEach((item) => {
      item.addEventListener('mouseenter', () => {
        if (hoverTimer) { clearTimeout(hoverTimer); hoverTimer = null; }
        moveIndicator(item);
        showPane((item as HTMLElement).dataset.pane ?? null);
      });
      // Keyboard: focus opens the pane
      item.addEventListener('focusin', () => {
        if (hoverTimer) { clearTimeout(hoverTimer); hoverTimer = null; }
        moveIndicator(item);
        showPane((item as HTMLElement).dataset.pane ?? null);
      });
    });
    topbar?.addEventListener('mouseleave', () => {
      hoverTimer = window.setTimeout(closePanel, 120);
    });
    // Close when focus leaves topbar entirely
    topbar?.addEventListener('focusout', (e) => {
      if (!topbar.contains((e as FocusEvent).relatedTarget as Node | null)) {
        hoverTimer = window.setTimeout(closePanel, 120);
      }
    });
    panel?.addEventListener('mouseenter', () => { if (hoverTimer) { clearTimeout(hoverTimer); hoverTimer = null; } });
    panel?.addEventListener('mouseleave', () => { hoverTimer = window.setTimeout(closePanel, 120); });
    // ESC closes the panel
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && panel?.classList.contains('open')) {
        closePanel();
        (document.querySelector('.nav-item:hover a, .nav-item:focus-within a') as HTMLElement | null)?.focus();
      }
    });

    const path = window.location.pathname;
    let activeEl: Element | null = null;
    items.forEach((item) => {
      const a = item.querySelector('a') as HTMLAnchorElement | null;
      if (!a) return;
      const href = a.getAttribute('href') || '';
      if (href !== '/' && path.startsWith(href)) { item.classList.add('active'); activeEl = item; }
    });
    window.addEventListener('resize', () => {
      const a = nav.querySelector('.nav-item.active');
      if (a) moveIndicator(a);
    });

    // Carousel scopri
    const carousel = document.getElementById('scopriCarousel');
    if (carousel) {
      const slides = carousel.querySelectorAll<HTMLElement>('.cs');
      const dots   = carousel.querySelectorAll<HTMLElement>('.cs-dot');
      let current = 0;
      let timer: number | null = null;

      function goTo(n: number) {
        slides[current].classList.remove('cs--active');
        dots[current].classList.remove('cs-dot--active');
        current = ((n % slides.length) + slides.length) % slides.length;
        slides[current].classList.add('cs--active');
        dots[current].classList.add('cs-dot--active');
      }
      function start() { timer = window.setInterval(() => goTo(current + 1), 3800); }
      function stop()  { if (timer) { clearInterval(timer); timer = null; } }

      start();
      carousel.addEventListener('mouseenter', stop);
      carousel.addEventListener('mouseleave', start);
      dots.forEach((dot, i) => dot.addEventListener('click', (e) => {
        e.preventDefault(); stop(); goTo(i); start();
      }));
    }

    // Lang pill slide on click
    const langToggle = document.getElementById('lang-toggle') as HTMLElement | null;
    langToggle?.querySelectorAll<HTMLAnchorElement>('a[data-lang]').forEach((a) => {
      a.addEventListener('click', () => {
        if (langToggle.dataset.active !== a.dataset.lang) {
          langToggle.dataset.active = a.dataset.lang ?? langToggle.dataset.active;
        }
      });
    });

    const burger  = document.getElementById('burger') as HTMLButtonElement | null;
    const drawer  = document.getElementById('drawer');
    const overlay = document.getElementById('drawerOverlay');
    const closeBtn = document.getElementById('drawerClose');

    function openDrawer() {
      drawer?.classList.add('open');
      overlay?.classList.add('open');
      burger?.classList.add('open');
      burger?.setAttribute('aria-expanded', 'true');
      (drawer?.querySelector('.drawer-toggle') as HTMLElement | null)?.focus();
    }
    function closeDrawer() {
      drawer?.classList.remove('open');
      overlay?.classList.remove('open');
      burger?.classList.remove('open');
      burger?.setAttribute('aria-expanded', 'false');
      burger?.focus();
    }

    burger?.addEventListener('click', () => {
      drawer?.classList.contains('open') ? closeDrawer() : openDrawer();
    });
    closeBtn?.addEventListener('click', closeDrawer);
    overlay?.addEventListener('click', closeDrawer);

    drawer?.addEventListener('keydown', (e) => {
      if ((e as KeyboardEvent).key === 'Escape') closeDrawer();
    });

    // Accordion toggles — removed (drawer items are now direct links)
  })();
</script>
