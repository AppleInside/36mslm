---
import { localizedPath } from '../i18n/utils';
import type { DbEvent } from '../server/db';

const { event } = Astro.props as { event: DbEvent };
const lang = event.lang;
const href = localizedPath(lang, `eventi/${event.slug}`);

const d = new Date(event.date);
const day = d.getUTCDate();
const months = lang === 'it'
  ? ['gen','feb','mar','apr','mag','giu','lug','ago','set','ott','nov','dic']
  : ['jan','feb','mar','apr','may','jun','jul','aug','sep','oct','nov','dec'];
const mon = months[d.getUTCMonth()];
---

<a href={href} class="ev-card">
  <div class="ev-pic">
    {event.cover_url
      ? <img src={event.cover_url} alt={event.title} class="ev-cover" loading="lazy" />
      : <div class="ev-placeholder" aria-hidden="true"></div>
    }
    <div class="ev-stamp">
      <span class="ev-d">{day}</span>
      <span class="ev-m">{mon}</span>
    </div>
  </div>
  <div class="ev-body">
    <p class="ev-where">{event.location}</p>
    <h3 class="ev-title">{event.title}</h3>
    {event.signup_required && (
      <span class="ev-badge">
        {lang === 'it' ? 'Iscrizione richiesta' : 'Registration required'}
      </span>
    )}
  </div>
</a>

<style>
  .ev-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: theme('colors.ink');
    border-radius: 10px;
    overflow: hidden;
    background: theme('colors.sabbia');
    border: 1px solid rgba(31,42,42,.1);
    box-shadow: 0 2px 12px rgba(31,42,42,0.07);
    transition: transform .3s ease, box-shadow .3s ease;
  }
  .ev-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 32px rgba(31,42,42,0.14);
    color: theme('colors.ink');
  }

  .ev-pic {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: theme('colors.acqua');
  }

  .ev-placeholder {
    width: 100%; height: 100%;
    background: linear-gradient(135deg, theme('colors.acqua'), theme('colors.argento') 80%);
    opacity: .6;
  }
  .ev-cover {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
  }

  .ev-stamp {
    position: absolute;
    top: .9rem; left: .9rem;
    background: theme('colors.sabbia');
    color: theme('colors.ink');
    padding: .45rem .65rem;
    line-height: 1;
    text-align: center;
    border-radius: 3px;
    box-shadow: 0 2px 8px rgba(31,42,42,0.18);
    transform: rotate(-2.5deg);
  }
  .ev-d {
    font-family: theme('fontFamily.serif');
    font-size: 1.7rem;
    font-weight: 300;
    font-style: italic;
    display: block;
  }
  .ev-m {
    font-family: theme('fontFamily.mono');
    font-size: .62rem;
    text-transform: uppercase;
    letter-spacing: .2em;
    display: block;
    margin-top: .1rem;
    color: theme('colors.ink-soft');
  }

  .ev-body {
    padding: 1.1rem 1.2rem 1.35rem;
    display: flex;
    flex-direction: column;
    gap: .3rem;
    flex: 1;
  }
  .ev-where {
    font-family: theme('fontFamily.mono');
    font-size: .7rem;
    text-transform: uppercase;
    letter-spacing: .18em;
    color: theme('colors.ink-soft');
    margin: 0;
  }
  .ev-title {
    font-family: theme('fontFamily.hand');
    font-size: 1.55rem;
    font-weight: 700;
    line-height: 1.15;
    margin: .1rem 0 0;
    color: theme('colors.ink');
  }
  .ev-badge {
    display: inline-flex;
    align-items: center;
    gap: .35rem;
    margin-top: .5rem;
    font-family: theme('fontFamily.mono');
    font-size: .65rem;
    text-transform: uppercase;
    letter-spacing: .18em;
    color: theme('colors.gold-deep');
  }
  .ev-badge::before {
    content: "→";
  }
</style>
