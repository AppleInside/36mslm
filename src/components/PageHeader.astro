---
interface Props {
  eyebrow?: string;
  bg?: string;
  pageKey?: string;
}
const { eyebrow, bg, pageKey } = Astro.props;
---
<section
  class:list={['page-header', bg && 'has-bg']}
  style={bg ? `--ph-bg: url('${bg}')` : undefined}
  data-page-key={pageKey || undefined}
>
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <h1><slot /></h1>

  {pageKey && (
    <>
      {/* Overlay: captures drag/wheel events in edit mode, sits above content but below bar */}
      <div class="ph-overlay" id={`ph-overlay-${pageKey}`}></div>

      <button class="ph-edit-btn" id={`ph-editbtn-${pageKey}`} aria-label="Modifica copertina" title="Modifica copertina" style="display:none">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="3" width="18" height="18" rx="2"/>
          <circle cx="8.5" cy="8.5" r="1.5"/>
          <polyline points="21 15 16 10 5 21"/>
        </svg>
      </button>

      <div class="ph-bar" id={`ph-bar-${pageKey}`} style="display:none">
        <span class="ph-drag-hint">trascina · scorri per zoom</span>
        <div class="ph-zoom-wrap">
          <svg class="ph-zoom-icon" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="5" y1="12" x2="19" y2="12"/></svg>
          <input type="range" class="ph-zoom-slider" id={`ph-zoom-${pageKey}`} min="100" max="500" step="5" value="100" disabled />
          <svg class="ph-zoom-icon" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        </div>
        <div class="ph-bar-actions">
          <label class="ph-pick">
            <input type="file" accept="image/*" id={`ph-file-${pageKey}`} />
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
            CARICA IMMAGINE
          </label>
          <button class="ph-btn-cancel" id={`ph-cancel-${pageKey}`}>Annulla</button>
          <button class="ph-btn-confirm" id={`ph-confirm-${pageKey}`} disabled>Conferma</button>
        </div>
      </div>
    </>
  )}
</section>

{pageKey && (
  <script is:inline data-page-key={pageKey}>
  (function() {
    var pk = document.currentScript.getAttribute('data-page-key');
    function el(id) { return document.getElementById(id); }

    var section    = document.querySelector('[data-page-key="' + pk + '"]');
    var overlay    = el('ph-overlay-'  + pk);
    var editBtn    = el('ph-editbtn-'  + pk);
    var bar        = el('ph-bar-'      + pk);
    var fileInp    = el('ph-file-'     + pk);
    var cancelBtn  = el('ph-cancel-'   + pk);
    var confirmBtn = el('ph-confirm-'  + pk);
    var zoomSlider = el('ph-zoom-'     + pk);

    if (!section || !overlay || !editBtn) return;

    // ── Saved state (for cancel) ───────────────────────────────
    var origStyle = '', origHasBg = false;

    // ── Edit state ─────────────────────────────────────────────
    var editFile = null;
    var imgNatW  = 0, imgNatH = 0;
    var zoom     = 1.0;
    var panX     = 0, panY = 0;

    // ── Drag state ─────────────────────────────────────────────
    var dragging = false;
    var dragX0, dragY0, dragPX0, dragPY0;

    // ── Geometry helpers ───────────────────────────────────────
    function coverScale() {
      return Math.max(section.clientWidth / imgNatW, section.clientHeight / imgNatH);
    }
    function scaledDims() {
      var s = coverScale() * zoom;
      return { w: imgNatW * s, h: imgNatH * s };
    }
    function clamp(val, lo, hi) { return Math.min(hi, Math.max(lo, val)); }
    function clampPan(x, y, d) {
      return {
        x: clamp(x, -(d.w - section.clientWidth),  0),
        y: clamp(y, -(d.h - section.clientHeight), 0)
      };
    }

    function applyTransform() {
      if (!imgNatW) return;
      var d = scaledDims();
      var p = clampPan(panX, panY, d);
      panX = p.x; panY = p.y;
      section.style.backgroundSize     = Math.round(d.w) + 'px ' + Math.round(d.h) + 'px';
      section.style.backgroundPosition = Math.round(panX) + 'px ' + Math.round(panY) + 'px';
      if (zoomSlider) zoomSlider.value = String(Math.round(zoom * 100));
    }

    function centerPan() {
      var d = scaledDims();
      panX = -(d.w - section.clientWidth)  / 2;
      panY = -(d.h - section.clientHeight) / 2;
    }

    // ── Load saved cover ───────────────────────────────────────
    function applySavedCover(url, posStr) {
      section.style.setProperty('--ph-bg', "url('" + url + "')");
      section.classList.add('has-bg');
      if (posStr && posStr.indexOf('size:') === 0) {
        var sm = posStr.match(/size:([^|]+)/);
        var pm = posStr.match(/\|pos:(.+)$/);
        if (sm) section.style.backgroundSize     = sm[1].trim();
        if (pm) section.style.backgroundPosition = pm[1].trim();
      } else if (posStr) {
        section.style.backgroundPosition = posStr;
      }
    }

    // ── Admin check ────────────────────────────────────────────
    fetch('/api/admin/me')
      .then(function(r) { return r.json(); })
      .then(function(d) { if (d && d.ok) editBtn.style.display = 'flex'; })
      .catch(function() {});

    // ── Load existing DB cover ─────────────────────────────────
    fetch('/api/covers/' + pk)
      .then(function(r) { return r.json(); })
      .then(function(d) { if (d) applySavedCover(d.cover_url, d.cover_position); })
      .catch(function() {});

    // ── Enter edit mode ────────────────────────────────────────
    editBtn.addEventListener('click', function(e) {
      e.stopPropagation();
      origStyle = section.getAttribute('style') || '';
      origHasBg = section.classList.contains('has-bg');
      editFile  = null; imgNatW = 0; zoom = 1.0;
      panX = 0; panY = 0;
      fileInp.value = '';
      confirmBtn.disabled = true;
      if (zoomSlider) { zoomSlider.value = '100'; zoomSlider.disabled = true; }

      section.classList.add('ph-editing');
      overlay.style.pointerEvents = 'auto';
      overlay.style.cursor = 'grab';
      bar.style.display = 'flex';
      editBtn.style.display = 'none';
    });

    // ── Cancel ─────────────────────────────────────────────────
    function cancelEdit() {
      // Restore exact inline style saved at edit-mode entry (reliable across all scenarios)
      section.setAttribute('style', origStyle);
      if (origHasBg) section.classList.add('has-bg');
      else section.classList.remove('has-bg');
      overlay.style.pointerEvents = '';
      overlay.style.cursor = '';
      section.classList.remove('ph-editing');
      bar.style.display = 'none';
      editBtn.style.display = 'flex';
      if (zoomSlider) { zoomSlider.value = '100'; zoomSlider.disabled = true; }
      editFile = null; imgNatW = 0;
    }
    cancelBtn.addEventListener('click', cancelEdit);

    // ── File pick → live preview + load dimensions ─────────────
    fileInp.addEventListener('change', function() {
      var f = fileInp.files && fileInp.files[0];
      if (!f) return;
      editFile = f;
      var reader = new FileReader();
      reader.onload = function(ev) {
        var dataUrl = String(ev.target.result);
        var img = new Image();
        img.onload = function() {
          imgNatW = img.naturalWidth  || 1;
          imgNatH = img.naturalHeight || 1;
          zoom    = 1.0;
          section.style.setProperty('--ph-bg', "url('" + dataUrl + "')");
          section.classList.add('has-bg');
          if (zoomSlider) { zoomSlider.value = '100'; zoomSlider.disabled = false; }
          centerPan();
          applyTransform();
          confirmBtn.disabled = false;
        };
        img.onerror = function() {
          // Fallback: show image but without pixel math
          section.style.setProperty('--ph-bg', "url('" + dataUrl + "')");
          section.classList.add('has-bg');
          confirmBtn.disabled = false;
        };
        img.src = dataUrl;
      };
      reader.readAsDataURL(f);
    });

    // ── Zoom slider ────────────────────────────────────────────
    function zoomTowardCenter(newZoom) {
      var prev = zoom;
      zoom = clamp(newZoom, 1.0, 5.0);
      if (zoom === prev) return;
      var ratio = zoom / prev;
      var cx = section.clientWidth  / 2;
      var cy = section.clientHeight / 2;
      panX = cx + ratio * (panX - cx);
      panY = cy + ratio * (panY - cy);
      applyTransform();
    }

    if (zoomSlider) {
      zoomSlider.addEventListener('input', function() {
        if (!imgNatW) return;
        zoomTowardCenter(parseInt(zoomSlider.value) / 100);
      });
    }

    // ── Wheel → zoom (attached to overlay) ────────────────────
    overlay.addEventListener('wheel', function(e) {
      if (!imgNatW) return;
      e.preventDefault();
      zoomTowardCenter(zoom + (e.deltaY < 0 ? 0.1 : -0.1));
    }, { passive: false });

    // ── Drag → pan (attached to overlay) ──────────────────────
    overlay.addEventListener('mousedown', function(e) {
      if (!imgNatW) return;
      dragging = true;
      dragX0 = e.clientX; dragY0 = e.clientY;
      dragPX0 = panX;      dragPY0 = panY;
      overlay.style.cursor = 'grabbing';
      e.preventDefault();
    });

    document.addEventListener('mousemove', function(e) {
      if (!dragging) return;
      panX = dragPX0 + (e.clientX - dragX0);
      panY = dragPY0 + (e.clientY - dragY0);
      applyTransform();
    });

    document.addEventListener('mouseup', function() {
      if (dragging) overlay.style.cursor = 'grab';
      dragging = false;
    });

    // Touch pan
    overlay.addEventListener('touchstart', function(e) {
      if (!imgNatW || e.touches.length !== 1) return;
      dragging = true;
      var t = e.touches[0];
      dragX0 = t.clientX; dragY0 = t.clientY;
      dragPX0 = panX;      dragPY0 = panY;
    }, { passive: true });

    document.addEventListener('touchmove', function(e) {
      if (!dragging || e.touches.length !== 1) return;
      var t = e.touches[0];
      panX = dragPX0 + (t.clientX - dragX0);
      panY = dragPY0 + (t.clientY - dragY0);
      applyTransform();
    }, { passive: true });

    document.addEventListener('touchend', function() { dragging = false; });

    // ── Save ───────────────────────────────────────────────────
    confirmBtn.addEventListener('click', function() {
      if (!editFile) return;
      confirmBtn.disabled = true;
      confirmBtn.textContent = '...';

      var fd = new FormData();
      fd.append('cover', editFile);

      if (imgNatW) {
        var d   = scaledDims();
        var p   = clampPan(panX, panY, d);
        var enc = 'size:' + Math.round(d.w) + 'px ' + Math.round(d.h) + 'px'
                + '|pos:' + Math.round(p.x) + 'px '  + Math.round(p.y) + 'px';
        fd.append('position', enc);
      } else {
        fd.append('position', 'center 30%');
      }

      fetch('/api/covers/' + pk, { method: 'POST', body: fd })
        .then(function(r) { return r.json(); })
        .then(function(resp) {
          if (resp && resp.ok) applySavedCover(resp.cover_url, resp.cover_position);
          overlay.style.pointerEvents = '';
          overlay.style.cursor = '';
          section.classList.remove('ph-editing');
          bar.style.display = 'none';
          editBtn.style.display = 'flex';
          if (zoomSlider) { zoomSlider.value = '100'; zoomSlider.disabled = true; }
          editFile = null; imgNatW = 0;
          confirmBtn.textContent = 'Conferma';
        })
        .catch(function() {
          confirmBtn.disabled    = false;
          confirmBtn.textContent = 'Conferma';
        });
    });
  })();
  </script>
)}

<style>
  .page-header {
    padding: 2.4rem 1.25rem 1.6rem;
    border-bottom: 1px solid theme('colors.rule');
    position: relative;
  }
  .eyebrow {
    font-family: theme('fontFamily.mono');
    font-size: .75rem;
    text-transform: uppercase;
    letter-spacing: .22em;
    color: theme('colors.ink-soft');
    margin-bottom: .5rem;
    position: relative;
    z-index: 1;
  }
  h1 {
    font-size: clamp(1.9rem, 6.4vw, 4rem);
    margin: 0;
    line-height: 1.05;
    position: relative;
    z-index: 1;
  }
  h1 :global(em) { color: theme('colors.acquadeep'); }

  /* ── With background image ── */
  .has-bg {
    background-image: var(--ph-bg);
    background-size: cover;
    background-position: center 30%;
    min-height: 125px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    border-bottom: none;
  }
  .has-bg::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(15,22,28,0.28) 0%, rgba(15,22,28,0.68) 100%);
    pointer-events: none;
  }
  .has-bg .eyebrow { color: rgba(232,244,248,0.75); }
  .has-bg h1 { color: #fff; text-shadow: 0 2px 16px rgba(0,0,0,0.4); }
  .has-bg h1 :global(em) { color: theme('colors.gold'); }

  /* ── Overlay: intercepts drag/wheel in edit mode ── */
  .ph-overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    cursor: grab;
    user-select: none;
  }
  .ph-editing .ph-overlay {
    pointer-events: auto;
  }
  .ph-editing .ph-overlay:active {
    cursor: grabbing;
  }

  /* ── Edit button ── */
  .ph-edit-btn {
    position: absolute;
    bottom: .75rem;
    right: .75rem;
    z-index: 4;
    width: 2.2rem;
    height: 2.2rem;
    border-radius: 50%;
    border: none;
    background: rgba(15,22,28,.55);
    backdrop-filter: blur(6px);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background .15s, transform .12s;
    box-shadow: 0 1px 8px rgba(0,0,0,.2), 0 0 0 1px rgba(255,255,255,.1);
  }
  .ph-edit-btn:hover { background: rgba(15,22,28,.82); transform: scale(1.08); }

  /* ── Edit mode outline ── */
  .ph-editing {
    outline: 2px solid rgba(216,161,74,.55);
    outline-offset: -2px;
    isolation: isolate;
  }

  /* ── Bar ── */
  .ph-bar {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    z-index: 3;
    display: flex;
    align-items: center;
    gap: .65rem;
    padding: .55rem .85rem;
    background: rgba(10,18,22,.78);
    backdrop-filter: blur(10px);
    flex-wrap: wrap;
  }

  .ph-drag-hint {
    font-family: theme('fontFamily.mono');
    font-size: .58rem;
    text-transform: uppercase;
    letter-spacing: .1em;
    color: rgba(232,240,248,.32);
    flex: 1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .ph-zoom-wrap {
    display: flex;
    align-items: center;
    gap: .3rem;
    flex-shrink: 0;
  }
  .ph-zoom-icon {
    color: rgba(232,240,248,.35);
    flex-shrink: 0;
  }
  .ph-zoom-slider {
    -webkit-appearance: none;
    appearance: none;
    width: 80px;
    height: 3px;
    border-radius: 2px;
    background: rgba(232,240,248,.2);
    outline: none;
    cursor: pointer;
    transition: opacity .15s;
  }
  .ph-zoom-slider:disabled { opacity: .3; cursor: default; }
  .ph-zoom-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: rgba(216,161,74,.9);
    cursor: pointer;
    transition: transform .1s;
  }
  .ph-zoom-slider:not(:disabled)::-webkit-slider-thumb:hover { transform: scale(1.2); }
  .ph-zoom-slider::-moz-range-thumb {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: rgba(216,161,74,.9);
    border: none;
    cursor: pointer;
  }

  .ph-bar-actions { display: flex; gap: .4rem; flex-shrink: 0; align-items: center; }

  .ph-pick {
    display: flex;
    align-items: center;
    gap: .35rem;
    font-family: theme('fontFamily.mono');
    font-size: .62rem;
    text-transform: uppercase;
    letter-spacing: .12em;
    color: rgba(232,240,248,.75);
    cursor: pointer;
    padding: .3rem .65rem;
    border: 1px solid rgba(232,240,248,.18);
    border-radius: 5px;
    transition: border-color .14s, color .14s;
    flex-shrink: 0;
  }
  .ph-pick:hover { border-color: rgba(232,240,248,.45); color: #fff; }
  .ph-pick input[type="file"] { display: none; }

  .ph-btn-cancel,
  .ph-btn-confirm {
    font-family: theme('fontFamily.mono');
    font-size: .62rem;
    text-transform: uppercase;
    letter-spacing: .12em;
    border: none;
    border-radius: 5px;
    padding: .35rem .85rem;
    cursor: pointer;
    transition: background .13s, opacity .13s;
  }
  .ph-btn-cancel { background: rgba(232,240,248,.1); color: rgba(232,240,248,.65); }
  .ph-btn-cancel:hover { background: rgba(232,240,248,.18); color: #fff; }
  .ph-btn-confirm { background: theme('colors.gold'); color: #0b1114; font-weight: 500; }
  .ph-btn-confirm:hover:not(:disabled) { filter: brightness(1.1); }
  .ph-btn-confirm:disabled { opacity: .35; cursor: default; }

  @media (min-width: 1000px) {
    .page-header { padding: 4rem 4rem 2.4rem; }
    .has-bg { min-height: 272px; }
  }
</style>
