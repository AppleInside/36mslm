---
interface Props {
  eyebrow?: string;
  bg?: string;
}
const { eyebrow, bg } = Astro.props;
---
<section class:list={['page-header', bg && 'has-bg']} style={bg ? `--ph-bg: url('${bg}')` : undefined}>
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <h1><slot /></h1>
</section>

<style>
  .page-header {
    padding: 2.4rem 1.25rem 1.6rem;
    border-bottom: 1px solid theme('colors.rule');
    position: relative;
  }
  .eyebrow {
    font-family: theme('fontFamily.mono');
    font-size: .75rem;
    text-transform: uppercase;
    letter-spacing: .22em;
    color: theme('colors.ink-soft');
    margin-bottom: .5rem;
    position: relative;
    z-index: 1;
  }
  h1 {
    font-size: clamp(1.9rem, 6.4vw, 4rem);
    margin: 0;
    line-height: 1.05;
    position: relative;
    z-index: 1;
  }
  h1 :global(em) { color: theme('colors.acquadeep'); }

  /* ── With background image ── */
  .has-bg {
    background-image: var(--ph-bg);
    background-size: cover;
    background-position: center 30%;
    min-height: 125px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    border-bottom: none;
  }
  .has-bg::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(15,22,28,0.28) 0%,
      rgba(15,22,28,0.68) 100%
    );
  }
  .has-bg .eyebrow {
    color: rgba(232,244,248,0.75);
  }
  .has-bg h1 {
    color: #fff;
    text-shadow: 0 2px 16px rgba(0,0,0,0.4);
  }
  .has-bg h1 :global(em) {
    color: theme('colors.gold');
  }

  @media (min-width: 1000px) {
    .page-header { padding: 4rem 4rem 2.4rem; }
    .has-bg { min-height: 272px; }
  }
</style>
