---
import { SITE } from '../consts';
import { sql } from '../server/db';
import pkg from '../../package.json';

interface Props {
  title: string;
  userDisplayName: string;
}
const { title, userDisplayName } = Astro.props;
const pathname = Astro.url.pathname;

let unreadSegnalazioni = 0;
try {
  const rows = await sql<{ n: string }[]>`
    SELECT (
      (SELECT COUNT(*) FROM reports        WHERE read = false) +
      (SELECT COUNT(*) FROM notice_responses WHERE read = false)
    )::text AS n
  `;
  unreadSegnalazioni = parseInt(rows[0]?.n ?? '0');
} catch { /* tables might not exist yet */ }
---
<!DOCTYPE html>
<html lang="it">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{title} · Gestione · {SITE.name}</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;1,9..144,300;1,9..144,400&family=IBM+Plex+Mono:wght@300;400;500&display=swap" />
  </head>
  <body>

    <header class="topbar">
      <div class="topbar-left">
        <button id="sidebar-toggle" class="hamburger" aria-label="Menu">
          <svg width="18" height="12" viewBox="0 0 18 12" fill="none">
            <path d="M1 1H17M1 6H11M1 11H17" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
          </svg>
        </button>
        <a href="/management/eventi" class="topbar-brand">
          <img src="/logo.jpg" alt="36 m s.l.m." class="topbar-logo" />
          <span class="brand-sub">APS<br/>Polesine Parmense</span>
        </a>
      </div>
      <div class="topbar-right">
        <span class="user-name">{userDisplayName}</span>
        <form method="POST" action="/api/management/logout">
          <button type="submit" class="exit-btn">Esci</button>
        </form>
      </div>
    </header>

    <div class="shell">
      <aside id="sidebar" class="sidebar">
        <p class="nav-label">Sezioni</p>
        <nav class="sidebar-nav">
          <a
            href="/management/eventi"
            class={`nav-item${pathname.startsWith('/management/eventi') ? ' active' : ''}`}
          >
            <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true">
              <rect x="1" y="4.5" width="13" height="9.5" rx="1.5" stroke="currentColor" stroke-width="1.25"/>
              <path d="M4.5 1V6M10.5 1V6" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
              <path d="M4 9H7M4 11.5H11" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/>
            </svg>
            <span>Eventi</span>
          </a>

          <a
            href="/management/avvisi"
            class={`nav-item${pathname.startsWith('/management/avvisi') ? ' active' : ''}`}
          >
            <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true">
              <rect x="1" y="1" width="13" height="13" rx="1.5" stroke="currentColor" stroke-width="1.25"/>
              <path d="M4 5H11M4 7.5H8.5M4 10H7" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/>
            </svg>
            <span>Avvisi</span>
          </a>

          <a
            href="/management/segnalazioni"
            class={`nav-item${pathname.startsWith('/management/segnalazioni') ? ' active' : ''}`}
          >
            <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true">
              <path d="M2 2H13V10H8.5L5 13V10H2V2Z" stroke="currentColor" stroke-width="1.25" stroke-linejoin="round"/>
              <path d="M5 5.5H10M5 7.5H8" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/>
            </svg>
            <span>Segnalazioni</span>
            {unreadSegnalazioni > 0 && (
              <span class="nav-badge">{unreadSegnalazioni > 99 ? '99+' : unreadSegnalazioni}</span>
            )}
          </a>
        </nav>

        <p class="nav-label" style="margin-top:1rem">Contenuti</p>
        <nav class="sidebar-nav">
          <a
            href="/management/itinerari"
            class={`nav-item${pathname.startsWith('/management/itinerari') ? ' active' : ''}`}
          >
            <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true">
              <path d="M2 12C2 12 4 8 7.5 6C11 4 13 3 13 3" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
              <circle cx="4.5" cy="10.5" r="1" stroke="currentColor" stroke-width="1.1"/>
              <circle cx="10" cy="5.5" r="1" stroke="currentColor" stroke-width="1.1"/>
            </svg>
            <span>Itinerari</span>
          </a>

          <a
            href="/management/fauna"
            class={`nav-item${pathname.startsWith('/management/fauna') ? ' active' : ''}`}
          >
            <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true">
              <path d="M7.5 2C7.5 2 5 4 5 6.5C5 8.5 6.5 9.5 7.5 9.5C8.5 9.5 10 8.5 10 6.5C10 4 7.5 2 7.5 2Z" stroke="currentColor" stroke-width="1.2"/>
              <path d="M7.5 9.5V13" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
              <path d="M5.5 12H9.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
            </svg>
            <span>Fauna e Flora</span>
          </a>

          <a
            href="/management/horeca"
            class={`nav-item${pathname.startsWith('/management/horeca') ? ' active' : ''}`}
          >
            <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true">
              <rect x="2" y="6" width="11" height="7" rx="1" stroke="currentColor" stroke-width="1.25"/>
              <path d="M5 6V4.5C5 3.12 6.12 2 7.5 2C8.88 2 10 3.12 10 4.5V6" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/>
              <path d="M5 9.5H10" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/>
            </svg>
            <span>Horeca</span>
          </a>
        </nav>

        <p class="nav-label" style="margin-top:1rem">Strumenti</p>
        <nav class="sidebar-nav">
          <a
            href="/management/sito"
            class={`nav-item${pathname.startsWith('/management/sito') ? ' active' : ''}`}
          >
            <svg width="15" height="15" viewBox="0 0 15 15" fill="none" aria-hidden="true">
              <circle cx="7.5" cy="7.5" r="5.5" stroke="currentColor" stroke-width="1.25"/>
              <path d="M7.5 2C7.5 2 5.5 4.5 5.5 7.5C5.5 10.5 7.5 13 7.5 13" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/>
              <path d="M7.5 2C7.5 2 9.5 4.5 9.5 7.5C9.5 10.5 7.5 13 7.5 13" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/>
              <path d="M2 7.5H13" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/>
            </svg>
            <span>Sito pubblico</span>
          </a>
        </nav>

        <div style="flex:1"></div>
        <span class="sidebar-version">v{pkg.version}</span>
      </aside>

      <main class="content">
        <slot />
      </main>
    </div>

    <script>
      const btn = document.getElementById('sidebar-toggle');
      const sidebar = document.getElementById('sidebar');
      btn?.addEventListener('click', () => sidebar?.classList.toggle('open'));
    </script>

  </body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:           #0B1918;
    --bg-topbar:    #0C1E1C;
    --bg-sidebar:   rgba(10,25,23,0.8);
    --cream:        #E8DCC8;
    --cream-dim:    rgba(232,220,200,0.45);
    --cream-faint:  rgba(232,220,200,0.10);
    --cream-ghost:  rgba(232,220,200,0.05);
    --gold:         #D8A14A;
    --teal:         #4A6670;
    --alga:         #7B8F6F;
    --ff-serif:   'Fraunces', Georgia, serif;
    --ff-mono:    'IBM Plex Mono', ui-monospace, monospace;
  }

  html, body { height: 100%; }

  body {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    background: var(--bg);
    color: var(--cream);
    font-family: var(--ff-mono);
    -webkit-font-smoothing: antialiased;
  }

  /* ── Topbar ── */
  .topbar {
    position: relative;
    z-index: 20;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.9rem 1.25rem;
    background: var(--bg-topbar);
    border-bottom: 1px solid var(--cream-ghost);
  }

  .topbar::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, rgba(216,161,74,0.35) 50%, transparent 100%);
    pointer-events: none;
  }

  .topbar-left { display: flex; align-items: center; gap: 1rem; }

  .hamburger {
    display: none;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    color: var(--cream-dim);
    cursor: pointer;
    padding: 5px;
    border-radius: 4px;
    transition: color 0.2s;
  }
  .hamburger:hover { color: var(--cream); }

  .topbar-brand {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    text-decoration: none;
  }

  .topbar-logo {
    height: 40px;
    width: auto;
    border-radius: 3px;
    display: block;
    box-shadow: 0 0 10px rgba(15,113,184,0.3);
  }

  .brand-sub {
    font-family: var(--ff-mono);
    font-size: 0.6rem;
    font-weight: 300;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(232,220,200,0.38);
    border-left: 1px solid rgba(232,220,200,0.18);
    padding-left: 0.75rem;
    line-height: 1.4;
  }

  .topbar-right { display: flex; align-items: center; gap: 1.25rem; }

  .user-name {
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--cream-dim);
  }

  .exit-btn {
    background: none;
    border: 1px solid var(--cream-faint);
    color: var(--cream-dim);
    font-family: var(--ff-mono);
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    padding: 0.32rem 0.9rem;
    border-radius: 3px;
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s;
  }
  .exit-btn:hover { border-color: rgba(216,161,74,0.45); color: var(--gold); }

  /* ── Shell ── */
  .shell { display: flex; flex: 1; min-height: 0; }

  /* ── Sidebar ── */
  .sidebar {
    width: 220px;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    background: var(--bg-sidebar);
    border-right: 1px solid var(--cream-ghost);
    padding: 1.5rem 1rem 1.5rem 1.1rem;
  }

  .nav-label {
    font-size: 0.55rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: rgba(232,220,200,0.2);
    padding: 0 0.5rem;
    margin-bottom: 0.25rem;
  }

  .sidebar-nav {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .nav-item {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.85rem 0.65rem 0.85rem 0.7rem;
    border-radius: 5px;
    font-size: 0.82rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--cream-dim);
    border-left: 2px solid transparent;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
  }

  .nav-item:hover {
    color: var(--cream);
    background: var(--cream-ghost);
  }

  .nav-item.active {
    color: var(--gold);
    border-left-color: var(--gold);
    background: rgba(216,161,74,0.07);
  }

  .nav-item--soon {
    opacity: 0.35;
    cursor: default;
    pointer-events: none;
  }

  .nav-soon-pill {
    margin-left: auto;
    font-size: 0.52rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(232,220,200,0.35);
    border: 1px solid rgba(232,220,200,0.15);
    padding: 0.1rem 0.4rem;
    border-radius: 20px;
  }

  /* ── Version ── */
  .sidebar-version {
    padding-top: .75rem;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(232,220,200,0.65);
    padding-left: 0.5rem;
  }

  /* ── Unread badge ── */
  .nav-badge {
    margin-left: auto;
    min-width: 20px;
    height: 20px;
    padding: 0 5px;
    border-radius: 10px;
    background: #D8A14A;
    color: #1A0E00;
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }

  /* ── Content ── */
  .content {
    flex: 1;
    padding: 2rem 2.5rem;
    overflow-y: auto;
    min-width: 0;
    background:
      radial-gradient(ellipse 700px 450px at 85% 0%, rgba(74,102,112,0.10), transparent 55%),
      radial-gradient(ellipse 450px 350px at 0% 100%, rgba(123,143,111,0.07), transparent 50%);
  }

  /* ── Desktop ── */
  @media (min-width: 769px) {
    .topbar { padding: 1.2rem 2rem; }
    .topbar-logo { height: 50px; }
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .hamburger { display: flex; }
    .user-name  { display: none; }

    .sidebar {
      position: fixed;
      top: 70px; left: 0; bottom: 0;
      z-index: 30;
      width: 240px;
      transform: translateX(-100%);
      transition: transform 0.28s cubic-bezier(0.22,1,0.36,1);
      background: #0B1918;
      border-right-color: rgba(232,220,200,0.08);
    }

    .sidebar.open { transform: translateX(0); }
    .content { padding: 1.25rem 1rem; }
  }
</style>
